comment_char %
escape_char /

% Minimal locale for expect_pty POSIX compliance testing.
% Compiled at suite startup via: localedef -f UTF-8 -i test_EPTY.def <outdir>/test_EPTY.UTF-8
% Used with LOCPATH=<outdir> LC_ALL=test_EPTY.UTF-8

LC_IDENTIFICATION
title      "expect_pty test locale"
language   "English"
territory  "Test"
revision   "1.0"
date       "2026-03-31"
category   "i18n:2012";LC_IDENTIFICATION
category   "i18n:2012";LC_CTYPE
category   "i18n:2012";LC_COLLATE
category   "i18n:2012";LC_TIME
category   "i18n:2012";LC_NUMERIC
category   "i18n:2012";LC_MONETARY
category   "i18n:2012";LC_MESSAGES
category   "i18n:2012";LC_PAPER
category   "i18n:2012";LC_NAME
category   "i18n:2012";LC_ADDRESS
category   "i18n:2012";LC_TELEPHONE
category   "i18n:2012";LC_MEASUREMENT
END LC_IDENTIFICATION

% Full Unicode character classification ([:alpha:], [:upper:], multi-byte)
LC_CTYPE
copy "i18n"
END LC_CTYPE

% Standard Unicode collation order (ISO 14651)
LC_COLLATE
copy "iso14651_t1"
END LC_COLLATE

% Custom yes/no expressions distinguishable from the C locale
LC_MESSAGES
yesexpr "^[+1yYoO]"
noexpr  "^[-0nN]"
yesstr  "oui"
nostr   "non"
END LC_MESSAGES

LC_MONETARY
copy "en_US"
END LC_MONETARY

LC_NUMERIC
decimal_point "."
thousands_sep ","
grouping      3;3
END LC_NUMERIC

LC_TIME
copy "en_US"
END LC_TIME

LC_PAPER
copy "en_US"
END LC_PAPER

LC_NAME
copy "en_US"
END LC_NAME

LC_ADDRESS
copy "en_US"
END LC_ADDRESS

LC_TELEPHONE
copy "en_US"
END LC_TELEPHONE

LC_MEASUREMENT
copy "en_US"
END LC_MEASUREMENT
