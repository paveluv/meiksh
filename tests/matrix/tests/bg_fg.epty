testsuite "bg/fg — Interactive Job Control Utilities"

# ==============================================================================
# bg: Resume a suspended job in the background
# ==============================================================================

requirement "SHALL-BG-1062" doc="If job control is enabled, the bg utility shall resume the execution of a currently suspended job in the background"
requirement "SHALL-BG-1031" doc="The output of bg shall consist of a line in the format: [%d] %s, <job-number>, <command>"
requirement "SHALL-BG-1065" doc="If no job_id operand is given, the most recently suspended job shall be used"
requirement "SHALL-JOBS-1237" doc="The implementation may substitute the string Suspended in place of Stopped"
requirement "SHALL-BG-1063" doc="If the job specified by job_id is already a running background job, the bg utility shall have no effect and shall exit successfully"
requirement "SHALL-BG-1029" doc="The following operand shall be supported: job_id"
requirement "SHALL-BG-1069" doc="If job control is disabled, the bg utility shall exit with an error"
requirement "SHALL-FG-1166" doc="If job control is enabled, the fg utility shall move a background job into the foreground"
requirement "SHALL-FG-1035" doc="The fg utility shall write the command line of the job to standard output in the following format: %s, <command>"
requirement "SHALL-STDERR-627" doc="The fg utility shall write the command line of the job to standard output"
requirement "SHALL-FG-1169" doc="If no job_id operand is given, the job most recently suspended, placed in the background, or run as a background job shall be used"
requirement "SHALL-FG-1047" doc="The following operand shall be supported: job_id"
requirement "SHALL-FG-1167" doc="Using fg to place a job into the foreground shall remove its process ID from the list of those known in the current shell execution environment"
requirement "SHALL-FG-1173" doc="If job control is disabled, the fg utility shall exit with an error"
requirement "SHALL-JOBS-1234" doc="The jobs utility shall display the status of jobs that were started in the current shell environment"

begin interactive test "bg: suspend with Ctrl-Z then bg"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "bg"
  expect "sleep 60"
  expect "$ "
  send "kill %1"
  expect "$ "
  sendeof
  wait
end interactive test "bg: suspend with Ctrl-Z then bg"

# ==============================================================================
# bg: Job already running in background has no effect
# ==============================================================================

begin interactive test "bg: job already running in background"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "bg %1; echo bg_exit_$?"
  expect "bg_exit_0"
  send "kill %1 2>/dev/null; wait"
  expect "$ "
  sendeof
  wait
end interactive test "bg: job already running in background"

# ==============================================================================
# bg: With explicit job_id operand
# ==============================================================================

begin interactive test "bg: with explicit job_id operand"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "bg %1"
  expect "sleep 60"
  expect "$ "
  send "kill %1 2>/dev/null; wait; true"
  expect "$ "
  sendeof
  wait
end interactive test "bg: with explicit job_id operand"

# ==============================================================================
# fg: Bring a background job to the foreground
# ==============================================================================

begin interactive test "fg: bring background job to foreground"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "fg"
  expect "sleep 60"
  sleep 200ms
  sendraw 03
  expect "$ "
  sendeof
  wait
end interactive test "fg: bring background job to foreground"

# ==============================================================================
# fg: With explicit job_id
# ==============================================================================

begin interactive test "fg: with explicit job_id"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "fg %1"
  expect "sleep 60"
  sleep 200ms
  sendraw 03
  expect "$ "
  sendeof
  wait
end interactive test "fg: with explicit job_id"

# ==============================================================================
# fg: Removes job from known process list
# ==============================================================================

begin interactive test "fg: removes job from known process list"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "fg"
  expect "sleep 60"
  sleep 200ms
  sendraw 03
  expect "$ "
  send "jobs"
  expect "$ "
  not_expect "sleep 60"
  sendeof
  wait
end interactive test "fg: removes job from known process list"

# ==============================================================================
# Suspend with Ctrl-Z and resume cycle
# ==============================================================================

begin interactive test "suspend -> bg -> fg cycle"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "bg"
  expect "sleep 60"
  expect "$ "
  send "fg"
  expect "sleep 60"
  sleep 200ms
  sendraw 03
  expect "$ "
  sendeof
  wait
end interactive test "suspend -> bg -> fg cycle"

# ==============================================================================
# bg: Error when job control is disabled
# ==============================================================================

begin test "bg: error when job control is disabled"
  begin script
    bg 2>/dev/null
  end script
  not_expect_exit_code 0
end test "bg: error when job control is disabled"

begin test "fg: error when job control is disabled"
  begin script
    fg 2>/dev/null
  end script
  not_expect_exit_code 0
end test "fg: error when job control is disabled"

# ==============================================================================
# Multiple suspended jobs — +/- marking
# ==============================================================================

begin interactive test "multiple suspended jobs with +/- marking"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "sleep 61"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "jobs"
  expect_line "\[[[:digit:]]+\]-.*(Stopped|Suspended)"
  expect_line "\[[[:digit:]]+\]\+.*(Stopped|Suspended)"
  send "kill %1 %2; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "multiple suspended jobs with +/- marking"

# ==============================================================================
# bg: Output format — POSIX "[%d] %s\n"
# ==============================================================================

begin interactive test "bg: output format POSIX [%d] %s"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "bg"
  expect "\[[[:digit:]]+\] .*sleep 60"
  expect "$ "
  send "kill %1 2>/dev/null; wait; true"
  expect "$ "
  sendeof
  wait
end interactive test "bg: output format POSIX [%d] %s"

# ==============================================================================
# bg/fg: Explicit %N job IDs with multiple jobs
# ==============================================================================

begin interactive test "bg/fg: explicit %N job IDs with multiple jobs"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "sleep 61"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended)"
  send "bg %1"
  expect "sleep 60"
  expect "$ "
  send "fg %2"
  expect "sleep 61"
  sleep 200ms
  sendraw 03
  expect "$ "
  send "kill %1 2>/dev/null; wait; true"
  expect "$ "
  sendeof
  wait
end interactive test "bg/fg: explicit %N job IDs with multiple jobs"
