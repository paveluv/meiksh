testsuite "Standard Error Usage (Diagnostic Messages)"

# ==============================================================================
# Clean Standard Error from Built-ins
# ==============================================================================

requirement "SHALL-STDERR-518" doc="The standard error shall be used only for diagnostic messages."
requirement "SHALL-STDERR-557" doc="If the resource being reported does not have a numeric limit, in the POSIX locale the following format shall be used: unlimited. STDERR The standard error shall be used only for diagnostic messages."
requirement "SHALL-STDERR-574" doc="When the -V option is specified, standard output shall be formatted as: %s, unspecified. STDERR The standard error shall be used only for diagnostic messages."
requirement "SHALL-STDERR-577" doc="If the command consists of more than one line, the lines after the first shall be displayed as: tab %s, continued-command. STDERR The standard error shall be used only for diagnostic messages."
requirement "SHALL-STDERR-622" doc="The standard error shall be used only for diagnostic messages and the warning message specified in EXIT STATUS."
requirement "SHALL-STDERR-627" doc="The fg utility shall write the command line of the job to standard output. STDERR The standard error shall be used only for diagnostic messages."
requirement "SHALL-STDERR-650" doc="The standard error shall be used only for diagnostic messages and warning messages about invalid signal names."
requirement "SHALL-STDERR-030" doc="Except as otherwise stated, standard error shall be used only for diagnostic messages."

begin test "special builtins produce no stderr on success"
  begin script
    myfunc() { for i in 1; do break >/dev/null; done; for i in 1; do continue >/dev/null; done; : >/dev/null; eval "true" >/dev/null; exec 3>&1 3>&- >/dev/null; export EXPORT_VAR=1 >/dev/null; readonly RO_VAR=1 >/dev/null; set -- a b c >/dev/null; shift 1 >/dev/null; unset EXPORT_VAR >/dev/null; return 0 >/dev/null; }
    myfunc
  end script
  expect_stderr ""
  expect_exit_code 0
end test "special builtins produce no stderr on success"
