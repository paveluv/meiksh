testsuite "Token Recognition Rules"

# ==============================================================================
# Operators vs Words
# ==============================================================================

requirement "SHALL-2-3-045" doc="If the current character is not quoted and can be used as the first character of a new operator, the current token shall be delimited"
requirement "SHALL-2-3-046" doc="The current character shall be used as the beginning of the next operator token"

begin test "unquoted > is a control operator"
  begin script
    echo a>tmp_token.txt
    cat tmp_token.txt
  end script
  expect_stdout "a"
end test "unquoted > is a control operator"

requirement "SHALL-2-3-034" doc="If the previous character was part of an operator and the current character can form an operator with it, it shall be used as part of that token"
requirement "SHALL-2-3-035" doc="If the previous character was part of an operator and the current character cannot form an operator, the operator shall be delimited"

begin test ">> forms a single append operator"
  begin script
    echo a >tmp_token.txt
    echo b >>tmp_token.txt
    cat tmp_token.txt
  end script
  expect_stdout "a\nb"
end test ">> forms a single append operator"


# ==============================================================================
# Blanks and Words
# ==============================================================================

requirement "SHALL-2-3-047" doc="If the current character is an unquoted blank, any token containing the previous character is delimited"
requirement "SHALL-2-3-048" doc="If the previous character was part of a word, the current character shall be appended to that word"

begin test "multiple blanks between words"
  begin script
    echo a      b
  end script
  expect_stdout "a b"
end test "multiple blanks between words"


# ==============================================================================
# Comments
# ==============================================================================

requirement "SHALL-2-3-049" doc="If the current character is # it and all subsequent characters up to the next newline shall be discarded as a comment"

begin test "comments ignored up to newline"
  begin script
    echo a # this is a comment
    echo b
  end script
  expect_stdout "a\nb"
end test "comments ignored up to newline"

begin test "quoted # is not a comment"
  begin script
    echo "a # not a comment"
  end script
  expect_stdout "a # not a comment"
end test "quoted # is not a comment"

begin test "# in middle of word is not a comment"
  begin script
    echo a#b
  end script
  expect_stdout "a#b"
end test "# in middle of word is not a comment"


# ==============================================================================
# Alias Substitution
# ==============================================================================

requirement "SHALL-2-3-1-052" doc="When a TOKEN is subject to alias substitution, the value of the alias shall be processed as if read from input"
requirement "SHALL-2-3-1-053" doc="An implementation may defer alias changes but they shall take effect by completion of the current complete_command"
requirement "SHALL-2-3-1-054" doc="Changes to aliases shall not take effect out of order"
requirement "SHALL-2-3-1-055" doc="Alias definitions shall not be inherited by separate invocations of the shell"

begin interactive test "alias substitution"
  spawn {{SHELL}} -i
  expect "$ "
  send "alias foo=\"echo aliased\""
  expect "$ "
  send "foo"
  expect "aliased"
  sendeof
  wait
end interactive test "alias substitution"

begin interactive test "alias with trailing space chains to next word"
  spawn {{SHELL}} -i
  expect "$ "
  send "alias a1=\"echo \""
  expect "$ "
  send "alias a2=\"chained\""
  expect "$ "
  send "a1 a2"
  expect "chained"
  sendeof
  wait
end interactive test "alias with trailing space chains to next word"
