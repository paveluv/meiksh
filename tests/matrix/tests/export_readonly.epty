testsuite "Export and Readonly Built-ins"

# ==============================================================================
# export -p output format
# ==============================================================================

requirement "SHALL-V3CHAP02-1015-DUP505" doc="export -p output format: \"export %s=%s\\n\" for set names, \"export %s\\n\" for unset"
requirement "SHALL-V3CHAP02-1016-DUP506" doc="Shell shall format export -p output with proper quoting, suitable for reinput to the shell"

begin test "export -p shows exported variable"
  begin script
    MYEXPORTVAR=hello
    export MYEXPORTVAR
    export -p | grep MYEXPORTVAR
  end script
  expect_exit_code 0
  expect_stdout_line ".*export.*MYEXPORTVAR.*hello.*"
end test "export -p shows exported variable"

begin test "export -p handles spaces in values"
  begin script
    TESTV="has spaces"
    export TESTV
    export -p | grep TESTV
  end script
  expect_exit_code 0
  expect_stdout_line ".*export.*TESTV.*"
end test "export -p handles spaces in values"

# ==============================================================================
# set -o allexport / set -a
# ==============================================================================

requirement "SHALL-V3CHAP02-1018-DUP540" doc="set -o allexport shall be equivalent to -a"

begin test "set -o allexport exports all assignments"
  begin script
    set -o allexport
    ALLEXP_VAR=allexp_val
    env | grep ALLEXP_VAR
  end script
  expect_exit_code 0
  expect_stdout_line ".*ALLEXP_VAR=allexp_val.*"
end test "set -o allexport exports all assignments"

# ==============================================================================
# readonly -p output format
# ==============================================================================

requirement "SHALL-V3CHAP02-1017-DUP513" doc="readonly -p output shall be formatted with quoting suitable for reinput"

begin test "readonly -p shows readonly variable"
  begin script
    ROVAR=roval
    readonly ROVAR
    readonly -p | grep ROVAR
  end script
  expect_exit_code 0
  expect_stdout_line ".*readonly.*ROVAR.*roval.*"
end test "readonly -p shows readonly variable"
