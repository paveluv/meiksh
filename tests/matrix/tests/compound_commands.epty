testsuite "Compound Commands"

# ==============================================================================
# The 'for' Loop
# ==============================================================================

requirement "SHALL-2-9-4-2-349" doc="The for loop shall execute a sequence of commands for each member in a list of items ."
requirement "SHALL-2-9-4-2-351" doc="Then, the variable name shall be set to each item, in turn, and the compound-list executed each time."

begin test "for loop iterates over items"
  script
    for i in a b c; do
      printf "%s " "$i"
    done
  expect
    stdout "a b c"
    stderr ""
    exit_code 0
end test "for loop iterates over items"

requirement "SHALL-2-9-4-2-352" doc="If no items result from the expansion, the compound-list shall not be executed."
requirement "SHALL-2-9-4-2-1-353" doc="If there is at least one item in the list of items, the exit status of a for command shall be the exit status of the last compound-list executed."
requirement "SHALL-2-9-4-2-1-354" doc="If there are no items, the exit status shall be zero."

begin test "for loop exit status is last command"
  script
    for i in 1 2; do
    false
    done
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 1
end test "for loop exit status is last command"

requirement "SHALL-2-9-4-1-346" doc="Variable assignments and built-in commands that affect the environment shall not remain in effect after the list finishes."
begin test "for loop with empty list does not execute body"
  script
    x=1
    for i in; do
      x=2
    done
    echo "$x"
  expect
    stdout "1"
    stderr ""
    exit_code 0
end test "for loop with empty list does not execute body"


# ==============================================================================
# The 'case' Construct
# ==============================================================================

requirement "SHALL-2-9-4-3-355" doc="The conditional construct case shall execute the compound-list corresponding to the first pattern (see 2.14 Pattern Matching Notation ), if any are present, that is matched by the string resulting from the tilde expansion, parameter expansion, command substitution, arithmetic expansion, and quote removal of the given word."
requirement "SHALL-2-9-4-3-356" doc="The reserved word in shall denote the beginning of the patterns to be matched."
requirement "SHALL-2-9-4-3-357" doc="Multiple patterns with the same compound-list shall be delimited by the '|' symbol."

begin test "case exit status from matched clause"
  script
    case "xyz" in
    abc) false ;;
    xyz) false ;;
    esac
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 1
end test "case exit status from matched clause"

requirement "SHALL-2-9-4-3-1-363" doc="The exit status of case shall be zero if no patterns are matched."
begin test "case exit status zero when no match"
  script
    case "xyz" in
    abc) false ;;
    esac
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "case exit status zero when no match"

requirement "SHALL-2-9-4-3-361" doc="If the case statement clause is terminated by \";;\" , no further clauses shall be examined."

begin test "case with pipe patterns and early exit"
  script
    case "apple" in
    banana|orange) echo "no" ;;
    apple|pear) echo "yes" ;;
    *) echo "default" ;;
    esac
  expect
    stdout "yes"
    stderr ""
    exit_code 0
end test "case with pipe patterns and early exit"

requirement "SHALL-DESCRIPTION-640" doc="When a subshell is entered, traps that are not being ignored shall be set to the default actions, except in the case of a command substitution containing only a single trap command, when the traps need not be altered."
begin test "case default wildcard match"
  script
    case "grape" in
    apple) echo "no" ;;
    *) echo "default" ;;
    esac
  expect
    stdout "default"
    stderr ""
    exit_code 0
end test "case default wildcard match"


# ==============================================================================
# The 'if' Construct
# ==============================================================================

requirement "SHALL-2-9-4-4-365" doc="The if command shall execute a compound-list and use its exit status to determine whether to execute another compound-list ."
requirement "SHALL-2-9-4-4-366" doc="The format for the if construct is as follows: if compound-list then compound-list [ elif compound-list then compound-list ] ... [ else compound-list ] fi The if compound-list shall be executed; if its exit status is zero, the then compound-list shall be executed and the command shall complete."
requirement "SHALL-2-9-4-4-367" doc="Otherwise, each elif compound-list shall be executed, in turn, and if its exit status is zero, the then compound-list shall be executed and the command shall complete."

begin test "if exit status from then clause"
  script
    if true; then
    false
    fi
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 1
end test "if exit status from then clause"

requirement "SHALL-2-9-3-319" doc="For example, both of the following commands write solely bar to standard output: false && echo foo || echo bar true || echo foo && echo bar A ';' separator or a ';' or <newline> terminator shall cause the preceding AND-OR list to be executed sequentially; an '&' separator or terminator shall cause asynchronous execution of the preceding AND-OR list."
begin test "if true branch"
  script
    if true; then
      echo "if"
    elif false; then
      echo "elif"
    else
      echo "else"
    fi
  expect
    stdout "if"
    stderr ""
    exit_code 0
end test "if true branch"

requirement "SHALL-2-9-3-319" doc="For example, both of the following commands write solely bar to standard output: false && echo foo || echo bar true || echo foo && echo bar A ';' separator or a ';' or <newline> terminator shall cause the preceding AND-OR list to be executed sequentially; an '&' separator or terminator shall cause asynchronous execution of the preceding AND-OR list."
begin test "elif true branch"
  script
    if false; then
      echo "if"
    elif true; then
      echo "elif"
    else
      echo "else"
    fi
  expect
    stdout "elif"
    stderr ""
    exit_code 0
end test "elif true branch"

requirement "SHALL-V3CHAP02-1003" doc="The following words shall be recognized as reserved words: ! { } case do done elif else esac fi for if in then until while."
begin test "else branch"
  script
    if false; then
      echo "if"
    elif false; then
      echo "elif"
    else
      echo "else"
    fi
  expect
    stdout "else"
    stderr ""
    exit_code 0
end test "else branch"


# ==============================================================================
# The 'while' Loop
# ==============================================================================

requirement "SHALL-2-9-4-5-370" doc="The while loop shall continuously execute one compound-list as long as another compound-list has a zero exit status."
requirement "SHALL-2-9-4-5-371" doc="The format of the while loop is as follows: while compound-list-1 do compound-list-2 done The compound-list-1 shall be executed, and if it has a non-zero exit status, the while command shall complete."
requirement "SHALL-2-9-4-5-372" doc="Otherwise, the compound-list-2 shall be executed, and the process shall repeat."

begin test "while loop exit status zero when body never executes"
  script
    while false; do
    true
    done
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "while loop exit status zero when body never executes"

requirement "SHALL-2-9-4-5-1-373" doc="The exit status of the while loop shall be the exit status of the last compound-list-2 executed, or zero if none was executed."
begin test "while loop exit status from last iteration"
  script
    counter=0
    while [ "$counter" -lt 1 ]; do
    counter=$((counter + 1))
    false
    done
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 1
end test "while loop exit status from last iteration"

requirement "SHALL-2-9-4-5-371" doc="The format of the while loop is as follows: while compound-list-1 do compound-list-2 done The compound-list-1 shall be executed, and if it has a non-zero exit status, the while command shall complete."
begin test "while loop iterates correctly"
  script
    x=0
    while [ $x -lt 3 ]; do
      x=$((x+1))
      printf "%s " "$x"
    done
  expect
    stdout "1 2 3"
    stderr ""
    exit_code 0
end test "while loop iterates correctly"

requirement "SHALL-2-9-4-5-370" doc="The while loop shall continuously execute one compound-list as long as another compound-list has a zero exit status."
begin test "while loop with false condition does not execute"
  script
    x=0
    while false; do
      x=$((x+1))
    done
    echo "$x"
  expect
    stdout "0"
    stderr ""
    exit_code 0
end test "while loop with false condition does not execute"


# ==============================================================================
# The 'until' Loop
# ==============================================================================

requirement "SHALL-2-9-4-6-374" doc="The until loop shall continuously execute one compound-list as long as another compound-list has a non-zero exit status."
requirement "SHALL-2-9-4-6-375" doc="The format of the until loop is as follows: until compound-list-1 do compound-list-2 done The compound-list-1 shall be executed, and if it has a zero exit status, the until command completes."
requirement "SHALL-2-9-4-6-376" doc="Otherwise, the compound-list-2 shall be executed, and the process repeats."

begin test "until loop iterates correctly"
  script
    x=0
    until [ $x -eq 3 ]; do
      x=$((x+1))
      printf "%s " "$x"
    done
  expect
    stdout "1 2 3"
    stderr ""
    exit_code 0
end test "until loop iterates correctly"

requirement "SHALL-2-9-4-6-374" doc="The until loop shall continuously execute one compound-list as long as another compound-list has a non-zero exit status."
begin test "until loop with true condition does not execute"
  script
    x=0
    until true; do
      x=$((x+1))
    done
    echo "$x"
  expect
    stdout "0"
    stderr ""
    exit_code 0
end test "until loop with true condition does not execute"


# ==============================================================================
# Grouping Commands (Subshells)
# ==============================================================================

requirement "SHALL-2-9-4-1-346" doc="Variable assignments and built-in commands that affect the environment shall not remain in effect after the list finishes."

begin test "subshell variable isolation"
  script
    FOO=parent
    (FOO=child)
    echo "$FOO"
  expect
    stdout "parent"
    stderr ""
    exit_code 0
end test "subshell variable isolation"


# ==============================================================================
# Redirections on Compound Commands
# ==============================================================================

requirement "SHALL-2-9-4-344" doc="Each redirection shall apply to all the commands within the compound command that do not explicitly override that redirection."

begin test "redirection applies to all commands in group"
  script
    { echo a; echo b; } > tmp_group.txt
    cat tmp_group.txt
  expect
    stdout "a\nb"
    stderr ""
    exit_code 0
end test "redirection applies to all commands in group"
