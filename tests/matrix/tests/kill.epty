testsuite "Kill"

# ==============================================================================
# kill — Send Signals to Processes
# ==============================================================================


requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
requirement "SHALL-KILL-1241" doc="The kill utility shall conform to XBD 12.2 Utility Syntax Guidelines , except that in the last two SYNOPSIS forms, the - signal_number and - signal_name options are usually more than a single character."
requirement "SHALL-KILL-1247" doc="The corresponding signal shall be sent instead of SIGTERM."
begin test "kill with default signal sends SIGTERM"
  script
    sleep 60 & p=$!
    kill $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill with default signal sends SIGTERM"

requirement "SHALL-KILL-1240" doc="For each pid operand, the kill utility shall perform actions equivalent to the kill () function defined in the System Interfaces volume of POSIX.1-2024 called with the following arguments: The value of the pid operand shall be used as the pid argument."
begin test "kill -s TERM sends SIGTERM"
  script
    sleep 60 & p=$!
    kill -s TERM $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -s TERM sends SIGTERM"

requirement "SHALL-KILL-1040" doc="The following environment variables shall affect the execution of kill : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "kill -s KILL sends SIGKILL"
  script
    sleep 60 & p=$!
    kill -s KILL $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -s KILL sends SIGKILL"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin test "kill -TERM abbreviated form"
  script
    sleep 60 & p=$!
    kill -TERM $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -TERM abbreviated form"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin test "kill -KILL abbreviated form"
  script
    sleep 60 & p=$!
    kill -KILL $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -KILL abbreviated form"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin test "kill -HUP abbreviated form"
  script
    sleep 60 & p=$!
    kill -HUP $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -HUP abbreviated form"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin test "kill -15 sends SIGTERM by number"
  script
    sleep 60 & p=$!
    kill -15 $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -15 sends SIGTERM by number"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin test "kill -9 sends SIGKILL by number"
  script
    sleep 60 & p=$!
    kill -9 $p
    wait $p 2>/dev/null
    echo done
  expect
    stdout "done"
    stderr ""
    exit_code 0
end test "kill -9 sends SIGKILL by number"

requirement "SHALL-KILL-1062" doc="The following options shall be supported: -l (The letter ell.) Write all values of signal_name supported by the implementation, if no operand is given."
requirement "SHALL-KILL-1065" doc="The following exit values shall be returned: 0 The -l option was specified and the output specified in STDOUT was successfully written to standard output; or, the -l option was not specified, at least one matching process was found for each pid operand, and the specified signal was successfully processed for at least one matching process."
requirement "SHALL-KILL-1253" doc="When the -l option is not specified, the standard output shall not be used."
begin test "kill -l lists standard POSIX signals"
  script
    kill -l
  expect
    stdout ".*TERM.*"
    stderr ""
    exit_code 0
end test "kill -l lists standard POSIX signals"

requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
begin test "kill -l 9 outputs KILL"
  script
    kill -l 9
  expect
    stdout ".*KILL.*"
    stderr ""
    exit_code 0
end test "kill -l 9 outputs KILL"

requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
begin test "kill -l 137 outputs KILL"
  script
    kill -l 137
  expect
    stdout ".*KILL.*"
    stderr ""
    exit_code 0
end test "kill -l 137 outputs KILL"

requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
begin test "kill -l 15 outputs TERM"
  script
    kill -l 15
  expect
    stdout ".*TERM.*"
    stderr ""
    exit_code 0
end test "kill -l 15 outputs TERM"

requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
begin test "kill -l 143 outputs TERM"
  script
    kill -l 143
  expect
    stdout ".*TERM.*"
    stderr ""
    exit_code 0
end test "kill -l 143 outputs TERM"

requirement "SHALL-KILL-1243" doc="If an exit_status operand is given and it is a value of the '?' shell special parameter (see 2.5.2 Special Parameters and wait ) corresponding to a process that was terminated or stopped by a signal, the signal_name corresponding to the signal that terminated or stopped the process shall be written."
requirement "SHALL-KILL-1256" doc="For the last signal written, < separator > shall be a <newline>."
requirement "SHALL-KILL-1246" doc="In addition, the symbolic name 0 shall be recognized, representing the signal value zero."
begin test "kill exits 0 on success with default signal"
  script
    sleep 60 & p=$!
    kill $p
    echo $?
    wait $p 2>/dev/null
  expect
    stdout "0.*"
    stderr "(.|\n)*"
    exit_code >128
end test "kill exits 0 on success with default signal"

requirement "SHALL-KILL-1040" doc="The following environment variables shall affect the execution of kill : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "kill -s KILL exits 0 on success"
  script
    sleep 60 & p=$!
    kill -s KILL $p
    echo $?
    wait $p 2>/dev/null
  expect
    stdout "0.*"
    stderr "(.|\n)*"
    exit_code >128
end test "kill -s KILL exits 0 on success"

requirement "SHALL-KILL-1250" doc="The process or processes selected by positive, negative, and zero values of the pid operand shall be as described for the kill () function."
begin test "kill nonexistent PID exits non-zero"
  script
    kill 99999999 2>/dev/null
  expect
    stdout ""
    stderr ""
    exit_code !=0
end test "kill nonexistent PID exits non-zero"

requirement "SHALL-KILL-1245" doc="Values of signal_name shall be recognized in a case-independent fashion, without the SIG prefix."
requirement "SHALL-KILL-1255" doc="When the -l option is specified, the symbolic name of each signal shall be written in the following format: \"%s%c\", < signal_name >, < separator > where the < signal_name > is in uppercase, without the SIG prefix, and the < separator > shall be either a <newline> or a <space>."
begin test "kill without -l produces no stdout"
  script
    kill -s TERM $$ 2>/dev/null
  expect
    stdout "(.|\n)*"
    stderr "(.|\n)*"
    exit_code >=128
end test "kill without -l produces no stdout"

requirement "SHALL-2-6-2-127" doc="If parameter is unset or null, the expansion of word (or a message indicating it is unset if word is omitted) shall be written to standard error and the shell exits with a non-zero exit status."
begin test "kill -s NONEXISTENT exits non-zero"
  script
    kill -s NONEXISTENT $$ 2>/dev/null
  expect
    stdout ""
    stderr ""
    exit_code !=0
end test "kill -s NONEXISTENT exits non-zero"

requirement "SHALL-2-6-2-127" doc="If parameter is unset or null, the expansion of word (or a message indicating it is unset if word is omitted) shall be written to standard error and the shell exits with a non-zero exit status."
begin test "kill -NONEXISTENT exits non-zero"
  script
    kill -NONEXISTENT $$ 2>/dev/null
  expect
    stdout ""
    stderr ""
    exit_code !=0
end test "kill -NONEXISTENT exits non-zero"

requirement "SHALL-BG-1031" doc="The output of bg shall consist of a line in the format: \"[%d] %s\\n\", < job-number >, < command > where the fields are as follows: < job-number > A number that can be used to identify the job to the wait , fg , and kill utilities."
begin test "kill -l output contains HUP"
  script
    kill -l
  expect
    stdout ".*HUP.*"
    stderr ""
    exit_code 0
end test "kill -l output contains HUP"

requirement "SHALL-KILL-1244" doc="If an exit_status operand is given and it is the unsigned decimal integer value of a signal number, the signal_name (the symbolic constant name without the SIG prefix defined in the Base Definitions volume of POSIX.1-2024) corresponding to that signal shall be written."
begin test "kill -99999 invalid signal number exits non-zero"
  script
    kill -99999 $$ 2>/dev/null
  expect
    stdout ""
    stderr ""
    exit_code !=0
end test "kill -99999 invalid signal number exits non-zero"

requirement "SHALL-KILL-1248" doc="If the first argument is a negative integer, it shall be interpreted as a - signal_number option, not as a negative pid operand specifying a process group."
requirement "SHALL-KILL-1063" doc="The following operands shall be supported: pid One of the following: A decimal integer specifying a process or process group to be signaled."
requirement "SHALL-KILL-1251" doc="If process number 0 is specified, all processes in the current process group shall be signaled."
begin test "kill -s 0 0 checks current process group"
  script
    kill -s 0 0
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "kill -s 0 0 checks current process group"

requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
begin test "kill -0 own PID succeeds"
  script
    kill -0 $$
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "kill -0 own PID succeeds"

requirement "SHALL-KILL-1238" doc="The kill utility shall send a signal to the process or processes specified by each pid operand."
begin test "kill -0 nonexistent PID fails"
  script
    kill -0 99999999 2>/dev/null
  expect
    stdout ""
    stderr ""
    exit_code !=0
end test "kill -0 nonexistent PID fails"

requirement "SHALL-KILL-1240" doc="For each pid operand, the kill utility shall perform actions equivalent to the kill () function defined in the System Interfaces volume of POSIX.1-2024 called with the following arguments: The value of the pid operand shall be used as the pid argument."
begin interactive test "kill with job ID %1"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill %1"
  expect "$ "
  send "wait 2>/dev/null; echo killed_ok"
  expect "killed_ok"
  sendeof
  wait
end interactive test "kill with job ID %1"

requirement "SHALL-BG-1031" doc="The output of bg shall consist of a line in the format: \"[%d] %s\\n\", < job-number >, < command > where the fields are as follows: < job-number > A number that can be used to identify the job to the wait , fg , and kill utilities."
begin interactive test "kill -s KILL with job ID %1"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill -s KILL %1"
  expect "$ "
  send "wait 2>/dev/null; echo killed_ok"
  expect "killed_ok"
  sendeof
  wait
end interactive test "kill -s KILL with job ID %1"

requirement "SHALL-BG-1031" doc="The output of bg shall consist of a line in the format: \"[%d] %s\\n\", < job-number >, < command > where the fields are as follows: < job-number > A number that can be used to identify the job to the wait , fg , and kill utilities."
begin interactive test "kill -s 0 with job ID checks existence"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill -s 0 %1; echo check_$?"
  expect "check_0"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "kill -s 0 with job ID checks existence"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "kill %% targets current job"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill %%; echo kill_ok_$?"
  expect "kill_ok_0"
  send "wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "kill %% targets current job"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "kill %+ targets current job"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill %+; echo kill_ok_$?"
  expect "kill_ok_0"
  send "wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "kill %+ targets current job"

requirement "SHALL-BG-1031" doc="The output of bg shall consist of a line in the format: \"[%d] %s\\n\", < job-number >, < command > where the fields are as follows: < job-number > A number that can be used to identify the job to the wait , fg , and kill utilities."
begin interactive test "kill %- targets previous job"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "sleep 61 &"
  expect "$ "
  send "kill %-; echo kill_ok_$?"
  expect "kill_ok_0"
  send "kill %+; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "kill %- targets previous job"

requirement "SHALL-KILL-1041" doc="When both the -l option and exit_status operand are specified, the symbolic name of the corresponding signal shall be written in the following format: \"%s\\n\", <signal_name>."
requirement "SHALL-XBD-12-4000" doc="If the SYNOPSIS of a standard utility shows an option with a mandatory option-argument (as with [ -c option_argument ] in the example), a conforming application shall use separate arguments for that option and its option-argument."
begin test "kill -s TERM as separate option-argument"
  script
    sleep 0 & _pid=$!
    kill -s TERM $_pid 2>/dev/null
    wait $_pid 2>/dev/null
    true
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "kill -s TERM as separate option-argument"
