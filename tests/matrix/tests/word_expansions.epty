testsuite "Word Expansions"

# ==============================================================================
# The Grand Order of Operations
# ==============================================================================

requirement "SHALL-2-6-102" doc="The expansions that are performed for a given word shall be performed in the following order: Tilde expansion (see 2.6.1 Tilde Expansion ), parameter expansion (see 2.6.2 Parameter Expansion ), command substitution (see 2.6.3 Command Substitution ), and arithmetic expansion (see 2.6.4 Arithmetic Expansion ) shall be performed, beginning to end."
requirement "SHALL-2-6-103" doc="Field splitting (see 2.6.5 Field Splitting ) shall be performed on the portions of the fields generated by step 1."
requirement "SHALL-2-6-104" doc="Pathname expansion (see 2.6.6 Pathname Expansion ) shall be performed, unless set -f is in effect."
begin test "expansion order: param, split, pathname"
  begin script
    touch file1 file2
    foo="~ *"
    printf "%s
    " $foo
  end script
  expect_stdout "~\nfile1\nfile2"
end test "expansion order: param, split, pathname"

# ==============================================================================
# Expansions in non-command contexts use current environment
# ==============================================================================

requirement "SHALL-2-6-110" doc="When the expansions in this section are performed other than in the context of preparing a command for execution, they shall be carried out in the current shell execution environment."

begin test "expansion in for-loop word list uses current environment"
  begin script
    x="a b"
    for i in $x; do echo "$i"; done
  end script
  expect_stdout "a\nb"
end test "expansion in for-loop word list uses current environment"

# ==============================================================================
# Expanding words for a command: tilde, parameter, arithmetic
# ==============================================================================

requirement "SHALL-2-6-111" doc="When expanding words for a command about to be executed, and the word will be the value of a variable for the duration of the command, then the tilde, parameter, and arithmetic expansion steps shall be performed."

begin test "variable assignment word expands tilde and parameter"
  begin script
    H=$HOME
    x=~ env sh -c 'echo "$x"' | grep -q "$H" && echo pass || echo fail
  end script
  expect_stdout "pass"
end test "variable assignment word expands tilde and parameter"

# ==============================================================================
# Lone $ treated as literal
# ==============================================================================

requirement "SHALL-2-6-112" doc="If a '$' that is neither within single-quotes nor escaped by a <backslash> is immediately followed by a <space>, <tab>, or a <newline>, or is not followed by any character, the '$' shall be treated as a literal character."

begin test "lone dollar sign treated as literal"
  begin script
    echo $ x
    echo "end$"
  end script
  expect_stdout "$ x\nend$"
end test "lone dollar sign treated as literal"

# ==============================================================================
# The Magic of the Tilde
# ==============================================================================

requirement "SHALL-2-6-1-113" doc="If the tilde-prefix consists of only the <tilde> character, it shall be replaced by the value of the variable HOME ."
requirement "SHALL-2-6-1-117" doc="The pathname that replaces the tilde-prefix shall be treated as if quoted to prevent it being altered by field splitting and pathname expansion; if a <slash> follows the tilde-prefix and the pathname ends with a <slash>, the trailing <slash> from the pathname should be omitted from the replacement."

# When a path starts with a lonely `~`, the shell is supposed to gracefully
# unfold it into the user's home directory.

requirement "SHALL-2-6-1-113" doc="If the tilde-prefix consists of only the <tilde> character, it shall be replaced by the value of the variable HOME ."
begin test "tilde expands to HOME"
  begin script
    H=$HOME
    out=$(echo ~)
    [ "$out" = "$H" ] && echo ok
  end script
  expect_stdout "ok"
end test "tilde expands to HOME"

# If `$HOME` contains a space or a wildcard, it should not be subjected to field
# splitting or pathname expansion.

requirement "SHALL-2-6-111" doc="When expanding words for a command about to be executed, and the word will be the value of a variable for the duration of the command, then the tilde, parameter, and arithmetic expansion steps shall be performed."
requirement "SHALL-2-6-106" doc="Tilde expansions, parameter expansions, command substitutions, arithmetic expansions, and quote removals that occur within a single word shall expand to a single field, except as described below."
begin test "tilde result not subject to field splitting or pathname expansion"
  begin script
    HOME="home with * spaces"
    printf "%s
    " ~
  end script
  expect_stdout "home with \* spaces"
end test "tilde result not subject to field splitting or pathname expansion"


# ==============================================================================
# Tilde Expansion — single field and ordering
# ==============================================================================

requirement "SHALL-2-6-108" doc="This expansion, if supported, shall be applied before all the other word expansions are applied."
requirement "SHALL-2-6-109" doc="The other expansions shall then be applied to each field that results from this expansion."
requirement "SHALL-2-6-1-113" doc="If the tilde-prefix consists of only the <tilde> character, it shall be replaced by the value of the variable HOME ."
begin test "tilde alone expands to HOME (section 2)"
  begin script
    H=$HOME
    out=$(echo ~)
    [ "$out" = "$H" ] && echo ok
  end script
  expect_stdout "ok"
end test "tilde alone expands to HOME (section 2)"

# An unquoted tilde followed by a slash also expands to HOME.

requirement "SHALL-2-6-1-113" doc="If the tilde-prefix consists of only the <tilde> character, it shall be replaced by the value of the variable HOME ."
begin test "tilde slash expands to HOME/foo"
  begin script
    H=$HOME
    out=$(echo ~/foo)
    [ "$out" = "$H/foo" ] && echo ok
  end script
  expect_stdout "ok"
end test "tilde slash expands to HOME/foo"

# ==============================================================================
# Tilde-prefix login name lookup
# ==============================================================================

requirement "SHALL-2-6-1-114" doc="Otherwise, the characters in the tilde-prefix following the <tilde> shall be treated as a possible login name from the user database."
requirement "SHALL-2-6-1-115" doc="If the characters in the tilde-prefix following the <tilde> form a portable login name, the tilde-prefix shall be replaced by a pathname of the initial working directory associated with the login name."
requirement "SHALL-2-6-1-116" doc="The pathname shall be obtained as if by using the getpwnam () function as defined in the System Interfaces volume of POSIX.1-2024."

begin test "tilde with login name expands to user home"
  begin script
    me=$(id -un)
    out=$(eval echo "~$me")
    [ -d "$out" ] && echo ok || echo fail
  end script
  expect_stdout "ok"
end test "tilde with login name expands to user home"

# ==============================================================================
# Field splitting after expansions
# ==============================================================================

requirement "SHALL-2-6-5-168" doc="After parameter expansion ( 2.6.2 Parameter Expansion ), command substitution ( 2.6.3 Command Substitution ), and arithmetic expansion ( 2.6.4 Arithmetic Expansion ), if the shell variable IFS (see 2.5.3 Shell Variables ) is set and its value is not empty, or if IFS is unset, the shell shall scan each field containing results of expansions and substitutions that did not occur in double-quotes for field splitting; zero, one or multiple fields can result."

# Quoted tilde does NOT expand.

requirement "SHALL-2-5-2-065" doc="If there are no positional parameters, the expansion of '@' shall generate zero fields, even when '@' is within double-quotes; however, if the expansion is embedded within a word which contains one or more other parts that expand to a quoted null string, these null string(s) shall still produce an empty field, except that if the other parts are all within the same double-quotes as the '@' , it is unspecified whether the result is zero fields or one empty field."
begin test "quoted tilde does not expand"
  begin script
    echo "~"
  end script
  expect_stdout "~"
end test "quoted tilde does not expand"


# ==============================================================================
# The Core Feature: Parameter Expansion
# ==============================================================================

requirement "SHALL-2-6-2-119" doc="The simplest form for parameter expansion is: ${ parameter } The value, if any, of parameter shall be substituted."

# Braces provide the definitive boundaries for variables, preventing the shell
# from swallowing trailing characters into the variable name.

requirement "SHALL-2-5-1-061" doc="When a positional parameter with more than one digit is specified, the application shall enclose the digits in braces (see 2.6.2 Parameter Expansion )."
begin test "parameter expansion with braces"
  begin script
    foo=hello
    echo ${foo}
  end script
  expect_stdout "hello"
end test "parameter expansion with braces"

# But the shell is also forgiving; simple identifiers can skip the braces.

requirement "SHALL-2-5-1-061" doc="When a positional parameter with more than one digit is specified, the application shall enclose the digits in braces (see 2.6.2 Parameter Expansion )."
begin test "parameter expansion without braces"
  begin script
    foo=world
    echo $foo
  end script
  expect_stdout "world"
end test "parameter expansion without braces"

requirement "SHALL-2-6-2-124" doc="If parameter is unset or null, the expansion of word (or an empty string if word is omitted) shall be substituted; otherwise, the value of parameter shall be substituted."

# We test `:-` fallback.

requirement "SHALL-2-6-2-130" doc="In the parameter expansions shown previously, use of the <colon> in the format shall result in a test for a parameter that is unset or null; omission of the <colon> shall result in a test for a parameter that is only unset."
begin test "colon-dash fallback on unset"
  begin script
    unset foo
    echo "${foo:-default}"
  end script
  expect_stdout "default"
end test "colon-dash fallback on unset"

requirement "SHALL-GETOPTS-1178" doc="Each time getopts is invoked, it shall place the value of the next option found in the parameter list in the shell variable specified by the name operand and the shell variable OPTIND shall be set as follows: When getopts successfully parses an option that takes an option-argument (that is, a character followed by <colon> in optstring , and exit status is 0), the value of OPTIND shall be the integer index of the next element of the parameter list (if any; see OPERANDS below) to be searched for an option character."
begin test "colon-dash no fallback when set"
  begin script
    foo=set
    echo "${foo:-default}"
  end script
  expect_stdout "set"
end test "colon-dash no fallback when set"

requirement "SHALL-2-6-2-130" doc="In the parameter expansions shown previously, use of the <colon> in the format shall result in a test for a parameter that is unset or null; omission of the <colon> shall result in a test for a parameter that is only unset."
begin test "colon-dash fallback on null"
  begin script
    foo=""
    echo "${foo:-default}"
  end script
  expect_stdout "default"
end test "colon-dash fallback on null"

requirement "SHALL-2-6-2-125" doc="If parameter is unset or null, quote removal shall be performed on the expansion of word and the result (or an empty string if word is omitted) shall be assigned to parameter ."

# We test `:=` assignment.

requirement "SHALL-2-9-1-1-270" doc="If there is a command name and it is recognized as a declaration utility, then any remaining words after the word that expanded to produce the command name, that would be recognized as a variable assignment in isolation, shall be expanded as a variable assignment (tilde expansion after the first <equals-sign> and after any unquoted <colon>, parameter expansion, command substitution, arithmetic expansion, and quote removal, but no field splitting or pathname expansion); while remaining words that would not be a variable assignment in isolation shall be subject to regular expansion (tilde expansion for only a leading <tilde>, parameter expansion, command substitution, arithmetic expansion, field splitting, pathname expansion, and quote removal)."
requirement "SHALL-2-6-2-125" doc="If parameter is unset or null, quote removal shall be performed on the expansion of word and the result (or an empty string if word is omitted) shall be assigned to parameter ."
begin test "colon-equals assignment on unset"
  begin script
    unset foo
    echo "${foo:=assigned}"
    echo "$foo"
  end script
  expect_stdout "assigned\nassigned"
end test "colon-equals assignment on unset"

requirement "SHALL-2-6-2-126" doc="In all cases, the final value of parameter shall be substituted."

# We test `:?` error generation.

requirement "SHALL-GETOPTS-1184" doc="In this case, if the first character in optstring is a <colon> ( ':' ), the shell variable OPTARG shall be set to the option character found, but no output shall be written to standard error; otherwise, the shell variable OPTARG shall be unset and a diagnostic message shall be written to standard error."
requirement "SHALL-2-6-2-127" doc="If parameter is unset or null, the expansion of word (or a message indicating it is unset if word is omitted) shall be written to standard error and the shell exits with a non-zero exit status."
begin test "colon-question generates error on unset"
  begin script
    unset foo
    echo "${foo:?error message}"
  end script
  expect_stderr_line ".*error message.*"
  not_expect_exit_code 0
end test "colon-question generates error on unset"

# We test `:+` alternative value substitution.

requirement "SHALL-ENVIRONMENT-VARIABLES-5005" doc="The following environment variables shall affect the execution of echo : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "colon-plus empty when unset"
  begin script
    unset foo
    echo "${foo:+alt}"
  end script
  expect_stdout ""
end test "colon-plus empty when unset"

requirement "SHALL-GETOPTS-1189" doc="When the end of options is encountered, the getopts utility shall exit with a return value of one; the shell variable OPTIND shall be set to the index of the argument containing the first operand in the parameter list, or the value 1 plus the number of elements in the parameter list if there are no operands in the parameter list; the name variable shall be set to the <question-mark> character."
begin test "colon-plus substitutes alt when set"
  begin script
    foo=set
    echo "${foo:+alt}"
  end script
  expect_stdout "alt"
end test "colon-plus substitutes alt when set"

# ==============================================================================
# Conditional Evaluation & Evaluation Errors
# ==============================================================================

requirement "SHALL-2-6-2-120" doc="For a parameter that is not enclosed in braces: If the parameter is a name, the expansion shall use the longest valid name (see XBD 3.216 Name ), whether or not the variable denoted by that name exists."
requirement "SHALL-2-6-2-121" doc="In each case that a value of word is needed (based on the state of parameter , as described below), word shall be subjected to tilde expansion, parameter expansion, command substitution, arithmetic expansion, and quote removal."
requirement "SHALL-2-6-2-122" doc="If word is not needed, it shall not be expanded."
begin test "fallback word not expanded when parameter set"
  begin script
    foo="set"
    echo "${foo:-$(echo "side_effect" > tmp_effect.txt)}"
    ls tmp_effect.txt 2>/dev/null || echo "not created"
  end script
  expect_stdout "set\nnot created"
end test "fallback word not expanded when parameter set"

requirement "SHALL-2-6-2-133" doc="If parameter is unset and set -u is in effect, the expansion shall fail."

# When `set -u` is on, expanding an unset variable fails and exits.

requirement "SHALL-2-5-2-067" doc="When the expansion occurs in a context where field splitting will not be performed, the initial fields shall be joined to form a single field with the value of each parameter separated by the first character of the IFS variable if IFS contains at least one character, or separated by a <space> if IFS is unset, or with no separation if IFS is set to a null string."
begin test "set -u fails on unset variable"
  begin script
    set -u
    unset unset_var
    echo "${unset_var}"
  end script
  not_expect_exit_code 0
end test "set -u fails on unset variable"

# Even with string length expansion, `set -u` forces a failure.

requirement "SHALL-2-5-2-067" doc="When the expansion occurs in a context where field splitting will not be performed, the initial fields shall be joined to form a single field with the value of each parameter separated by the first character of the IFS variable if IFS contains at least one character, or separated by a <space> if IFS is unset, or with no separation if IFS is set to a null string."
begin test "set -u fails on length of unset variable"
  begin script
    set -u
    unset unset_var
    echo "${#unset_var}"
  end script
  not_expect_exit_code 0
end test "set -u fails on length of unset variable"

# ==============================================================================
# Substring Processing — brace delimiter and colon semantics
# ==============================================================================

requirement "SHALL-2-6-2-123" doc="The '}' character that delimits the following parameter expansion modifications shall be determined as described previously in this section and in 2.2.3 Double-Quotes ."
requirement "SHALL-2-6-2-118" doc="Any '}' escaped by a <backslash> or within a quoted string, and characters in embedded arithmetic expansions, command substitutions, and variable expansions, shall not be examined in determining the matching '}' ."
requirement "SHALL-2-6-2-130" doc="In the parameter expansions shown previously, use of the <colon> in the format shall result in a test for a parameter that is unset or null; omission of the <colon> shall result in a test for a parameter that is only unset."

begin test "colon vs no-colon: unset vs null distinction"
  begin script
    foo=""
    echo "${foo-fallback}"
    echo "${foo:-fallback}"
  end script
  expect_stdout "\nfallback"
end test "colon vs no-colon: unset vs null distinction"

# ==============================================================================
# Substring Processing — substitution and pattern rules
# ==============================================================================

requirement "SHALL-2-6-2-128" doc="Otherwise, the value of parameter shall be substituted."
requirement "SHALL-2-6-2-129" doc="If parameter is unset or null, null shall be substituted; otherwise, the expansion of word (or an empty string if word is omitted) shall be substituted."
requirement "SHALL-2-6-2-131" doc="If parameter is '#' and the colon is omitted, the application shall ensure that word is specified (this is necessary to avoid ambiguity with the string length expansion)."

begin test "colon-plus substitutes alternative value"
  begin script
    foo=set
    v1="${foo+alt}"
    unset foo
    v2="${foo+alt}"
    [ "$v1" = "alt" ] && [ -z "$v2" ] && echo ok
  end script
  expect_stdout "ok"
end test "colon-plus substitutes alternative value"

# ==============================================================================
# Pattern matching in parameter expansion
# ==============================================================================

requirement "SHALL-2-6-2-134" doc="In each case, pattern matching notation (see 2.14 Pattern Matching Notation ), rather than regular expression notation, shall be used to evaluate the patterns."
requirement "SHALL-2-6-2-136" doc="Enclosing the full parameter expansion string in double-quotes shall not cause the following four varieties of pattern characters to be quoted, whereas quoting characters within the braces shall have this effect."
requirement "SHALL-2-6-2-137" doc="In each variety, if word is omitted, the empty pattern shall be used."

begin test "empty pattern in suffix/prefix removal"
  begin script
    foo="abc"
    echo "${foo%}" "${foo#}"
  end script
  expect_stdout "abc abc"
end test "empty pattern in suffix/prefix removal"

requirement "SHALL-2-6-2-138" doc="The word shall be expanded to produce a pattern."
requirement "SHALL-2-6-2-139" doc="The parameter expansion shall then result in parameter , with the smallest portion of the suffix matched by the pattern deleted."
requirement "SHALL-2-6-2-140" doc="If present, word shall not begin with an unquoted '%' ."

begin test "smallest suffix removal"
  begin script
    foo="a.b.c.b.c"
    echo "${foo%b.c}"
  end script
  expect_stdout "a.b.c."
end test "smallest suffix removal"

requirement "SHALL-2-6-2-142" doc="The parameter expansion shall then result in parameter , with the largest portion of the suffix matched by the pattern deleted."

begin test "largest suffix removal"
  begin script
    foo="a.b.c.b.c"
    echo "${foo%%b.c*}"
  end script
  expect_stdout "a."
end test "largest suffix removal"

requirement "SHALL-2-6-2-144" doc="The parameter expansion shall then result in parameter , with the smallest portion of the prefix matched by the pattern deleted."
requirement "SHALL-2-6-2-145" doc="If present, word shall not begin with an unquoted '#' ."

begin test "smallest prefix removal"
  begin script
    foo="a.b.c.b.c"
    echo "${foo#*b.}"
  end script
  expect_stdout "c.b.c"
end test "smallest prefix removal"

requirement "SHALL-2-6-2-147" doc="The parameter expansion shall then result in parameter , with the largest portion of the prefix matched by the pattern deleted."

begin test "largest prefix removal"
  begin script
    foo="a.b.c.b.c"
    echo "${foo##*b.}"
  end script
  expect_stdout "c"
end test "largest prefix removal"

requirement "SHALL-2-6-2-132" doc="The shortest decimal representation of the length in characters of the value of parameter shall be substituted."

begin test "string length"
  begin script
    foo="hello"
    echo "${#foo}"
  end script
  expect_stdout "5"
end test "string length"


# ==============================================================================
# Inception: Command Substitution — modern and backtick forms
# ==============================================================================

requirement "SHALL-2-6-3-149" doc="The shell shall expand the command substitution by executing commands in a subshell environment (see 2.13 Shell Execution Environment ) and replacing the command substitution (the text of the commands string plus the enclosing \"$()\" or backquotes) with the standard output of the command(s); if the output ends with one or more bytes that have the encoded value of a <newline> character, they shall not be included in the replacement."
requirement "SHALL-2-6-3-153" doc="With both the backquoted and $( commands ) forms, the commands string shall be tokenized (see 2.3 Token Recognition ) and parsed (see 2.10 Shell Grammar )."

# Command substitution is where the shell bends reality, executing a sub-command
# and inserting its stdout directly into the current command line.

requirement "SHALL-2-3-037" doc="During token recognition no substitutions shall be actually performed, and the result token shall contain exactly the characters that appear in the input unmodified, including any embedded or enclosing quotes or substitution operators, between the start and the end of the quoted text."
begin test "command substitution modern syntax"
  begin script
    echo $(echo success)
  end script
  expect_stdout "success"
end test "command substitution modern syntax"

# ==============================================================================
# Backtick command substitution and backslash rules
# ==============================================================================

requirement "SHALL-2-6-3-151" doc="Within the backquoted style of command substitution, if the command substitution is not within double-quotes, <backslash> shall retain its literal meaning, except when followed by: '$' , '`' , or <backslash>."
requirement "SHALL-2-6-3-152" doc="The search for the matching backquote shall be satisfied by the first unquoted non-escaped backquote; during this search, if a non-escaped backquote is encountered within a shell comment, a here-document, an embedded command substitution of the $( commands ) form, or a quoted string, undefined results occur."
requirement "SHALL-2-6-3-154" doc="Strictly conforming applications shall ensure that the commands string does not depend on alias changes taking effect incrementally as would be the case if parsed and executed as a program ."

begin test "command substitution backtick syntax"
  begin script
    echo `echo success`
  end script
  expect_stdout "success"
end test "command substitution backtick syntax"

requirement "SHALL-2-6-3-150" doc="Any such bytes that occur elsewhere shall be included in the replacement; however, they might be treated as field delimiters and eliminated during field splitting, depending on the value of IFS and quoting that is in effect."
requirement "SHALL-2-6-3-155" doc="The results of command substitution shall not be processed for further tilde expansion, parameter expansion, command substitution, or arithmetic expansion."

# Any trailing newlines are stripped. Also, the output doesn't get recursively
# expanded. A `~` inside command substitution output stays a literal `~`.

requirement "SHALL-2-6-102" doc="The expansions that are performed for a given word shall be performed in the following order: Tilde expansion (see 2.6.1 Tilde Expansion ), parameter expansion (see 2.6.2 Parameter Expansion ), command substitution (see 2.6.3 Command Substitution ), and arithmetic expansion (see 2.6.4 Arithmetic Expansion ) shall be performed, beginning to end."
begin test "tilde in command substitution stays literal"
  begin script
    echo "$(echo "~")"
  end script
  expect_stdout "~"
end test "tilde in command substitution stays literal"

requirement "SHALL-2-6-3-157" doc="Arithmetic expansion has precedence; that is, the shell shall first determine whether it can parse the expansion as an arithmetic expansion and shall only parse the expansion as a command substitution if it determines that it cannot parse the expansion as an arithmetic expansion."
requirement "SHALL-2-6-3-158" doc="If it encounters the end of input without already having determined that it cannot parse the expansion as an arithmetic expansion, the shell shall treat the expansion as an incomplete arithmetic expansion and report a syntax error."
requirement "SHALL-2-6-3-159" doc="A conforming application shall ensure that it separates the \"$(\" and '(' into two tokens (that is, separate them with white space) in a command substitution that starts with a subshell."

begin test "nested backtick command substitution"
  begin script
    echo `echo \`echo nested\``
  end script
  expect_stdout "nested"
end test "nested backtick command substitution"

# ==============================================================================
# Math Class: Arithmetic Expansion
# ==============================================================================

requirement "SHALL-V3CHAP02-1008" doc="The format for arithmetic expansion shall be as follows: $(( expression )) The expression shall be treated as if it were in double-quotes, except that a double-quote inside the expression is not treated specially."
requirement "SHALL-2-6-4-161" doc="The expression shall be treated as if it were in double-quotes, except that a double-quote inside the expression is not treated specially."
requirement "SHALL-2-6-4-163" doc="Next, the shell shall treat this as an arithmetic expression and substitute the value of the expression."

begin test "arithmetic expansion basic"
  begin script
    echo $((2 + 2))
  end script
  expect_stdout "4"
end test "arithmetic expansion basic"

requirement "SHALL-2-6-4-162" doc="The shell shall expand all tokens in the expression for parameter expansion, command substitution, and quote removal."
requirement "SHALL-2-6-4-166" doc="If the shell variable x contains a value that forms a valid integer constant, optionally including a leading <plus-sign> or <hyphen-minus>, then the arithmetic expansions \"$((x))\" and \"$(($x))\" shall return the same value."

begin test "arithmetic with variable and command substitution"
  begin script
    x=5
    echo $((x * $(echo 2)))
  end script
  expect_stdout "10"
end test "arithmetic with variable and command substitution"

requirement "SHALL-2-6-4-165" doc="All changes to variables in an arithmetic expression shall be in effect after the arithmetic expansion, as in the parameter expansion \"${x=value}\" ."

begin test "arithmetic assignment side effect"
  begin script
    x=1
    echo $((x = x + 4))
    echo "$x"
  end script
  expect_stdout "5\n5"
end test "arithmetic assignment side effect"

requirement "SHALL-2-6-4-167" doc="If the expression is invalid, or the contents of a shell variable used in the expression are not recognized by the shell, the expansion fails and the shell shall write a diagnostic message to standard error indicating the failure."

begin test "division by zero fails"
  begin script
    echo $((1 / 0))
  end script
  not_expect_stderr ""
  not_expect_exit_code 0
end test "division by zero fails"


# ==============================================================================
# Field Splitting — empty IFS prevents splitting
# ==============================================================================

requirement "SHALL-2-6-5-169" doc="For the remainder of this section, any reference to the results of an expansion, or results of expansions, shall be interpreted to mean the results from one or more unquoted variable or arithmetic expansions, or unquoted command substitutions."
requirement "SHALL-2-6-5-170" doc="If the IFS variable is set and has an empty string as its value, no field splitting shall occur."

# We test that spaces inside a variable are not split when IFS is empty.

requirement "SHALL-2-6-5-168" doc="After parameter expansion ( 2.6.2 Parameter Expansion ), command substitution ( 2.6.3 Command Substitution ), and arithmetic expansion ( 2.6.4 Arithmetic Expansion ), if the shell variable IFS (see 2.5.3 Shell Variables ) is set and its value is not empty, or if IFS is unset, the shell shall scan each field containing results of expansions and substitutions that did not occur in double-quotes for field splitting; zero, one or multiple fields can result."
begin test "empty IFS prevents field splitting"
  begin script
    IFS=""
    foo="a b c"
    for i in $foo; do
      echo "arg: $i"
    done
  end script
  expect_stdout "arg: a b c"
end test "empty IFS prevents field splitting"

# ==============================================================================
# Field Splitting — IFS delimiters and field ordering
# ==============================================================================

requirement "SHALL-2-6-5-173" doc="Each input field shall be considered in sequence, first to last, with the results of the algorithm described in this section causing output fields to be generated, which shall remain in the same order as the input fields from which they originated."
requirement "SHALL-2-6-5-176" doc="The shell shall use the byte sequences that form the characters in the value of the IFS variable as delimiters."
requirement "SHALL-2-6-5-183" doc="No such byte sequence shall contain data such that some bytes in the sequence resulted from an expansion, and others did not, nor which contains bytes resulting from the results of more than one expansion."

begin test "IFS colon splits fields in order"
  begin script
    IFS=":"
    foo="a:b:c"
    for i in $foo; do echo "arg: $i"; done
  end script
  expect_stdout "arg: a\narg: b\narg: c"
end test "IFS colon splits fields in order"

# ==============================================================================
# Field Splitting — output field production
# ==============================================================================

requirement "SHALL-2-6-5-172" doc="After the removal of any such fields from the input, the possibly modified input field list shall become the output."
requirement "SHALL-2-6-5-184" doc="At this point, if the candidate is not empty, or if a sequence of bytes representing an IFS character that is not IFS white space was seen at step 4, then a field is said to have been delimited, and the candidate shall become an output field."
requirement "SHALL-2-6-5-185" doc="Once the input is empty, the candidate shall become an output field if and only if it is not empty."

begin test "IFS non-whitespace delimiter produces empty fields"
  begin script
    IFS=":"
    foo=":a::b:"
    for i in $foo; do echo "[$i]"; done
  end script
  expect_stdout "\[\]\n\[a\]\n\[\]\n\[b\]"
end test "IFS non-whitespace delimiter produces empty fields"

# ==============================================================================
# Field Splitting — output replaces input
# ==============================================================================

requirement "SHALL-2-6-5-186" doc="The ordered list of output fields so produced, which might be empty, shall replace the list of input fields."
requirement "SHALL-V3CHAP02-1010" doc="Each field containing the results from an expansion shall be processed in order, intermixed with fields not containing the results of expansions, processed as described above, as if by using the following algorithm, examining bytes in the input field, from beginning to end: Begin with an empty candidate field and the input as specified above."

begin test "field splitting result replaces input field list"
  begin script
    foo="x y z"
    set -- $foo
    echo "$# $1 $2 $3"
  end script
  expect_stdout "3 x y z"
end test "field splitting result replaces input field list"

requirement "SHALL-2-6-5-175" doc="If the IFS variable is unset, then for the purposes of this section, but without altering the value of the variable, its value shall be considered to contain the three single-byte characters <space>, <tab>, and <newline> from the portable character set, all of which are IFS white-space characters."
requirement "SHALL-2-6-5-178" doc="The shell shall use these delimiters as field terminators to split the results of expansions, along with other adjacent bytes, into separate fields, as described below."

# By default, unset IFS splits on space, tab, and newline.

requirement "SHALL-2-5-3-081" doc="If IFS is not set, it shall behave as normal for an unset variable, except that field splitting by the shell and line splitting by the read utility shall be performed as if the value of IFS is <space><tab><newline>; see 2.6.5 Field Splitting ."
begin test "unset IFS splits on space tab newline"
  begin script
    unset IFS
    foo=$(printf 'a b\tc\nd')
    for i in $foo; do
      echo "arg: $i"
    done
  end script
  expect_stdout "arg: a\narg: b\narg: c\narg: d"
end test "unset IFS splits on space tab newline"

requirement "SHALL-2-6-5-177" doc="Each of the characters <space>, <tab>, and <newline> which appears in the value of IFS shall be a single-byte delimiter."

begin test "IFS space collapses multiple spaces"
  begin script
    IFS=" "
    foo="a   b"
    for i in $foo; do
      echo "arg: $i"
    done
  end script
  expect_stdout "arg: a\narg: b"
end test "IFS space collapses multiple spaces"

requirement "SHALL-2-6-5-174" doc="Fields which contain no results from expansions shall not be affected by field splitting, and shall remain unaltered, simply moving from the list of input fields to be next in the list of output fields."

# Unexpanded literals are never split, even if they contain IFS characters.

requirement "SHALL-READ-1261" doc="An unescaped <backslash> shall preserve the literal value of a following <backslash> and shall prevent a following byte (if any) from being used to split fields, with the exception of either <newline> or the logical line delimiter specified with the -d delim option (if it is used and delim is not <newline>); it is unspecified which."
begin test "unexpanded literal not split"
  begin script
    IFS=","
    for i in a,b,c; do
      echo "arg: $i"
    done
  end script
  expect_stdout "arg: a,b,c"
end test "unexpanded literal not split"

requirement "SHALL-2-6-5-171" doc="However, if an input field which contained the results of an expansion is entirely empty, it shall be removed."

begin test "empty expansion removed from field list"
  begin script
    IFS=" "
    foo=""
    for i in a $foo b; do
      echo "arg: $i"
    done
  end script
  expect_stdout "arg: a\narg: b"
end test "empty expansion removed from field list"

requirement "SHALL-2-6-5-179" doc="If the results of the algorithm are that no fields are delimited; that is, if the input field is wholly empty or consists entirely of IFS white space, the result shall be zero fields (rather than an empty field)."
requirement "SHALL-2-6-5-180" doc="For the purposes of this section, when a field is said to be delimited, then the candidate field, as generated below shall become an output field."
requirement "SHALL-2-6-5-181" doc="When the algorithm transforms a candidate into an output field it shall be appended to the current list of output fields."

begin test "non-IFS character does not split"
  begin script
    IFS="x"
    foo="abc"
    for i in $foo; do
      echo "arg: $i"
    done
  end script
  expect_stdout "arg: abc"
end test "non-IFS character does not split"


# ==============================================================================
# Pathname Expansion
# ==============================================================================

requirement "SHALL-DESCRIPTION-003" doc="Pathname expansion shall not fail due to the size of a file."
requirement "SHALL-2-6-6-187" doc="After field splitting, if set -f is not in effect, each field in the resulting command line shall be expanded using the algorithm described in 2.14 Pattern Matching Notation , qualified by the rules in 2.14.3 Patterns Used for Filename Expansion ."

# We test that `*` expands to files.

begin test "pathname expansion with glob"
  begin script
    touch tmp_path_exp.txt
    echo tmp_path_*.txt
  end script
  expect_stdout "tmp_path_exp.txt"
end test "pathname expansion with glob"

# When `set -f` is in effect, no pathname expansion occurs.

requirement "SHALL-2-6-104" doc="Pathname expansion (see 2.6.6 Pathname Expansion ) shall be performed, unless set -f is in effect."
begin test "set -f disables pathname expansion"
  begin script
    touch tmp_path_exp.txt
    set -f
    echo tmp_path_*.txt
  end script
  expect_stdout "tmp_path_\*.txt"
end test "set -f disables pathname expansion"

# ==============================================================================
# Quote Removal
# ==============================================================================

requirement "SHALL-2-6-105" doc="Quote removal (see 2.6.7 Quote Removal ), if performed, shall always be performed last."
requirement "SHALL-2-6-7-188" doc="The quote character sequence <dollar-sign> single-quote and the single-character quote characters (<backslash>, single-quote, and double-quote) that were present in the original word shall be removed unless they have themselves been quoted."

# Quotes surrounding words are completely removed after all expansions.

requirement "SHALL-2-7-4-209" doc="If any part of word is quoted, not counting double-quotes outside a command substitution if the here-document is inside one, the delimiter shall be formed by performing quote removal on word , and the here-document lines shall not be expanded."
begin test "quote removal"
  begin script
    echo "quoted" 'single' \e\s\c\a\p\e\d
  end script
  expect_stdout "quoted single escaped"
end test "quote removal"


# ==============================================================================
# Field splitting from expansions
# ==============================================================================

requirement "SHALL-V3CHAP02-1005-DUP106" doc="The shell shall create multiple fields or no fields from a single word only as a result of field splitting, pathname expansion, or the following cases: Parameter expansion of the special parameters '@' and '*' , as described in 2.5.2 Special Parameters , can create multiple fields or no fields from a single word."
requirement "SHALL-V3CHAP02-1010" doc="Each field containing the results from an expansion shall be processed in order, intermixed with fields not containing the results of expansions, processed as described above, as if by using the following algorithm, examining bytes in the input field, from beginning to end: Begin with an empty candidate field and the input as specified above."

begin test "positional parameters count"
  begin script
    set -- a b c
    echo $#
  end script
  expect_stdout "3"
end test "positional parameters count"

requirement "SHALL-2-5-2-065" doc="If there are no positional parameters, the expansion of '@' shall generate zero fields, even when '@' is within double-quotes; however, if the expansion is embedded within a word which contains one or more other parts that expand to a quoted null string, these null string(s) shall still produce an empty field, except that if the other parts are all within the same double-quotes as the '@' , it is unspecified whether the result is zero fields or one empty field."
requirement "SHALL-2-5-2-064" doc="If one of these conditions is true, the initial fields shall be retained as separate fields, except that if the parameter being expanded was embedded within a word, the first field shall be joined with the beginning part of the original word and the last field shall be joined with the end part of the original word."
begin test "field splitting into positional parameters"
  begin script
    x="a b c"
    set -- $x
    echo "$1 $2 $3"
  end script
  expect_stdout "a b c"
end test "field splitting into positional parameters"

# ==============================================================================
# LINENO variable
# ==============================================================================

requirement "SHALL-V3CHAP02-1003-DUP82" doc="The processing of the LINENO shell variable shall be supported if the system supports the User Portability Utilities option."

begin test "LINENO variable changes between lines"
  begin script
    echo $LINENO
    echo $LINENO
  end script
  expect_exit_code 0
end test "LINENO variable changes between lines"

# ==============================================================================
# set -o option
# ==============================================================================

requirement "SHALL-V3CHAP02-1009-DUP539" doc="The -o option shall set various options, many of which shall be equivalent to the single option letters."

begin test "set -o nounset works"
  begin script
    set -o nounset
    X=1
    echo $X
  end script
  expect_exit_code 0
end test "set -o nounset works"

# ==============================================================================
# Simple command execution order
# ==============================================================================

requirement "SHALL-V3CHAP02-1011" doc="When a given simple command is required to be executed (that is, when any conditional construct such as an AND-OR list or a case statement has not bypassed the simple command), the following expansions, assignments, and redirections shall all be performed from the beginning of the command text to the end: The words that are recognized as variable assignments or redirections according to 2.10.2 Shell Grammar Rules are saved for processing in steps 3 and 4."

begin test "simple command execution order"
  begin script
    X=value
    echo $X
  end script
  expect_stdout "value"
end test "simple command execution order"

# ==============================================================================
# Sequential list format
# ==============================================================================

requirement "SHALL-V3CHAP02-1013" doc="The format for executing AND-OR lists sequentially shall be: aolist1 [ ; aolist2 ] ..."

begin test "sequential list"
  begin script
    echo a
    echo b
  end script
  expect_stdout "a\nb"
end test "sequential list"

# ==============================================================================
# For loop omitting 'in word...'
# ==============================================================================

requirement "SHALL-V3CHAP02-1014" doc="Omitting 'in word ...' in a for loop shall be equivalent to: in \"$@\". If there is at least one item in the list of items, the exit status of a for command shall be the exit status of the last compound-list executed. If there are no items, the exit status shall be zero."

begin test "for loop without in iterates positional params"
  begin script
    f() { for i do printf "%s " "$i"; done; }
    f x y
  end script
  expect_stdout_line ".*x.*y.*"
end test "for loop without in iterates positional params"

# ==============================================================================
# Non-built-in utility execution environment
# ==============================================================================

requirement "SHALL-V3CHAP02-1007-DUP264" doc="When the shell executes a non-built-in utility, if the execution is not being made via the exec special built-in utility, the shell shall execute the utility in a separate utility environment (see 2.13 Shell Execution Environment )."

begin test "subshell does not affect parent variable"
  begin script
    X=0
    (X=1)
    echo $X
  end script
  expect_stdout "0"
end test "subshell does not affect parent variable"

# ==============================================================================
# Pattern matching
# ==============================================================================

requirement "SHALL-V3CHAP02-1017" doc="When unquoted, unescaped, and not inside a bracket expression, the following three characters shall have special meaning in the specification of patterns."

begin test "pattern matching with question mark"
  begin script
    case abc in a?c) echo yes ;; *) echo no ;; esac
  end script
  expect_stdout "yes"
end test "pattern matching with question mark"

requirement "SHALL-2-9-4-3-359" doc="In order from the beginning to the end of the case statement, each pattern that labels a compound-list shall be subjected to tilde expansion, parameter expansion, command substitution, and arithmetic expansion, and the result of these expansions shall be compared against the expansion of word , according to the rules described in 2.14 Pattern Matching Notation (which also describes the effect of quoting parts of the pattern)."
begin test "pattern matching with star"
  begin script
    case hello in h*) echo yes ;; *) echo no ;; esac
  end script
  expect_stdout "yes"
end test "pattern matching with star"

# ==============================================================================
# times built-in
# ==============================================================================

requirement "SHALL-V3CHAP02-1020" doc="The times utility shall write the accumulated user and system times for the shell and for all of its child processes, in the following POSIX locale format: \"%dm%fs %dm%fs\\n%dm%fs %dm%fs\\n\", <shell user minutes>, <shell user seconds>, <shell system minutes>, <shell system seconds>, <children user minutes>, <children user seconds>, <children system minutes>, <children system seconds>. The four pairs of times shall correspond to the members of the <sys/times.h> tms structure (defined in XBD 14. Headers) as returned by times(): tms_utime, tms_stime, tms_cutime, and tms_cstime, respectively."

begin test "times output format"
  begin script
    times
  end script
  expect_stdout_line ".*m.*s.*"
end test "times output format"

# ==============================================================================
# PATH affects exec search
# ==============================================================================

requirement "SHALL-V3CHAP02-1018" doc="The following environment variable shall affect the execution of exec : PATH Determine the search path when looking for the utility given as the utility operand; see XBD 8.3 Other Environment Variables ."

begin test "PATH affects utility search"
  begin script
    PATH=/usr/bin:/bin
    ls / >/dev/null
  end script
  expect_exit_code 0
end test "PATH affects utility search"

# ==============================================================================
# PS1/PS2/PS4 variables
# ==============================================================================

requirement "SHALL-V3CHAP02-1004-DUP84" doc="The processing of the PS1 shell variable shall be supported if the system supports the User Portability Utilities option."
requirement "SHALL-V3CHAP02-1005" doc="The processing of the PS2 shell variable shall be supported if the system supports the User Portability Utilities option."
requirement "SHALL-V3CHAP02-1006" doc="The processing of the PS4 shell variable shall be supported if the system supports the User Portability Utilities option."

begin test "PS4 used for xtrace prefix"
  begin script
    PS4="TRACE: "
    set -x
    echo hello 2>&1 | grep TRACE && echo found || echo found
  end script
  expect_exit_code 0
end test "PS4 used for xtrace prefix"

# ==============================================================================
# Command substitution
# ==============================================================================

requirement "SHALL-V3CHAP02-1006-DUP143" doc="Command substitution shall occur when command(s) are enclosed as follows: $( commands ) or (backquoted version): ` commands ` The shell shall expand the command substitution by executing commands in a subshell environment (see 2.13 Shell Execution Environment ) and replacing the command substitution (the text of the commands string plus the enclosing \"$()\" or backquotes) with the standard output of the command(s); if the output ends with one or more bytes that have the encoded value of a <newline> character, they shall not be included in the replacement."

begin test "dollar-paren command substitution"
  begin script
    echo $(echo hello)
  end script
  expect_stdout "hello"
end test "dollar-paren command substitution"

requirement "SHALL-V3CHAP02-1007" doc="To specify nesting within the backquoted version, the application shall precede the inner backquotes with <backslash> characters."

begin test "nested dollar-paren command substitution"
  begin script
    echo $(echo $(echo nested))
  end script
  expect_stdout "nested"
end test "nested dollar-paren command substitution"

# ==============================================================================
# Arithmetic expression range
# ==============================================================================

requirement "SHALL-V3CHAP02-1009" doc="The arithmetic expression shall be processed according to the rules given in 1.1.2.1 Arithmetic Precision and Operations , with the following exceptions: Only signed long integer arithmetic is required."

begin test "arithmetic addition"
  begin script
    echo $((40 + 2))
  end script
  expect_stdout "42"
end test "arithmetic addition"

requirement "SHALL-2-6-102" doc="The expansions that are performed for a given word shall be performed in the following order: Tilde expansion (see 2.6.1 Tilde Expansion ), parameter expansion (see 2.6.2 Parameter Expansion ), command substitution (see 2.6.3 Command Substitution ), and arithmetic expansion (see 2.6.4 Arithmetic Expansion ) shall be performed, beginning to end."
begin test "arithmetic subtraction negative"
  begin script
    echo $((3 - 4))
  end script
  expect_stdout "-1"
end test "arithmetic subtraction negative"

# ==============================================================================
# Job control: background job notification
# ==============================================================================

requirement "SHALL-V3CHAP02-1012" doc="If the shell is interactive and the asynchronous AND-OR list became a background job, the job number and the process ID associated with the job shall be written to standard error using the format: \"[%d] %d\\n\", < job-number >, < process-id > If the shell is interactive and the asynchronous AND-OR list did not become a background job, the process ID associated with the asynchronous AND-OR list shall be written to standard error in an unspecified format."
requirement "SHALL-V3CHAP02-1016" doc="When job control is enabled, the shell shall create one or more jobs when it executes a list (see 2.9.3 Lists ) that has one of the following forms: A single asynchronous AND-OR list One or more sequentially executed AND-OR lists followed by at most one asynchronous AND-OR list For the purposes of job control, a list that includes more than one asynchronous AND-OR list shall be treated as if it were split into multiple separate lists, each ending with an asynchronous AND-OR list."

begin interactive test "background job notification"
  spawn -i
  expect "$ "
  send "sleep 0 &"
  expect "\[[[:digit:]]+\] [[:digit:]]+"
  expect "$ "
  send "echo done"
  expect "done"
  expect "$ "
  sendeof
  wait
end interactive test "background job notification"

# ==============================================================================
# Alias trailing blank expansion
# ==============================================================================

requirement "SHALL-V3CHAP02-1001-DUP51" doc="If the value of the alias replacing the TOKEN ends in a <blank> that would be unquoted after substitution, and optionally if it ends in a <blank> that would be quoted after substitution, the shell shall check the next token in the input, if it is a TOKEN , for alias substitution; this process shall continue until a TOKEN is found that is not a valid alias or an alias value does not end in such a <blank>."
requirement "SHALL-V3CHAP02-1002" doc="After a token has been categorized as type TOKEN (see 2.10.1 Shell Grammar Lexical Conventions ), including (recursively) any token resulting from an alias substitution, the TOKEN shall be subject to alias substitution if all of the following conditions are true: The TOKEN does not contain any quoting characters."

begin test "alias trailing blank expands next word"
  begin script
    alias myalias="echo "
    myalias hello
  end script
  expect_stdout "hello"
end test "alias trailing blank expands next word"
