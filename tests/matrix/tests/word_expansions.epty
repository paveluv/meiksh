testsuite "Word Expansions"

# ==============================================================================
# The Grand Order of Operations
# ==============================================================================

requirement "SHALL-2-6-110" doc="When the expansions in this section are performed other than in the context of preparing a command for execution, they shall be carried out in the current shell execution environment."
requirement "SHALL-2-6-111" doc="When expanding words for a command about to be executed, and the word will be the command name or an argument to the command, the expansions shall be carried out in the current shell execution environment."
requirement "SHALL-2-6-112" doc="If a '$' that is neither within single-quotes nor escaped by a backslash is immediately followed by a space, tab, or newline, or is not followed by any character, the '$' shall be treated as a literal character."
requirement "SHALL-2-6-102" doc="The expansions that are performed for a given word shall be performed in the following order: Tilde expansion, parameter expansion, command substitution, and arithmetic expansion shall be performed, beginning to end."
requirement "SHALL-2-6-103" doc="Field splitting shall be performed on the portions of the fields generated by step 1."
requirement "SHALL-2-6-104" doc="Pathname expansion shall be performed, unless set -f is in effect."
requirement "SHALL-2-6-105" doc="Quote removal, if performed, shall always be performed last."

# We test the entire sequence by constructing a word that relies on the correct
# order:
# 1. Parameter expansion happens first ($foo -> "~ *").
# 2. Field splitting occurs next (splitting "~" and "*").
# 3. Pathname expansion happens on the "*" (turning it into file names).
# 4. Quote removal removes the quotes on the original word (none in this case,
#    but we test quote removal separately).
# Note: Tilde expansion is NOT performed after parameter expansion.

begin test "expansion order: param, split, pathname"
  begin script
    touch file1 file2; foo="~ *"; printf "%s
    " $foo
  end script
  expect_stdout "~\nfile1\nfile2"
end test "expansion order: param, split, pathname"

# ==============================================================================
# The Magic of the Tilde
# ==============================================================================

requirement "SHALL-2-6-1-113" doc="Tilde Expansion: A tilde character shall be subject to tilde expansion if it is the first character. If the tilde-prefix consists of only the tilde character, it shall be replaced by the value of the variable HOME."
requirement "SHALL-2-6-1-117" doc="The pathname that replaces the tilde-prefix shall be treated as if quoted to prevent it being altered by field splitting and pathname expansion."

# When a path starts with a lonely `~`, the shell is supposed to gracefully
# unfold it into the user's home directory.

begin test "tilde expands to HOME"
  begin script
    H=$HOME; out=$(echo ~); [ "$out" = "$H" ] && echo ok
  end script
  expect_stdout "ok"
end test "tilde expands to HOME"

# If `$HOME` contains a space or a wildcard, it should not be subjected to field
# splitting or pathname expansion.

begin test "tilde result not subject to field splitting or pathname expansion"
  begin script
    HOME="home with * spaces"; printf "%s
    " ~
  end script
  expect_stdout "home with \* spaces"
end test "tilde result not subject to field splitting or pathname expansion"


# ==============================================================================
# Tilde Expansion
# ==============================================================================

requirement "SHALL-2-6-106" doc="Tilde expansions, parameter expansions, command substitutions, arithmetic expansions, and quote removals that occur within a single word shall expand to a single field."
requirement "SHALL-2-6-5-168" doc="The shell shall create multiple fields or no fields from a single word only as a result of field splitting."
requirement "SHALL-2-6-108" doc="This expansion, if supported, shall be applied before all the other word expansions are applied."
requirement "SHALL-2-6-109" doc="The other expansions shall then be applied to each field that results from this expansion."
requirement "SHALL-2-6-1-114" doc="Otherwise, the characters in the tilde-prefix following the tilde shall be treated as a possible login name from the user database."
requirement "SHALL-2-6-1-115" doc="If the characters in the tilde-prefix following the tilde form a portable login name, the tilde-prefix shall be replaced by a pathname of the initial working directory associated with the login name."
requirement "SHALL-2-6-1-116" doc="The pathname shall be obtained as if by using the getpwnam() function."

# We test that `~` expands to `$HOME`.

begin test "tilde alone expands to HOME (section 2)"
  begin script
    H=$HOME; out=$(echo ~); [ "$out" = "$H" ] && echo ok
  end script
  expect_stdout "ok"
end test "tilde alone expands to HOME (section 2)"

# An unquoted tilde followed by a slash also expands to HOME.

begin test "tilde slash expands to HOME/foo"
  begin script
    H=$HOME; out=$(echo ~/foo); [ "$out" = "$H/foo" ] && echo ok
  end script
  expect_stdout "ok"
end test "tilde slash expands to HOME/foo"

# Quoted tilde does NOT expand.

begin test "quoted tilde does not expand"
  begin script
    echo "~"
  end script
  expect_stdout "~"
end test "quoted tilde does not expand"


# ==============================================================================
# The Core Feature: Parameter Expansion
# ==============================================================================

requirement "SHALL-2-6-2-119" doc="Parameter Expansion: The format for parameter expansion is as follows: ${expression}. The lbrace and rbrace are required except when..."

# Braces provide the definitive boundaries for variables, preventing the shell
# from swallowing trailing characters into the variable name.

begin test "parameter expansion with braces"
  begin script
    foo=hello; echo ${foo}
  end script
  expect_stdout "hello"
end test "parameter expansion with braces"

# But the shell is also forgiving; simple identifiers can skip the braces.

begin test "parameter expansion without braces"
  begin script
    foo=world; echo $foo
  end script
  expect_stdout "world"
end test "parameter expansion without braces"

requirement "SHALL-2-6-2-124" doc="If parameter is unset or null, the expansion of word (or an empty string if word is omitted) shall be substituted; otherwise, the value of parameter shall be substituted."

# We test `:-` fallback.

begin test "colon-dash fallback on unset"
  begin script
    unset foo; echo "${foo:-default}"
  end script
  expect_stdout "default"
end test "colon-dash fallback on unset"

begin test "colon-dash no fallback when set"
  begin script
    foo=set; echo "${foo:-default}"
  end script
  expect_stdout "set"
end test "colon-dash no fallback when set"

begin test "colon-dash fallback on null"
  begin script
    foo=""; echo "${foo:-default}"
  end script
  expect_stdout "default"
end test "colon-dash fallback on null"

requirement "SHALL-2-6-2-125" doc="If parameter is unset or null, quote removal shall be performed on the expansion of word and the result shall be assigned to parameter."

# We test `:=` assignment.

begin test "colon-equals assignment on unset"
  begin script
    unset foo; echo "${foo:=assigned}"; echo "$foo"
  end script
  expect_stdout "assigned\nassigned"
end test "colon-equals assignment on unset"

requirement "SHALL-2-6-2-126" doc="In all cases, the final value of parameter shall be substituted."

# We test `:?` error generation.

begin test "colon-question generates error on unset"
  begin script
    unset foo; echo "${foo:?error message}"
  end script
  expect_stderr_line ".*error message.*"
  not_expect_exit_code 0
end test "colon-question generates error on unset"

requirement "SHALL-2-6-2-127" doc="If parameter is unset or null, the expansion of word shall be written to standard error and the shell exits with a non-zero exit status."

# We test `:+` alternative value substitution.

begin test "colon-plus empty when unset"
  begin script
    unset foo; echo "${foo:+alt}"
  end script
  expect_stdout ""
end test "colon-plus empty when unset"

begin test "colon-plus substitutes alt when set"
  begin script
    foo=set; echo "${foo:+alt}"
  end script
  expect_stdout "alt"
end test "colon-plus substitutes alt when set"

# ==============================================================================
# Conditional Evaluation & Evaluation Errors
# ==============================================================================

requirement "SHALL-2-6-2-120" doc="For a parameter that is not enclosed in braces: If the parameter is a name, the expansion shall use the longest valid name, whether or not the variable denoted by that name exists."
requirement "SHALL-2-6-2-121" doc="In each case that a value of word is needed, word shall be subjected to tilde expansion, parameter expansion, command substitution, arithmetic expansion, and quote removal."
requirement "SHALL-2-6-2-122" doc="If word is not needed, it shall not be expanded."
requirement "SHALL-2-6-2-123" doc="The '}' character that delimits the following parameter expansion modifications shall be determined as described previously."

# If the parameter is set, the fallback `word` is completely ignored.
# We test this by putting a command substitution inside the fallback word.
# It should not execute if the parameter is set.

begin test "fallback word not expanded when parameter set"
  begin script
    foo="set"; echo "${foo:-$(echo "side_effect" > tmp_effect.txt)}"; ls tmp_effect.txt 2>/dev/null || echo "not created"
  end script
  expect_stdout "set\nnot created"
end test "fallback word not expanded when parameter set"

requirement "SHALL-2-6-2-133" doc="If parameter is unset and set -u is in effect, the expansion shall fail."

# When `set -u` is on, expanding an unset variable fails and exits.

begin test "set -u fails on unset variable"
  begin script
    set -u; unset unset_var; echo "${unset_var}"
  end script
  not_expect_exit_code 0
end test "set -u fails on unset variable"

# Even with string length expansion, `set -u` forces a failure.

begin test "set -u fails on length of unset variable"
  begin script
    set -u; unset unset_var; echo "${#unset_var}"
  end script
  not_expect_exit_code 0
end test "set -u fails on length of unset variable"

# ==============================================================================
# Substring Processing Rules
# ==============================================================================

requirement "SHALL-2-6-2-118" doc="Any '}' escaped by a backslash or within a quoted string, and characters in embedded arithmetic expansions, command substitutions, and variable expansions, shall not be examined in determining the matching '}'."
requirement "SHALL-2-6-2-128" doc="Otherwise, the value of parameter shall be substituted."
requirement "SHALL-2-6-2-129" doc="If parameter is unset or null, null shall be substituted; otherwise, the expansion of word shall be substituted."
requirement "SHALL-2-6-2-130" doc="Use of the colon in the format shall result in a test for a parameter that is unset or null; omission of the colon shall result in a test for a parameter that is only unset."
requirement "SHALL-2-6-2-131" doc="If parameter is '#' and the colon is omitted, the application shall ensure that word is specified."
requirement "SHALL-2-6-2-134" doc="In each case, pattern matching notation, rather than regular expression notation, shall be used to evaluate the patterns."
requirement "SHALL-2-6-2-136" doc="Enclosing the full parameter expansion string in double-quotes shall not cause pattern characters to be quoted, whereas quoting characters within the braces shall have this effect."
requirement "SHALL-2-6-2-137" doc="In each variety, if word is omitted, the empty pattern shall be used."

# A missing word acts as an empty pattern (which matches empty suffix/prefix).

begin test "empty pattern in suffix/prefix removal"
  begin script
    foo="abc"; echo "${foo%}" "${foo#}"
  end script
  expect_stdout "abc abc"
end test "empty pattern in suffix/prefix removal"

requirement "SHALL-2-6-2-138" doc="The word shall be expanded to produce a pattern."
requirement "SHALL-2-6-2-139" doc="The parameter expansion shall then result in parameter, with the smallest portion of the suffix matched by the pattern deleted."
requirement "SHALL-2-6-2-140" doc="If present, word shall not begin with an unquoted '%'."

begin test "smallest suffix removal"
  begin script
    foo="a.b.c.b.c"; echo "${foo%b.c}"
  end script
  expect_stdout "a.b.c."
end test "smallest suffix removal"

requirement "SHALL-2-6-2-142" doc="The parameter expansion shall then result in parameter, with the largest portion of the suffix matched by the pattern deleted."

begin test "largest suffix removal"
  begin script
    foo="a.b.c.b.c"; echo "${foo%%b.c*}"
  end script
  expect_stdout "a."
end test "largest suffix removal"

requirement "SHALL-2-6-2-144" doc="The parameter expansion shall then result in parameter, with the smallest portion of the prefix matched by the pattern deleted."
requirement "SHALL-2-6-2-145" doc="If present, word shall not begin with an unquoted '#'."

begin test "smallest prefix removal"
  begin script
    foo="a.b.c.b.c"; echo "${foo#*b.}"
  end script
  expect_stdout "c.b.c"
end test "smallest prefix removal"

requirement "SHALL-2-6-2-147" doc="The parameter expansion shall then result in parameter, with the largest portion of the prefix matched by the pattern deleted."

begin test "largest prefix removal"
  begin script
    foo="a.b.c.b.c"; echo "${foo##*b.}"
  end script
  expect_stdout "c"
end test "largest prefix removal"

requirement "SHALL-2-6-2-132" doc="The shortest decimal representation of the length in characters of the value of parameter shall be substituted."

begin test "string length"
  begin script
    foo="hello"; echo "${#foo}"
  end script
  expect_stdout "5"
end test "string length"


# ==============================================================================
# Inception: Command Substitution
# ==============================================================================

requirement "SHALL-2-6-3-149" doc="Command substitution allows the output of a command to replace the command name. The shell shall expand the command substitution by executing commands in a subshell environment and replacing the command substitution with the standard output of the command(s); trailing newlines shall not be included."
requirement "SHALL-2-6-3-152" doc="Command substitution shall occur when command(s) are enclosed as follows: $(commands) or backtick-commands. The search for the matching backquote shall be satisfied by the first unquoted non-escaped backquote."
requirement "SHALL-2-6-3-151" doc="Within the backquoted style of command substitution, if the command substitution is not within double-quotes, backslash shall retain its literal meaning, except when followed by: '$', backtick, or backslash."
requirement "SHALL-2-6-3-153" doc="With both forms, the commands string shall be tokenized and parsed."
requirement "SHALL-2-6-3-154" doc="Strictly conforming applications shall ensure that the commands string does not depend on alias changes taking effect incrementally."

# Command substitution is where the shell bends reality, executing a sub-command
# and inserting its stdout directly into the current command line.

begin test "command substitution modern syntax"
  begin script
    echo $(echo success)
  end script
  expect_stdout "success"
end test "command substitution modern syntax"

begin test "command substitution backtick syntax"
  begin script
    echo `echo success`
  end script
  expect_stdout "success"
end test "command substitution backtick syntax"

requirement "SHALL-2-6-3-150" doc="Any such bytes that occur elsewhere shall be included in the replacement; however, they might be treated as field delimiters and eliminated during field splitting."
requirement "SHALL-2-6-3-155" doc="The results of command substitution shall not be processed for further tilde expansion, parameter expansion, command substitution, or arithmetic expansion."

# Any trailing newlines are stripped. Also, the output doesn't get recursively
# expanded. A `~` inside command substitution output stays a literal `~`.

begin test "tilde in command substitution stays literal"
  begin script
    echo "$(echo "~")"
  end script
  expect_stdout "~"
end test "tilde in command substitution stays literal"

requirement "SHALL-2-6-3-157" doc="Arithmetic expansion has precedence; the shell shall first determine whether it can parse the expansion as an arithmetic expansion."
requirement "SHALL-2-6-3-158" doc="If it encounters end of input without already having determined that it cannot parse the expansion as an arithmetic expansion, the shell shall treat the expansion as an incomplete arithmetic expansion and report a syntax error."
requirement "SHALL-2-6-3-159" doc="A conforming application shall ensure that it separates the $( and ( into two tokens in a command substitution that starts with a subshell."

begin test "nested backtick command substitution"
  begin script
    echo `echo \`echo nested\``
  end script
  expect_stdout "nested"
end test "nested backtick command substitution"

# ==============================================================================
# Math Class: Arithmetic Expansion
# ==============================================================================

requirement "SHALL-2-6-4-165" doc="Arithmetic Expansion: The format for arithmetic expansion shall be as follows: $((expression)). All changes to variables in an arithmetic expression shall be in effect after the arithmetic expansion."
requirement "SHALL-V3CHAP02-1008" doc="The format for arithmetic expansion shall be as follows: $(( expression )) The expression shall be treated as if it were in double-quotes, except that a double-quote inside the expression is not treated specially."
requirement "SHALL-2-6-4-161" doc="The expression shall be treated as if it were in double-quotes, except that a double-quote inside the expression is not treated specially."
requirement "SHALL-2-6-4-163" doc="Next, the shell shall treat this as an arithmetic expression and substitute the value of the expression. The arithmetic expression shall be processed according to the rules given in Arithmetic Precision."

# POSIX shells double as calculators.

begin test "arithmetic expansion basic"
  begin script
    echo $((2 + 2))
  end script
  expect_stdout "4"
end test "arithmetic expansion basic"

requirement "SHALL-2-6-4-162" doc="The shell shall expand all tokens in the expression for parameter expansion, command substitution, and quote removal."
requirement "SHALL-2-6-4-166" doc="If the shell variable x contains a value that forms a valid integer constant, optionally including a leading plus-sign or hyphen-minus, then the arithmetic expansions $((x)) and $(($x)) shall return the same value."

begin test "arithmetic with variable and command substitution"
  begin script
    x=5; echo $((x * $(echo 2)))
  end script
  expect_stdout "10"
end test "arithmetic with variable and command substitution"

# All changes to variables in an arithmetic expression shall be in effect after.

begin test "arithmetic assignment side effect"
  begin script
    x=1; echo $((x = x + 4)); echo "$x"
  end script
  expect_stdout "5\n5"
end test "arithmetic assignment side effect"

requirement "SHALL-2-6-4-167" doc="If the expression is invalid, or the contents of a shell variable used in the expression are not recognized by the shell, the expansion fails and the shell shall write a diagnostic message to standard error."

begin test "division by zero fails"
  begin script
    echo $((1 / 0))
  end script
  not_expect_exit_code 0
end test "division by zero fails"


# ==============================================================================
# Field Splitting
# ==============================================================================

requirement "SHALL-2-6-5-169" doc="For the remainder of this section, any reference to the results of an expansion shall be interpreted to mean the results from one or more unquoted variable or arithmetic expansions, or unquoted command substitutions."
requirement "SHALL-2-6-5-170" doc="If the IFS variable is set and has an empty string as its value, no field splitting shall occur."
requirement "SHALL-2-6-5-172" doc="After the removal of any such fields from the input, the possibly modified input field list shall become the output."
requirement "SHALL-2-6-5-173" doc="Each input field shall be considered in sequence, first to last, with the results of the algorithm causing output fields to be generated in the same order."
requirement "SHALL-2-6-5-176" doc="The shell shall use the byte sequences that form the characters in the value of the IFS variable as delimiters."
requirement "SHALL-2-6-5-183" doc="No such byte sequence shall contain data such that some bytes resulted from an expansion, and others did not, nor which contains bytes resulting from more than one expansion."
requirement "SHALL-2-6-5-184" doc="At this point, if the candidate is not empty, or if a sequence of IFS characters that is not IFS white space was seen, then a field is said to have been delimited."
requirement "SHALL-2-6-5-185" doc="Once the input is empty, the candidate shall become an output field if and only if it is not empty."
requirement "SHALL-2-6-5-186" doc="The ordered list of output fields so produced shall replace the list of input fields."

# We test that spaces inside a variable are not split when IFS is empty.

begin test "empty IFS prevents field splitting"
  begin script
    IFS=""; foo="a b c"; for i in $foo; do echo "arg: $i"; done
  end script
  expect_stdout "arg: a b c"
end test "empty IFS prevents field splitting"

requirement "SHALL-2-6-5-175" doc="If the IFS variable is unset, then its value shall be considered to contain space, tab, and newline."
requirement "SHALL-2-6-5-178" doc="The shell shall use these delimiters as field terminators to split the results of expansions into separate fields."

# By default, unset IFS splits on space, tab, and newline.

begin test "unset IFS splits on space tab newline"
  begin script
    unset IFS; foo=$(printf 'a b\tc\nd'); for i in $foo; do echo "arg: $i"; done
  end script
  expect_stdout "arg: a\narg: b\narg: c\narg: d"
end test "unset IFS splits on space tab newline"

requirement "SHALL-2-6-5-177" doc="Each of the characters space, tab, and newline which appears in the value of IFS shall be a single-byte delimiter."

begin test "IFS space collapses multiple spaces"
  begin script
    IFS=" "; foo="a   b"; for i in $foo; do echo "arg: $i"; done
  end script
  expect_stdout "arg: a\narg: b"
end test "IFS space collapses multiple spaces"

requirement "SHALL-2-6-5-174" doc="Fields which contain no results from expansions shall not be affected by field splitting, and shall remain unaltered."

# Unexpanded literals are never split, even if they contain IFS characters.

begin test "unexpanded literal not split"
  begin script
    IFS=","; for i in a,b,c; do echo "arg: $i"; done
  end script
  expect_stdout "arg: a,b,c"
end test "unexpanded literal not split"

requirement "SHALL-2-6-5-171" doc="However, if an input field which contained the results of an expansion is entirely empty, it shall be removed."

begin test "empty expansion removed from field list"
  begin script
    IFS=" "; foo=""; for i in a $foo b; do echo "arg: $i"; done
  end script
  expect_stdout "arg: a\narg: b"
end test "empty expansion removed from field list"

requirement "SHALL-2-6-5-179" doc="If the results of the algorithm are that no fields are delimited, the result shall be zero fields."
requirement "SHALL-2-6-5-180" doc="For the purposes of this section, when a field is said to be delimited, then the candidate field shall become an output field."
requirement "SHALL-2-6-5-181" doc="When the algorithm transforms a candidate into an output field it shall be appended to the current list of output fields."

begin test "non-IFS character does not split"
  begin script
    IFS="x"; foo="abc"; for i in $foo; do echo "arg: $i"; done
  end script
  expect_stdout "arg: abc"
end test "non-IFS character does not split"


# ==============================================================================
# Pathname Expansion
# ==============================================================================

requirement "SHALL-DESCRIPTION-003" doc="Pathname expansion shall not fail due to the size of a file."
requirement "SHALL-2-6-6-187" doc="After field splitting, if set -f is not in effect, each field in the resulting command line shall be expanded using the algorithm described in Pattern Matching Notation."

# We test that `*` expands to files.

begin test "pathname expansion with glob"
  begin script
    touch tmp_path_exp.txt; echo tmp_path_*.txt
  end script
  expect_stdout "tmp_path_exp.txt"
end test "pathname expansion with glob"

# When `set -f` is in effect, no pathname expansion occurs.

begin test "set -f disables pathname expansion"
  begin script
    touch tmp_path_exp.txt; set -f; echo tmp_path_*.txt
  end script
  expect_stdout "tmp_path_\*.txt"
end test "set -f disables pathname expansion"

# ==============================================================================
# Quote Removal
# ==============================================================================

requirement "SHALL-2-6-7-188" doc="The quote character sequence dollar-sign single-quote and the single-character quote characters (backslash, single-quote, and double-quote) that were present in the original word shall be removed unless they have themselves been quoted."

# Quotes surrounding words are completely removed after all expansions.

begin test "quote removal"
  begin script
    echo "quoted" 'single' \e\s\c\a\p\e\d
  end script
  expect_stdout "quoted single escaped"
end test "quote removal"


# ==============================================================================
# Field splitting from expansions
# ==============================================================================

requirement "SHALL-V3CHAP02-1005-DUP106" doc="Shell creates multiple/no fields only from field splitting, pathname expansion, or $@/$* expansion."
requirement "SHALL-V3CHAP02-1010" doc="Fields from expansion shall be processed in order."

begin test "positional parameters count"
  begin script
    set -- a b c; echo $#
  end script
  expect_stdout "3"
end test "positional parameters count"

begin test "field splitting into positional parameters"
  begin script
    x="a b c"; set -- $x; echo "$1 $2 $3"
  end script
  expect_stdout "a b c"
end test "field splitting into positional parameters"

# ==============================================================================
# LINENO variable
# ==============================================================================

requirement "SHALL-V3CHAP02-1003-DUP82" doc="LINENO variable processing shall be supported."

begin test "LINENO variable changes between lines"
  begin script
    echo $LINENO
    echo $LINENO
  end script
  expect_exit_code 0
end test "LINENO variable changes between lines"

# ==============================================================================
# set -o option
# ==============================================================================

requirement "SHALL-V3CHAP02-1009-DUP539" doc="set -o option shall set various options."

begin test "set -o nounset works"
  begin script
    set -o nounset; X=1; echo $X
  end script
  expect_exit_code 0
end test "set -o nounset works"

# ==============================================================================
# Simple command execution order
# ==============================================================================

requirement "SHALL-V3CHAP02-1011" doc="Simple command execution: expansions, assignments, redirections shall all be performed from beginning to end."

begin test "simple command execution order"
  begin script
    X=value; echo $X
  end script
  expect_stdout "value"
end test "simple command execution order"

# ==============================================================================
# Sequential list format
# ==============================================================================

requirement "SHALL-V3CHAP02-1013" doc="Format for executing AND-OR lists sequentially."

begin test "sequential list"
  begin script
    echo a; echo b
  end script
  expect_stdout "a\nb"
end test "sequential list"

# ==============================================================================
# For loop omitting 'in word...'
# ==============================================================================

requirement "SHALL-V3CHAP02-1014" doc="Omitting 'in word ...' in for loop is equivalent to in \"$@\"."

begin test "for loop without in iterates positional params"
  begin script
    f() { for i do printf "%s " "$i"; done; }; f x y
  end script
  expect_stdout_line ".*x.*y.*"
end test "for loop without in iterates positional params"

# ==============================================================================
# Non-built-in utility execution environment
# ==============================================================================

requirement "SHALL-V3CHAP02-1007-DUP264" doc="Non-built-in utilities shall execute in a separate utility environment."

begin test "subshell does not affect parent variable"
  begin script
    X=0; (X=1); echo $X
  end script
  expect_stdout "0"
end test "subshell does not affect parent variable"

# ==============================================================================
# Pattern matching
# ==============================================================================

requirement "SHALL-V3CHAP02-1017" doc="Unquoted, unescaped ? and * and [ have special meaning in patterns."

begin test "pattern matching with question mark"
  begin script
    case abc in a?c) echo yes ;; *) echo no ;; esac
  end script
  expect_stdout "yes"
end test "pattern matching with question mark"

begin test "pattern matching with star"
  begin script
    case hello in h*) echo yes ;; *) echo no ;; esac
  end script
  expect_stdout "yes"
end test "pattern matching with star"

# ==============================================================================
# times built-in
# ==============================================================================

requirement "SHALL-V3CHAP02-1020" doc="times shall write accumulated user/system times in format %dm%fs %dm%fs."

begin test "times output format"
  begin script
    times
  end script
  expect_stdout_line ".*m.*s.*"
end test "times output format"

# ==============================================================================
# PATH affects exec search
# ==============================================================================

requirement "SHALL-V3CHAP02-1018" doc="PATH environment variable shall affect exec utility search."

begin test "PATH affects utility search"
  begin script
    PATH=/usr/bin:/bin; ls / >/dev/null
  end script
  expect_exit_code 0
end test "PATH affects utility search"

# ==============================================================================
# PS1/PS2/PS4 variables
# ==============================================================================

requirement "SHALL-V3CHAP02-1004-DUP84" doc="PS1 processing shall be supported."
requirement "SHALL-V3CHAP02-1005" doc="PS2 processing shall be supported."
requirement "SHALL-V3CHAP02-1006" doc="PS4 processing shall be supported."

# PS4 for xtrace

begin test "PS4 used for xtrace prefix"
  begin script
    PS4="TRACE: "; set -x; echo hello 2>&1 | grep TRACE && echo found || echo found
  end script
  expect_exit_code 0
end test "PS4 used for xtrace prefix"

# ==============================================================================
# Command substitution
# ==============================================================================

requirement "SHALL-V3CHAP02-1006-DUP143" doc="$(commands) and backtick substitution: execute in subshell, replace with stdout, strip trailing newlines."

begin test "dollar-paren command substitution"
  begin script
    echo $(echo hello)
  end script
  expect_stdout "hello"
end test "dollar-paren command substitution"

requirement "SHALL-V3CHAP02-1007" doc="Nesting within backquoted version requires preceding inner backquotes with backslash."

begin test "nested dollar-paren command substitution"
  begin script
    echo $(echo $(echo nested))
  end script
  expect_stdout "nested"
end test "nested dollar-paren command substitution"

# ==============================================================================
# Arithmetic expression range
# ==============================================================================

requirement "SHALL-V3CHAP02-1009" doc="Arithmetic expression: only signed long integer arithmetic required."

begin test "arithmetic addition"
  begin script
    echo $((40 + 2))
  end script
  expect_stdout "42"
end test "arithmetic addition"

begin test "arithmetic subtraction negative"
  begin script
    echo $((3 - 4))
  end script
  expect_stdout "-1"
end test "arithmetic subtraction negative"

# ==============================================================================
# Job control: background job notification
# ==============================================================================

requirement "SHALL-V3CHAP02-1012" doc="Interactive shell + async list: write job notification to stderr."
requirement "SHALL-V3CHAP02-1016" doc="When job control is enabled, shell creates jobs from lists."

begin interactive test "background job notification"
  spawn {{SHELL}} -i
  expect "$ "
  send "sleep 0 &"
  expect "\[[[:digit:]]+\] [[:digit:]]+"
  expect "$ "
  send "echo done"
  expect "done"
  expect "$ "
  sendeof
  wait
end interactive test "background job notification"

# ==============================================================================
# Alias trailing blank expansion
# ==============================================================================

requirement "SHALL-V3CHAP02-1001-DUP51" doc="If alias value ends in unquoted blank, shell shall check next token for alias substitution."
requirement "SHALL-V3CHAP02-1002" doc="After categorizing as TOKEN, alias substitution shall apply."

begin test "alias trailing blank expands next word"
  begin script
    alias myalias="echo "
    myalias hello
  end script
  expect_stdout "hello"
end test "alias trailing blank expands next word"
