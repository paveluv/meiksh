testsuite "XBD 8 Environment Variables"

# ==============================================================================
# PATH
# ==============================================================================

requirement "SHALL-XBD-8-3011" doc="PATH This variable shall represent the sequence of path prefixes that certain functions and utilities apply in searching for an executable file."

begin test "PATH used to find executable"
  script
    mkdir -p mybin
    printf '#!%s\necho mytool executed\n' "${SHELL%% *}" > mybin/mytool
    chmod +x mybin/mytool
    PATH="$PWD/mybin:$PATH" mytool
    rm -rf mybin
  expect
    stdout "mytool executed"
    stderr ""
    exit_code 0
end test "PATH used to find executable"

# ==============================================================================
# PWD
# ==============================================================================

requirement "SHALL-XBD-8-3012" doc="PWD This variable shall represent an absolute pathname of the current working directory."

begin test "PWD reflects current working directory"
  script
    echo "$PWD"
  expect
    stdout ".*"
    stderr ""
    exit_code 0
end test "PWD reflects current working directory"

# ==============================================================================
# HOME
# ==============================================================================

requirement "SHALL-XBD-8-3010" doc="HOME The system shall initialize this variable at the time of login to be a pathname of the user's home directory."

begin test "HOME used for tilde expansion"
  script
    mkdir -p myhome
    HOME="$PWD/myhome"
    echo ~
    rm -rf myhome
  expect
    stdout ".*/myhome"
    stderr ""
    exit_code 0
end test "HOME used for tilde expansion"

# ==============================================================================
# LANG determines locale in absence of LC_*
# ==============================================================================

requirement "SHALL-XBD-8-3000" doc="LANG This variable shall determine the locale category for native language, local customs, and coded character set in the absence of the LC_ALL and other LC_* ( LC_COLLATE , LC_CTYPE , LC_MESSAGES , LC_MONETARY , LC_NUMERIC , LC_TIME ) environment variables."
requirement "SHALL-XBD-8-3009" doc="If the LANG environment variable is defined and is not null, the value of the LANG environment variable shall be used."

begin test "LANG passed to child environment"
  script
    export LANG=C
    env | grep "^LANG=C$" && echo pass || echo fail
  expect
    stdout "LANG=C\npass"
    stderr ""
    exit_code 0
end test "LANG passed to child environment"

# ==============================================================================
# LC_ALL overrides all locale categories
# ==============================================================================

requirement "SHALL-XBD-8-3002" doc="LC_ALL This variable shall determine the values for all locale categories."
requirement "SHALL-XBD-8-3007" doc="If the LC_ALL environment variable is defined and is not null, the value of LC_ALL shall be used."

begin test "LC_ALL overrides individual LC_* variables"
  script
    export LC_ALL=C
    export LC_CTYPE=en_US.UTF-8
    env | grep "^LC_ALL=C$" && echo pass || echo fail
  expect
    stdout "LC_ALL=C\npass"
    stderr ""
    exit_code 0
end test "LC_ALL overrides individual LC_* variables"

# ==============================================================================
# Individual LC_* category variables
# ==============================================================================

requirement "SHALL-XBD-8-3003" doc="LC_COLLATE This variable shall determine the locale category for character collation."
requirement "SHALL-XBD-8-3004" doc="LC_CTYPE This variable shall determine the locale category for character handling functions, such as tolower () , toupper () , and isalpha ()."
requirement "SHALL-XBD-8-3008" doc="If the LC_* environment variable ( LC_COLLATE , LC_CTYPE , LC_MESSAGES , LC_MONETARY , LC_NUMERIC , LC_TIME ) is defined and is not null, the value of the environment variable shall be used to initialize the category that corresponds to the environment variable."

begin test "LC_COLLATE and LC_CTYPE passed to child"
  script
    export LC_COLLATE=C
    export LC_CTYPE=C
    env | grep -E "^(LC_COLLATE|LC_CTYPE)=C$" | sort
  expect
    stdout "LC_COLLATE=C\nLC_CTYPE=C"
    stderr ""
    exit_code 0
end test "LC_COLLATE and LC_CTYPE passed to child"

# ==============================================================================
# LC_MESSAGES determines message locale
# ==============================================================================

requirement "SHALL-XBD-8-3005" doc="LC_MESSAGES This variable shall determine the locale category for processing affirmative and negative responses and the language and cultural conventions in which messages should be written."

begin test "LC_MESSAGES passed to child"
  script
    export LC_MESSAGES=C
    env | grep "^LC_MESSAGES=C$" && echo pass || echo fail
  expect
    stdout "LC_MESSAGES=C\npass"
    stderr ""
    exit_code 0
end test "LC_MESSAGES passed to child"

# ==============================================================================
# LANGUAGE and NLSPATH for message catalog lookup
# ==============================================================================

requirement "SHALL-XBD-8-3001" doc="The LANGUAGE environment variable shall be examined to determine the messages object to be used for the gettext family of functions or the gettext and ngettext utilities if NLSPATH is not set or the evaluation of NLSPATH did not lead to a suitable messages object being found."
requirement "SHALL-XBD-8-3006" doc="This variable shall contain a sequence of templates to be used by catopen () when attempting to locate message catalogs, and by the gettext family of functions when locating messages objects."

begin test "LANGUAGE and NLSPATH passed to child"
  script
    export LANGUAGE=C
    export NLSPATH=/dev/null
    env | grep -E "^(LANGUAGE|NLSPATH)=" | sort
  expect
    stdout "LANGUAGE=C\nNLSPATH=/dev/null"
    stderr ""
    exit_code 0
end test "LANGUAGE and NLSPATH passed to child"

# ==============================================================================
# All locale variables together in child environment
# ==============================================================================

requirement "SHALL-ENVIRONMENT-VARIABLES-5005" doc="The following environment variables shall affect the execution of echo : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "locale variables passed to child environment"
  script
    export LANG=C
    export LC_ALL=C
    export LC_COLLATE=C
    export LC_CTYPE=C
    export LC_MESSAGES=C
    export LANGUAGE=C
    export NLSPATH=/dev/null
    env | grep -E "^(LANG|LC_ALL|LC_COLLATE|LC_CTYPE|LC_MESSAGES|LANGUAGE|NLSPATH)=" | sort
  expect
    stdout "LANG=C\nLANGUAGE=C\nLC_ALL=C\nLC_COLLATE=C\nLC_CTYPE=C\nLC_MESSAGES=C\nNLSPATH=/dev/null"
    stderr ""
    exit_code 0
end test "locale variables passed to child environment"
