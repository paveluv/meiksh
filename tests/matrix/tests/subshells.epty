testsuite "Shell Execution Environment (Subshells)"

# ==============================================================================
# Subshell Parsing and Status
# ==============================================================================

requirement "SHALL-2-9-4-1-346" doc="Variable assignments and built-in commands that affect the environment shall not remain in effect after the list finishes"
requirement "SHALL-2-9-4-1-1-348" doc="The exit status of a grouping command shall be the exit status of compound-list"

begin test "subshell false propagates exit status"
  begin script
    ( false )
    exit $?
  end script
  expect_exit_code 1
end test "subshell false propagates exit status"

# ==============================================================================
# Subshell Isolation
# ==============================================================================

requirement "SHALL-2-13-471" doc="A subshell environment shall be created as a duplicate of the shell environment"
requirement "SHALL-2-13-473" doc="Changes made to the subshell environment shall not affect the shell environment"
requirement "SHALL-2-13-474" doc="Command substitution, commands that are grouped with parentheses, and asynchronous AND-OR lists shall be executed in a subshell environment"

begin test "parent variable visible in subshell but changes do not propagate"
  begin script
    var="parent"; (echo "$var"; var="child"; echo "$var"); echo "$var"
  end script
  expect_stdout "parent\nchild\nparent"
end test "parent variable visible in subshell but changes do not propagate"

begin test "command substitution isolation"
  begin script
    var="parent"; output=$(var="child"; echo "$var"); echo "$output $var"
  end script
  expect_stdout "child parent"
end test "command substitution isolation"

begin test "asynchronous list isolation"
  begin script
    var="parent"; { var="child"; echo "$var" > tmp_sub.txt; } & wait; echo "$var"; cat tmp_sub.txt
  end script
  expect_stdout "parent\nchild"
end test "asynchronous list isolation"

# ==============================================================================
# Current Environment Execution
# ==============================================================================

requirement "SHALL-2-13-475" doc="Except where otherwise stated, all other commands shall be executed in the current shell environment"

begin test "group commands execute in current environment"
  begin script
    var="parent"; { var="child"; echo "$var"; }; echo "$var"
  end script
  expect_stdout "child\nchild"
end test "group commands execute in current environment"

begin test "if construct executes in current environment"
  begin script
    var="parent"; if true; then var="child"; fi; echo "$var"
  end script
  expect_stdout "child"
end test "if construct executes in current environment"

# ==============================================================================
# Utility Invocations
# ==============================================================================

requirement "SHALL-2-13-469" doc="The environment of the shell process shall not be changed by the utility unless explicitly specified by the utility description"

begin test "external cd does not change parent working directory"
  begin script
    cd /tmp; parent="$PWD"; env cd /; echo "$PWD" = "$parent"
  end script
  expect_stdout "/tmp = /tmp"
end test "external cd does not change parent working directory"
