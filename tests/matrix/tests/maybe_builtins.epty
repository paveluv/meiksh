testsuite "Maybe-Builtin Utilities (true, false, test, pwd, printf)"

# ==============================================================================
# true utility
# ==============================================================================

requirement "SHALL-DESCRIPTION-5076" doc="The true utility shall return with exit code zero."

begin test "true returns exit code 0"
  begin script
    true
  end script
  expect_exit_code 0
end test "true returns exit code 0"

# ==============================================================================
# false utility
# ==============================================================================

requirement "SHALL-DESCRIPTION-5018" doc="The false utility shall return with a non-zero exit code."
requirement "SHALL-EXIT-STATUS-5019" doc="The false utility shall always exit with a value between 1 and 125, inclusive."

begin test "false returns non-zero exit code"
  begin script
    false
  end script
  expect_exit_code !=0
end test "false returns non-zero exit code"

requirement "SHALL-EXIT-STATUS-5019" doc="The false utility shall always exit with a value between 1 and 125, inclusive."
begin test "false exit code is between 1 and 125"
  begin script
    false
    rc=$?
    [ $rc -ge 1 ] && [ $rc -le 125 ] && echo "in_range"
  end script
  expect_stdout "in_range"
end test "false exit code is between 1 and 125"

# ==============================================================================
# test utility
# ==============================================================================

requirement "SHALL-DESCRIPTION-5065" doc="The test utility shall evaluate the expression and indicate the result of the evaluation by its exit status."
requirement "SHALL-DESCRIPTION-5066" doc="In the second form of the utility, where the utility name used is [ rather than test , the application shall ensure that the closing square bracket is a separate argument."
requirement "SHALL-OPERANDS-5070" doc="The application shall ensure that all operators and elements of primaries are presented as separate arguments to the test utility."

begin test "test 1 -eq 1 returns 0"
  begin script
    test 1 -eq 1
  end script
  expect_exit_code 0
end test "test 1 -eq 1 returns 0"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
begin test "test 1 -eq 2 returns non-zero"
  begin script
    test 1 -eq 2
  end script
  expect_exit_code !=0
end test "test 1 -eq 2 returns non-zero"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
begin test "[ 1 -eq 1 ] returns 0"
  begin script
    [ 1 -eq 1 ]
  end script
  expect_exit_code 0
end test "[ 1 -eq 1 ] returns 0"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
begin test "[ 1 -eq 2 ] returns non-zero"
  begin script
    [ 1 -eq 2 ]
  end script
  expect_exit_code !=0
end test "[ 1 -eq 2 ] returns non-zero"

# ==============================================================================
# test does not recognize --
# ==============================================================================

requirement "SHALL-OPTIONS-5068" doc="The test utility shall not recognize the \"--\" argument in the manner specified by Guideline 10 in XBD 12.2 Utility Syntax Guidelines ."
requirement "SHALL-OPTIONS-5069" doc="No options shall be supported."

begin test "test does not consume -- as end-of-options"
  begin script
    test -- = --
  end script
  expect_exit_code 0
end test "test does not consume -- as end-of-options"

# ==============================================================================
# test file and string primaries
# ==============================================================================

requirement "SHALL-2-14-3-498" doc="If a specified pattern contains any '*' , '?' or '[' characters that will be treated as special (see 2.14.1 Patterns Matching a Single Character ), it shall be matched against existing filenames and pathnames, as appropriate; if directory entries for dot and dot-dot exist, they may be ignored."
begin test "test -d on existing directory"
  begin script
    test -d /
  end script
  expect_exit_code 0
end test "test -d on existing directory"

requirement "SHALL-2-6-2-130" doc="In the parameter expansions shown previously, use of the <colon> in the format shall result in a test for a parameter that is unset or null; omission of the <colon> shall result in a test for a parameter that is only unset."
begin test "test -d on nonexistent directory"
  begin script
    test -d /nonexistent_dir_99999
  end script
  expect_exit_code !=0
end test "test -d on nonexistent directory"

requirement "SHALL-ENVIRONMENT-VARIABLES-5074" doc="The following environment variables shall affect the execution of test : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "test -n on non-empty string"
  begin script
    test -n "hello"
  end script
  expect_exit_code 0
end test "test -n on non-empty string"

requirement "SHALL-ENVIRONMENT-VARIABLES-5074" doc="The following environment variables shall affect the execution of test : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "test -z on empty string"
  begin script
    test -z ""
  end script
  expect_exit_code 0
end test "test -z on empty string"

requirement "SHALL-ENVIRONMENT-VARIABLES-5074" doc="The following environment variables shall affect the execution of test : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "test -z on non-empty string returns non-zero"
  begin script
    test -z "hello"
  end script
  expect_exit_code !=0
end test "test -z on non-empty string returns non-zero"

# ==============================================================================
# test operand form and precedence
# ==============================================================================

requirement "SHALL-OPERANDS-5072" doc="They shall be of the form - operator where the first character of operator is not a digit."
requirement "SHALL-OPERANDS-5073" doc="The algorithm for determining the precedence of the operators and the return value that shall be generated is based on the number of arguments presented to test."
requirement "SHALL-EXIT-STATUS-5075" doc="The following exit values shall be returned: 0 expression evaluated to true."

begin test "unary -n on non-empty string"
  begin script
    test -n hello
  end script
  expect_exit_code 0
end test "unary -n on non-empty string"

requirement "SHALL-ENVIRONMENT-VARIABLES-5074" doc="The following environment variables shall affect the execution of test : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "unary -z on empty string"
  begin script
    test -z ""
  end script
  expect_exit_code 0
end test "unary -z on empty string"

requirement "SHALL-CD-1094" doc="If directory is an empty string, cd shall write a diagnostic message to standard error and exit with non-zero status."
begin test "unary -n on empty string returns non-zero"
  begin script
    test -n ""
  end script
  expect_exit_code !=0
end test "unary -n on empty string returns non-zero"

requirement "SHALL-V3CHAP02-1010" doc="Each field containing the results from an expansion shall be processed in order, intermixed with fields not containing the results of expansions, processed as described above, as if by using the following algorithm, examining bytes in the input field, from beginning to end: Begin with an empty candidate field and the input as specified above."
begin test "binary = equality"
  begin script
    test hello = hello
  end script
  expect_exit_code 0
end test "binary = equality"

requirement "SHALL-V3CHAP02-1010" doc="Each field containing the results from an expansion shall be processed in order, intermixed with fields not containing the results of expansions, processed as described above, as if by using the following algorithm, examining bytes in the input field, from beginning to end: Begin with an empty candidate field and the input as specified above."
begin test "binary = inequality"
  begin script
    test hello = world
  end script
  expect_exit_code !=0
end test "binary = inequality"

requirement "SHALL-2-5-2-064" doc="If one of these conditions is true, the initial fields shall be retained as separate fields, except that if the parameter being expanded was embedded within a word, the first field shall be joined with the beginning part of the original word and the last field shall be joined with the end part of the original word."
begin test "binary -gt true"
  begin script
    test 5 -gt 3
  end script
  expect_exit_code 0
end test "binary -gt true"

requirement "SHALL-2-9-3-319" doc="For example, both of the following commands write solely bar to standard output: false && echo foo || echo bar true || echo foo && echo bar A ';' separator or a ';' or <newline> terminator shall cause the preceding AND-OR list to be executed sequentially; an '&' separator or terminator shall cause asynchronous execution of the preceding AND-OR list."
begin test "binary -gt false"
  begin script
    test 3 -gt 5
  end script
  expect_exit_code !=0
end test "binary -gt false"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
begin test "zero arguments returns non-zero"
  begin script
    test
  end script
  expect_exit_code !=0
end test "zero arguments returns non-zero"

requirement "SHALL-CD-1101" doc="If a non-empty directory name from CDPATH is not used, and the directory argument is not '-' , there shall be no output."
begin test "one non-empty argument returns 0"
  begin script
    test something
  end script
  expect_exit_code 0
end test "one non-empty argument returns 0"

requirement "SHALL-2-5-2-065" doc="If there are no positional parameters, the expansion of '@' shall generate zero fields, even when '@' is within double-quotes; however, if the expansion is embedded within a word which contains one or more other parts that expand to a quoted null string, these null string(s) shall still produce an empty field, except that if the other parts are all within the same double-quotes as the '@' , it is unspecified whether the result is zero fields or one empty field."
begin test "one empty argument returns non-zero"
  begin script
    test ""
  end script
  expect_exit_code !=0
end test "one empty argument returns non-zero"

requirement "SHALL-DESCRIPTION-5076" doc="The true utility shall return with exit code zero."
begin test "test true exit code is 0"
  begin script
    test 1 -eq 1
    echo "$?"
  end script
  expect_stdout "0"
end test "test true exit code is 0"

requirement "SHALL-DESCRIPTION-5018" doc="The false utility shall return with a non-zero exit code."
begin test "test false exit code is 1"
  begin script
    test 1 -eq 2
    echo "$?"
  end script
  expect_stdout "1"
end test "test false exit code is 1"

requirement "SHALL-ENVIRONMENT-VARIABLES-5074" doc="The following environment variables shall affect the execution of test : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "test with single non-null argument exits 0"
  begin script
    test -f
    echo $?
  end script
  expect_stdout "0"
end test "test with single non-null argument exits 0"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
begin test "[ ] with no arguments returns non-zero"
  begin script
    [ ]
  end script
  expect_exit_code !=0
end test "[ ] with no arguments returns non-zero"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
begin test "[ hello ] returns 0"
  begin script
    [ hello ]
  end script
  expect_exit_code 0
end test "[ hello ] returns 0"

# ==============================================================================
# pwd utility
# ==============================================================================

requirement "SHALL-DESCRIPTION-5053" doc="The pwd utility shall write to standard output an absolute pathname of the current working directory, which does not contain the filenames dot or dot-dot."
requirement "SHALL-OPTIONS-5054" doc="The pwd utility shall conform to XBD 12.2 Utility Syntax Guidelines ."

begin test "pwd after cd / writes /"
  begin script
    cd / && pwd
  end script
  expect_stdout "/"
end test "pwd after cd / writes /"

requirement "SHALL-OPTIONS-5057" doc="The -P option shall cause the pathname written to standard output to not contain any components that refer to files of type symbolic link."

begin test "pwd -P returns non-empty path"
  begin script
    pwd -P | grep -q . && echo "ok"
  end script
  expect_stdout "ok"
end test "pwd -P returns non-empty path"

requirement "SHALL-OPTIONS-5060" doc="If both -L and -P are specified, the last one shall apply."

begin test "pwd -L -P succeeds"
  begin script
    pwd -L -P >/dev/null
  end script
  expect_exit_code 0
end test "pwd -L -P succeeds"

requirement "SHALL-OPTIONS-5061" doc="If neither -L nor -P is specified, the pwd utility shall behave as if -L had been specified."

begin test "pwd default matches pwd -L"
  begin script
    cd / && default=$(pwd) && l=$(pwd -L) && [ "$default" = "$l" ] && echo "match"
  end script
  expect_stdout "match"
end test "pwd default matches pwd -L"

# ==============================================================================
# printf utility
# ==============================================================================

requirement "SHALL-DESCRIPTION-5020" doc="The printf utility shall write formatted operands to the standard output."
requirement "SHALL-DESCRIPTION-5021" doc="The argument operands shall be formatted under control of the format operand."

begin test "printf with %s format"
  begin script
    printf "%s %s
    " hello world
  end script
  expect_stdout "hello world"
end test "printf with %s format"

requirement "SHALL-EXTENDED-DESCRIPTION-5043" doc="The format operand shall be reused as often as necessary to satisfy the argument operands."

begin test "printf reuses format for multiple arguments"
  begin script
    printf "%s
    " a b c
  end script
  expect_stdout "a\nb\nc"
end test "printf reuses format for multiple arguments"

requirement "SHALL-EXTENDED-DESCRIPTION-5047" doc="The argument operands shall be treated as strings if the corresponding conversion specifier is b , c , or s , and shall be evaluated as if by the strtod () function if the corresponding conversion specifier is a , A , e , E , f , F , g , or G ."

begin test "printf %s treats argument as string"
  begin script
    printf "%s
    " test
  end script
  expect_stdout "test"
end test "printf %s treats argument as string"

requirement "SHALL-EXTENDED-DESCRIPTION-5048" doc="Otherwise, they shall be evaluated as unsuffixed C integer constants, as described by the ISO C standard, with the following extensions: A leading <plus-sign> or <hyphen-minus> shall be allowed."

begin test "printf %d treats argument as integer"
  begin script
    printf "%d
    " 42
  end script
  expect_stdout "42"
end test "printf %d treats argument as integer"

requirement "SHALL-EXTENDED-DESCRIPTION-5049" doc="If the leading character is a single-quote or double-quote, the value shall be the numeric value in the underlying codeset of the character following the single-quote or double-quote."

begin test "printf %d with leading quote gives character value"
  begin script
    printf "%d
    " "'A"
  end script
  expect_stdout "65"
end test "printf %d with leading quote gives character value"
