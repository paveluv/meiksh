testsuite "Locale"

# ==============================================================================
# XBD 8: Locale environment variables — LANG, LC_ALL, LC_* precedence
# ==============================================================================

requirement "SHALL-XBD-8-3000" doc="LANG determines locale in the absence of LC_ALL and other LC_* variables"

begin test "LANG sets locale when LC_ALL and LC_* are unset"
  setenv "LANG" "test_EPTY.UTF-8"
  setenv "LC_ALL" ""
  begin script
    case "é" in
      [[:alpha:]]) echo "alpha_match";;
      *) echo "alpha_nomatch";;
    esac
  end script
  expect_stdout "alpha_match"
end test "LANG sets locale when LC_ALL and LC_* are unset"

requirement "SHALL-XBD-8-3002" doc="LC_ALL determines the values for all locale categories"

begin test "LC_ALL overrides LANG"
  setenv "LANG" "test_EPTY.UTF-8"
  setenv "LC_ALL" "C"
  begin script
    case "é" in
      [[:alpha:]]) echo "alpha_match";;
      *) echo "alpha_nomatch";;
    esac
  end script
  expect_stdout "alpha_nomatch"
end test "LC_ALL overrides LANG"

requirement "SHALL-XBD-8-3003" doc="LC_COLLATE determines locale for character collation"

begin test "LC_COLLATE affects collation order"
  setenv "LC_ALL" ""
  setenv "LANG" "C"
  setenv "LC_COLLATE" "test_EPTY.UTF-8"
  setenv "LC_CTYPE" "test_EPTY.UTF-8"
  begin script
    case "b" in
      [a-z]) echo "range_match";;
      *) echo "range_nomatch";;
    esac
  end script
  expect_stdout "range_match"
end test "LC_COLLATE affects collation order"

requirement "SHALL-XBD-8-3004" doc="LC_CTYPE determines locale for character handling functions"

begin test "LC_CTYPE affects character classification"
  setenv "LC_ALL" ""
  setenv "LANG" "C"
  setenv "LC_CTYPE" "test_EPTY.UTF-8"
  begin script
    case "é" in
      [[:alpha:]]) echo "alpha_match";;
      *) echo "alpha_nomatch";;
    esac
  end script
  expect_stdout "alpha_match"
end test "LC_CTYPE affects character classification"

requirement "SHALL-XBD-8-3005" doc="LC_MESSAGES determines locale for affirmative/negative responses"

begin test "LC_MESSAGES affects message processing"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    locale | grep LC_MESSAGES
  end script
  expect_stdout "LC_MESSAGES=.*test_EPTY.UTF-8.*"
end test "LC_MESSAGES affects message processing"

requirement "SHALL-XBD-8-3007" doc="If LC_ALL is defined and not null, its value shall be used"

begin test "LC_ALL overrides all LC_* variables"
  setenv "LANG" "C"
  setenv "LC_CTYPE" "C"
  setenv "LC_COLLATE" "C"
  setenv "LC_MESSAGES" "C"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    case "é" in
      [[:alpha:]]) echo "alpha_match";;
      *) echo "alpha_nomatch";;
    esac
  end script
  expect_stdout "alpha_match"
end test "LC_ALL overrides all LC_* variables"

requirement "SHALL-XBD-8-3008" doc="If LC_* is defined and not null, it shall be used for the corresponding category"

begin test "individual LC_* variables override LANG"
  setenv "LC_ALL" ""
  setenv "LANG" "C"
  setenv "LC_CTYPE" "test_EPTY.UTF-8"
  begin script
    case "é" in
      [[:alpha:]]) echo "alpha_match";;
      *) echo "alpha_nomatch";;
    esac
  end script
  expect_stdout "alpha_match"
end test "individual LC_* variables override LANG"

requirement "SHALL-XBD-8-3009" doc="If LANG is defined and not null, its value shall be used"

begin test "LANG provides fallback locale"
  setenv "LC_ALL" ""
  setenv "LANG" "test_EPTY.UTF-8"
  begin script
    case "é" in
      [[:alpha:]]) echo "alpha_match";;
      *) echo "alpha_nomatch";;
    esac
  end script
  expect_stdout "alpha_match"
end test "LANG provides fallback locale"

# ==============================================================================
# XBD 8: LANGUAGE variable
# ==============================================================================

requirement "SHALL-XBD-8-3001" doc="LANGUAGE examined for gettext message object lookup"

begin test "LANGUAGE variable is recognized"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  setenv "LANGUAGE" "en"
  begin script
    env | grep LANGUAGE
  end script
  expect_stdout_line "LANGUAGE=en"
end test "LANGUAGE variable is recognized"

# ==============================================================================
# Builtin locale boilerplate — builtins respect locale environment variables
# ==============================================================================

requirement "SHALL-ALIAS-1025" doc="Locale environment variables affect alias execution"

begin test "alias respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    alias foo=bar
    alias foo
  end script
  expect_stdout ".*foo=.*bar.*"
end test "alias respects locale env vars"

requirement "SHALL-COMMAND-1028" doc="Locale environment variables affect command execution"

begin test "command respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    command echo "hello"
  end script
  expect_stdout "hello"
end test "command respects locale env vars"

requirement "SHALL-GETOPTS-1036" doc="Locale environment variables affect getopts execution"

begin test "getopts respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    set -- -a value
    getopts a: opt
    echo "$opt $OPTARG"
  end script
  expect_stdout "a value"
end test "getopts respects locale env vars"

requirement "SHALL-HASH-1037" doc="Locale environment variables affect hash execution"

begin test "hash respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    hash -r
    echo "ok"
  end script
  expect_stdout "ok"
end test "hash respects locale env vars"

requirement "SHALL-JOBS-1038" doc="Locale environment variables affect jobs execution"

begin interactive test "jobs respects locale env vars"
  spawn -i
  expect "$ "
  send "export LC_ALL=test_EPTY.UTF-8"
  expect "$ "
  send "jobs"
  expect "$ "
  send "echo ok"
  expect "ok"
  expect "$ "
  sendeof
  wait
end interactive test "jobs respects locale env vars"

requirement "SHALL-KILL-1040" doc="Locale environment variables affect kill execution"

begin test "kill respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    kill -l 1
  end script
  expect_stdout ".*HUP.*"
end test "kill respects locale env vars"

requirement "SHALL-TYPE-1042" doc="Locale environment variables affect type execution"

begin test "type respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    type echo
  end script
  expect_stdout ".*echo.*"
end test "type respects locale env vars"

requirement "SHALL-ULIMIT-1043" doc="Locale environment variables affect ulimit execution"

begin test "ulimit respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    ulimit -f
  end script
  expect_stdout_line "[0-9]+|unlimited"
end test "ulimit respects locale env vars"

requirement "SHALL-UMASK-1045" doc="Locale environment variables affect umask execution"

begin test "umask respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    umask
  end script
  expect_stdout_line "[0-7][0-7][0-7][0-7]"
end test "umask respects locale env vars"

requirement "SHALL-UNALIAS-1046" doc="Locale environment variables affect unalias execution"

begin test "unalias respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    alias tmptest=echo
    unalias tmptest
    echo "ok"
  end script
  expect_stdout "ok"
end test "unalias respects locale env vars"

requirement "SHALL-WAIT-1047" doc="Locale environment variables affect wait execution"

begin test "wait respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    wait
    echo "ok"
  end script
  expect_stdout "ok"
end test "wait respects locale env vars"

requirement "SHALL-BG-1027" doc="Locale environment variables affect bg execution"
requirement "SHALL-BG-1030" doc="Locale environment variables affect bg execution (XCU)"

begin interactive test "bg respects locale env vars"
  spawn -i
  expect "$ "
  send "export LC_ALL=test_EPTY.UTF-8"
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 100 &"
  expect "$ "
  send "echo ok"
  expect "ok"
  expect "$ "
  send "kill %1"
  expect "$ "
  sendeof
  wait
end interactive test "bg respects locale env vars"

requirement "SHALL-FG-1034" doc="Locale environment variables affect fg execution"
requirement "SHALL-FG-1048" doc="Locale environment variables affect fg execution (XCU)"

begin interactive test "fg respects locale env vars"
  spawn -i
  expect "$ "
  send "export LC_ALL=test_EPTY.UTF-8"
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 0.1 &"
  expect "$ "
  sleep 200ms
  send "fg"
  expect "$ "
  send "echo ok"
  expect "ok"
  expect "$ "
  sendeof
  wait
end interactive test "fg respects locale env vars"

requirement "SHALL-ENVIRONMENT-VARIABLES-5005" doc="Locale environment variables affect echo execution"

begin test "echo respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    echo "hello world"
  end script
  expect_stdout "hello world"
end test "echo respects locale env vars"

requirement "SHALL-ENVIRONMENT-VARIABLES-5023" doc="Locale environment variables affect printf execution"

begin test "printf respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    printf "%s\n" "test"
  end script
  expect_stdout "test"
end test "printf respects locale env vars"

requirement "SHALL-ENVIRONMENT-VARIABLES-5024" doc="LC_NUMERIC affects printf numeric formatting"

begin test "printf numeric formatting with LC_NUMERIC"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    printf '%f\n' 1234.5
  end script
  expect_stdout_line "[0-9]+[.,][0-9]+"
end test "printf numeric formatting with LC_NUMERIC"

requirement "SHALL-ENVIRONMENT-VARIABLES-5062" doc="Locale environment variables affect pwd execution"

begin test "pwd respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    pwd
  end script
  expect_stdout "/.*"
end test "pwd respects locale env vars"

requirement "SHALL-ENVIRONMENT-VARIABLES-5074" doc="Locale environment variables affect test execution"

begin test "test respects locale env vars"
  setenv "LC_ALL" "test_EPTY.UTF-8"
  begin script
    test -n "hello" && echo "ok"
  end script
  expect_stdout "ok"
end test "test respects locale env vars"
