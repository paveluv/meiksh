testsuite "Special Built-ins (shift, times, trap)"

# ==============================================================================
# The 'shift' Utility
# ==============================================================================


requirement "SHALL-DESCRIPTION-621" doc="If n is not given, it shall be assumed to be 1."
requirement "SHALL-OPTIONS-005" doc="The option letters derived from the set special built-in shall also be accepted with a leading <plus-sign> ( '+' ) instead of a leading <hyphen-minus> (meaning the reverse case of the option as described in this volume of POSIX.1-2024)."
requirement "SHALL-DESCRIPTION-603" doc="This option shall be supported if the system supports the User Portability Utilities option."
begin test "shift 1 without arguments shifts $2 to $1"
  begin script
    set -- a b c
    echo $#
    shift
    echo "$1 $#"
  end script
  expect_stdout "3\nb 2"
end test "shift 1 without arguments shifts $2 to $1"

requirement "SHALL-DESCRIPTION-605" doc="Enabling vi mode shall disable any other command line editing mode provided as an implementation extension."
begin test "shift 2 shifts $3 to $1"
  begin script
    set -- a b c
    echo $#
    shift 2
    echo "$1 $#"
  end script
  expect_stdout "3\nc 1"
end test "shift 2 shifts $3 to $1"

requirement "SHALL-DESCRIPTION-516" doc="If n is greater than the number of enclosing loops, the outermost enclosing loop shall be exited."
begin test "shift greater than $# fails and leaves parameters intact"
  begin script
    set -- a b c
    shift 5 2>/dev/null
    echo "$? $1"
  end script
  expect_stdout ".*[1-9].* a"
end test "shift greater than $# fails and leaves parameters intact"

requirement "SHALL-DESCRIPTION-626" doc="The four pairs of times shall correspond to the members of the <sys/times.h> tms structure (defined in XBD 14."
requirement "SHALL-DESCRIPTION-644" doc="The format shall be: command1 [ || command2 ] ..."
begin test "times produces output with time format"
  begin script
    times 2>/dev/null
  end script
  expect_stdout ".*m.*s.*\n.*m.*s.*"
end test "times produces output with time format"

requirement "SHALL-DESCRIPTION-629" doc="If the -p option is not specified and the first operand is an unsigned decimal integer, the shell shall treat all operands as conditions, and shall reset each condition to the default value."
requirement "SHALL-DESCRIPTION-647" doc="The trap special built-in shall conform to XBD 12.2 Utility Syntax Guidelines ."
begin test "trap with signal number resets to default"
  begin script
    trap "echo trapped" INT
    trap 2
    trap -p INT | grep -c 'echo trapped' || true
  end script
  expect_stdout "0"
end test "trap with signal number resets to default"

requirement "SHALL-DESCRIPTION-633" doc="Otherwise, the argument action shall be read and executed by the shell when one of the corresponding conditions arises."
requirement "SHALL-DESCRIPTION-635" doc="The value of \"$?\" after the trap action completes shall be the value it had before the trap action was executed."
begin test "trap action executed on signal"
  begin script
    trap "echo GOT_USR1" USR1
    kill -USR1 $$
    echo done
  end script
  expect_stdout "GOT_USR1\ndone"
end test "trap action executed on signal"

requirement "SHALL-DESCRIPTION-631" doc="If action is '-' , the shell shall reset each condition to the default value."
begin test "trap - resets trap to default"
  begin script
    trap "echo x" EXIT
    trap - EXIT
    echo done
  end script
  expect_stdout "done"
end test "trap - resets trap to default"

requirement "SHALL-DESCRIPTION-631" doc="If action is '-' , the shell shall reset each condition to the default value."
requirement "SHALL-DESCRIPTION-632" doc="If action is null ( \"\" ), the shell shall ignore each specified condition if it arises."
requirement "SHALL-DESCRIPTION-636" doc="The EXIT condition shall occur when the shell terminates normally (exits), and may occur when the shell terminates abnormally as a result of delivery of a signal (other than SIGKILL) whose trap action is the default."
begin test "trap with empty action ignores condition"
  begin script
    trap "" EXIT
    echo "running"
  end script
  expect_stdout "running"
end test "trap with empty action ignores condition"

requirement "SHALL-DESCRIPTION-637" doc="The environment in which the shell executes a trap action on EXIT shall be identical to the environment immediately after the last command executed before the trap action on EXIT was executed."
begin test "trap action fires on EXIT"
  begin script
    trap "echo exit_action" EXIT
    echo "main"
  end script
  expect_stdout "main\nexit_action"
end test "trap action fires on EXIT"

requirement "SHALL-DESCRIPTION-630" doc="Otherwise, if the -p option is not specified and there are operands, the first operand shall be treated as an action and the remaining as conditions."
requirement "SHALL-DESCRIPTION-634" doc="The action of trap shall override a previous action (either default action or one explicitly set)."
begin test "trap overrides previous action"
  begin script
    trap "echo first" EXIT
    trap "echo second" EXIT
    true
  end script
  expect_stdout "second"
end test "trap overrides previous action"

requirement "SHALL-DESCRIPTION-620" doc="The value n shall be an unsigned decimal integer less than or equal to the value of the special parameter '#' ."
begin test "trap preserves $? value"
  begin script
    trap 'echo qval=$?' EXIT
    false
  end script
  expect_stdout "qval=[1-9][0-9]*"
end test "trap preserves $? value"

requirement "SHALL-DESCRIPTION-555" doc="If n is not specified, the result shall be as if n were specified with the current value of the special parameter '?' (see 2.5.2 Special Parameters ), except that if the exit command would cause the end of execution of a trap action, the value for the special parameter '?' that is considered \"current\" shall be the value it had immediately preceding the trap action."
begin test "EXIT trap fires on normal exit"
  begin script
    trap "echo exit_trap" EXIT
    exit 0
  end script
  expect_stdout "exit_trap"
end test "EXIT trap fires on normal exit"

requirement "SHALL-DESCRIPTION-549" doc="The exit utility shall cause the shell to exit from its current execution environment."
begin test "EXIT trap sees latest environment"
  begin script
    MYVAL=hello
    trap 'echo $MYVAL' EXIT
    MYVAL=world
  end script
  expect_stdout "world"
end test "EXIT trap sees latest environment"

requirement "SHALL-DESCRIPTION-643" doc="Otherwise, the list shall contain the commands currently associated with each condition."
begin test "trap persists across commands"
  begin script
    trap "echo still_set" EXIT
    echo "first_command"
    echo "second_command"
  end script
  expect_stdout "first_command\nsecond_command\nstill_set"
end test "trap persists across commands"

requirement "SHALL-DESCRIPTION-640" doc="When a subshell is entered, traps that are not being ignored shall be set to the default actions, except in the case of a command substitution containing only a single trap command, when the traps need not be altered."
begin test "subshell resets traps to default"
  begin script
    trap "echo parent_trap" USR1
    (trap "echo child_trap" USR1; trap -p USR1)
  end script
  expect_stdout "trap -- .*child_trap.* USR1"
end test "subshell resets traps to default"

requirement "SHALL-DESCRIPTION-639" doc="Traps shall remain in place for a given shell until explicitly changed with another trap command."
begin test "trap with no args lists active traps"
  begin script
    trap "echo hi" INT
    trap
  end script
  expect_stdout "trap -- .*echo hi.* INT"
end test "trap with no args lists active traps"

requirement "SHALL-DESCRIPTION-645" doc="The shell shall format the output, including the proper use of quoting, so that it is suitable for reinput to the shell as commands that achieve the same trapping results for the set of conditions included in the output, except for signals that were ignored on entry to the shell as described above."
requirement "SHALL-DESCRIPTION-646" doc="If this set includes conditions corresponding to the SIGKILL and SIGSTOP signals, the shell shall accept them when the output is reinput to the shell (where accepting them means they do not cause a non-zero exit status, a diagnostic message, or undefined behavior)."
requirement "SHALL-OPTIONS-649" doc="The shell shall format the output, including the proper use of quoting, so that it is suitable for reinput to the shell as commands that achieve the same trapping results for the specified set of conditions."
begin test "trap output is suitable for reinput"
  begin script
    trap "echo reinput_trap" EXIT
    _saved=$(trap -p EXIT)
    trap - EXIT
    eval "$_saved"
    true
  end script
  expect_stdout "reinput_trap"
end test "trap output is suitable for reinput"

requirement "SHALL-DESCRIPTION-610" doc="The default for all these options shall be off (unset) unless stated otherwise in the description of the option or unless the shell was invoked with them on; see sh ."
begin test "options default to off (-e is off)"
  begin script
    false
    echo "survived"
  end script
  expect_stdout "survived"
end test "options default to off (-e is off)"

requirement "SHALL-DESCRIPTION-641" doc="The trap command with no operands shall write to standard output a list of commands associated with each of a set of conditions; if the -p option is not specified, this set shall contain only the conditions that are not in the default state (including signals that were ignored on entry to a non-interactive shell); if the -p option is specified, the set shall contain all conditions, except that it is unspecified whether conditions corresponding to the SIGKILL and SIGSTOP signals are included in the set."
requirement "SHALL-DESCRIPTION-642" doc="If the command is executed in a subshell, the implementation does not perform the optional check described above for a command substitution containing only a single trap command, and no trap commands with operands have been executed since entry to the subshell, the list shall contain the commands that were associated with each condition immediately before the subshell environment was entered."
begin test "subshell inherits trap list before entry"
  begin script
    trap "echo exit_trap" 0
    ( trap )
  end script
  expect_stdout "trap -- .*exit_trap.* (EXIT|0)\nexit_trap"
end test "subshell inherits trap list before entry"

requirement "SHALL-DESCRIPTION-617" doc="The positional parameters shall be shifted."
requirement "SHALL-DESCRIPTION-619" doc="The parameters represented by the numbers \"$#\" down to \"$#-n+1\" shall be unset, and the parameter '#' is updated to reflect the new number of positional parameters."
requirement "SHALL-DESCRIPTION-614" doc="The command set -- without argument shall unset all positional parameters and set the special parameter '#' to zero."
begin test "set -- without arguments unsets all positional parameters"
  begin script
    set -- a b c
    set --
    echo $#
  end script
  expect_stdout "0"
end test "set -- without arguments unsets all positional parameters"
