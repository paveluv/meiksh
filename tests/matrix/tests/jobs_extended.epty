testsuite "Jobs (Extended)"

# ==============================================================================
# jobs -l — long format with PIDs
# ==============================================================================

requirement "SHALL-JOBS-1057" doc="The following options shall be supported: -l (The letter ell.) Provide more information about each job listed."
requirement "SHALL-JOBS-1235" doc="If the -l option is specified: For job-control background jobs, a field containing the process group ID shall be inserted before the < state > field."
requirement "SHALL-JOBS-1223" doc="The jobs utility shall conform to XBD 12.2 Utility Syntax Guidelines ."

begin interactive test "jobs -l shows long listing"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "jobs -l"
  expect "\[[[:digit:]]+\].*sleep 60"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs -l shows long listing"

requirement "SHALL-JOBS-1060" doc="If the -p option is specified, the output shall consist of one line for each process ID: \"%d\\n\", <process ID>."
begin interactive test "jobs -l shows numeric PID"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "jobs -l | grep -E \"[0-9]+\" && echo pid_ok"
  expect "pid_ok"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs -l shows numeric PID"


# ==============================================================================
# jobs -p — PIDs only
# ==============================================================================

requirement "SHALL-JOBS-1060" doc="If the -p option is specified, the output shall consist of one line for each process ID: \"%d\\n\", <process ID>."
requirement "SHALL-JOBS-1221" doc="If the current shell execution environment (see 2.13 Shell Execution Environment ) is not a subshell environment, the jobs utility shall display the status of background jobs that were created in the current shell execution environment; it may also do so if the current shell execution environment is a subshell environment."

begin interactive test "jobs -p returns PID"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "JPID=$(jobs -p); echo pid_is_$JPID"
  expect "pid_is_"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs -p returns PID"

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "jobs -p output is numeric"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "jobs -p | grep -qE \"^[0-9]+$\" && echo numeric_ok"
  expect "numeric_ok"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs -p output is numeric"


# ==============================================================================
# Job state display: Running
# ==============================================================================

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."

begin interactive test "running job shows Running state"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "jobs"
  expect "\[[[:digit:]]+\].*Running.*sleep 60"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "running job shows Running state"


# ==============================================================================
# Job state display: Done
# ==============================================================================

requirement "SHALL-JOBS-1222" doc="When jobs reports the termination status of a job, the shell shall remove the job from the background jobs list and the associated process ID from the list of those \"known in the current shell execution environment\"; see 2.9.3.1 Asynchronous AND-OR Lists ."

begin interactive test "completed job shows Done state"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 0.1 &"
  sleep 500ms
  send "jobs"
  expect "\[[[:digit:]]+\].*Done.*sleep"
  expect "$ "
  sendeof
  wait
end interactive test "completed job shows Done state"


# ==============================================================================
# Job state display: Stopped / Suspended
# ==============================================================================

requirement "SHALL-JOBS-1232" doc="If there is any suspended job, then the current job shall be a suspended job."
requirement "SHALL-JOBS-1237" doc="The implementation may substitute the string Suspended in place of Stopped."

begin interactive test "stopped job shows Stopped or Suspended state"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended).*sleep 60"
  send "jobs"
  expect "\[[[:digit:]]+\].*(Stopped|Suspended).*sleep 60"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "stopped job shows Stopped or Suspended state"


# ==============================================================================
# Output format: job number, status, command
# ==============================================================================

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "output format includes job number status command"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "jobs"
  expect "\[1\].*Running.*sleep 60"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "output format includes job number status command"


# ==============================================================================
# jobs with job_id operand
# ==============================================================================

requirement "SHALL-JOBS-1058" doc="The following operand shall be supported: job_id Specifies the jobs for which the status is to be displayed."
requirement "SHALL-JOBS-1061" doc="The following exit values shall be returned: 0 The output specified in STDOUT was successfully written to standard output."

begin interactive test "jobs with job_id shows only that job"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "sleep 61 &"
  expect "$ "
  send "jobs %1 | grep -c 'sleep 61' || true; echo end_jobs_check"
  expect "0"
  expect "end_jobs_check"
  expect "$ "
  send "kill %1 %2; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs with job_id shows only that job"


# ==============================================================================
# jobs with no args lists all jobs
# ==============================================================================

requirement "SHALL-JOBS-1225" doc="By default, the jobs utility shall display the status of all background jobs, both running and suspended, and all jobs whose status has changed and have not been reported by the shell."
requirement "SHALL-JOBS-1227" doc="If no job_id is given, the status information for all jobs shall be displayed."

begin interactive test "jobs with no args lists all jobs"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "sleep 61 &"
  expect "$ "
  send "jobs"
  expect "sleep 60"
  expect "sleep 61"
  send "kill %1 %2; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs with no args lists all jobs"


# ==============================================================================
# jobs -l with stopped job shows PID and state
# ==============================================================================

requirement "SHALL-JOBS-1236" doc="For non-job-control background jobs (if supported), a field containing the process ID associated with the job shall be inserted before the < state > field."

begin interactive test "jobs -l with stopped job shows PID and state"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60"
  sleep 500ms
  sendraw 1a
  expect "(Stopped|Suspended).*sleep 60"
  send "jobs -l"
  expect "\[[[:digit:]]+\].*(Stopped|Suspended).*sleep 60"
  send "kill %1; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs -l with stopped job shows PID and state"


# ==============================================================================
# jobs: current job marker (+)
# ==============================================================================

requirement "SHALL-JOBS-1233" doc="If there are at least two suspended jobs, then the previous job also shall be a suspended job."

begin interactive test "current job marker +"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "sleep 61 &"
  expect "$ "
  send "jobs"
  expect "\[[[:digit:]]+\]\+.*sleep"
  send "kill %1 %2; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "current job marker +"


# ==============================================================================
# jobs: previous job marker (-)
# ==============================================================================

requirement "SHALL-JOBS-1234" doc="If the job was terminated by a signal, the format of < state > is unspecified, but it shall be visibly distinct from all of the other < state > formats shown here and shall indicate the name or description of the signal causing the termination."

begin interactive test "previous job marker -"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "sleep 61 &"
  expect "$ "
  send "jobs"
  expect "\[[[:digit:]]+\]-.*sleep"
  send "kill %1 %2; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "previous job marker -"


# ==============================================================================
# jobs with no background jobs produces no output
# ==============================================================================

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "jobs with no background jobs produces no output"
  spawn -i
  expect "$ "
  send "jobs | wc -l | tr -d ' '; echo end_of_jobs"
  expect "0"
  expect "end_of_jobs"
  sendeof
  wait
end interactive test "jobs with no background jobs produces no output"


# ==============================================================================
# Signal-terminated job state
# ==============================================================================

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "signal-terminated job no longer Running"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill -KILL %1"
  sleep 500ms
  send "jobs | grep -c Running || true; echo end_run_check"
  expect "0"
  expect "end_run_check"
  expect "$ "
  send "wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "signal-terminated job no longer Running"


# ==============================================================================
# Done(N) for non-zero exit
# ==============================================================================

requirement "SHALL-JOBS-1039" doc="Otherwise, if the -l option is not specified, the output shall be a series of lines of the form: \"[%d] %c %s %s\\n\", < job-number >, < current >, < state >, < command > where the fields shall be as follows: < current > The character '+' identifies the job that would be used as a default for the fg or bg utilities; this job can also be specified using the job_id %+ or \"%%\" . The character '-' identifies the job that would become the default if the current default job were to exit; this job can also be specified using the job_id %- . For other jobs, this field is a <space>. At most one job can be identified with '+' and at most one job can be identified with '-'. < job-number > A number that can be used to identify the job to the wait, fg, bg, and kill utilities. Using these utilities, the job can be identified by prefixing the job number with '%'. < state > One of the following strings (in the POSIX locale): Running (job has not been suspended by a signal and has not exited), Done (job completed and returned exit status zero), Done(code) (job completed normally with non-zero exit status), Stopped (job was suspended by the SIGTSTP signal), Stopped (SIGTSTP), Stopped (SIGSTOP), Stopped (SIGTTIN), Stopped (SIGTTOU). The implementation may substitute the string Suspended in place of Stopped. < command > The associated command that was given to the shell."
begin interactive test "Done(N) for non-zero exit"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "(exit 2) &"
  sleep 500ms
  send ""
  expect "Done\([[:digit:]]+\)"
  expect "$ "
  sendeof
  wait
end interactive test "Done(N) for non-zero exit"


# ==============================================================================
# jobs -p with multiple jobs
# ==============================================================================

requirement "SHALL-V3CHAP02-1016" doc="When job control is enabled, the shell shall create one or more jobs when it executes a list (see 2.9.3 Lists ) that has one of the following forms: A single asynchronous AND-OR list One or more sequentially executed AND-OR lists followed by at most one asynchronous AND-OR list For the purposes of job control, a list that includes more than one asynchronous AND-OR list shall be treated as if it were split into multiple separate lists, each ending with an asynchronous AND-OR list."
begin interactive test "jobs -p with multiple jobs"
  spawn -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "sleep 61 &"
  expect "$ "
  send "jobs -p"
  expect "[[:digit:]]+"
  expect "[[:digit:]]+"
  send "kill %1 %2; wait 2>/dev/null"
  expect "$ "
  sendeof
  wait
end interactive test "jobs -p with multiple jobs"
