testsuite "The set Utility and Shell Options"

# ==============================================================================
# The 'set' Utility Formatting
# ==============================================================================

requirement "SHALL-V3CHAP02-1019" doc="Each name shall start on a separate line, using the format: name=value. The value string shall be written with appropriate quoting."
requirement "SHALL-DESCRIPTION-585" doc="The set special built-in shall support XBD 12.2 Utility Syntax Guidelines except that options can be specified with either a leading hyphen-minus or plus-sign."
requirement "SHALL-DESCRIPTION-582" doc="The value string shall be written with appropriate quoting."
requirement "SHALL-DESCRIPTION-583" doc="The output shall be suitable for reinput to the shell."
requirement "SHALL-DESCRIPTION-612" doc="The special parameter # shall be set to reflect the number of positional parameters."

begin test "set output is suitable for reinput with quoting"
  begin script
    my_weird_var="space and literal and \"quotes\""
    output=$(set | grep "^my_weird_var=")
    unset my_weird_var
    eval "$output"
    echo "$my_weird_var"
  end script
  expect_stdout "space and literal and ""quotes"""
end test "set output is suitable for reinput with quoting"

# ==============================================================================
# The '-a' Option (allexport)
# ==============================================================================

requirement "SHALL-DESCRIPTION-587" doc="When this option is on, whenever a value is assigned to a variable in the current shell execution environment, the export attribute shall be set for the variable."

begin test "set -a causes variables to be auto-exported"
  begin script
    set -a
    auto_exported="yes"
    env | grep -q "^auto_exported=yes$" && echo "exported"
  end script
  expect_stdout "exported"
end test "set -a causes variables to be auto-exported"

# ==============================================================================
# The '-b' Option (notify)
# ==============================================================================

requirement "SHALL-DESCRIPTION-588" doc="-b This option shall be supported if the implementation supports the User Portability Utilities option."
requirement "SHALL-DESCRIPTION-589" doc="When job control and -b are both enabled, the shell shall write asynchronous notifications of background job completions."
requirement "SHALL-DESCRIPTION-590" doc="When job control is disabled, the -b option shall have no effect."

begin test "set -b is accepted without error"
  begin script
    set -b; set +b
  end script
  expect_exit_code 0
end test "set -b is accepted without error"

# ==============================================================================
# The '-C' Option (noclobber)
# ==============================================================================

requirement "SHALL-DESCRIPTION-592" doc="-C Prevent existing regular files from being overwritten by the shell > redirection operator; the >| redirection operator shall override this noclobber option for an individual file."

begin test "noclobber prevents overwrite with >"
  begin script
    _f=${TMPDIR:-/tmp}/_noclobber_test_$$; echo original > $_f; set -C; echo overwritten > $_f 2>/dev/null; cat $_f; rm -f $_f
  end script
  expect_stdout_line ".*original.*"
end test "noclobber prevents overwrite with >"

begin test ">| overrides noclobber"
  begin script
    _f=${TMPDIR:-/tmp}/_noclobber_test2_$$; echo original > $_f; set -C; echo forced >| $_f; cat $_f; rm -f $_f
  end script
  expect_stdout_line ".*forced.*"
end test ">| overrides noclobber"

# ==============================================================================
# The '-e' Option (errexit)
# ==============================================================================

requirement "SHALL-DESCRIPTION-593" doc="-e When this option is on, when any command fails, the shell immediately shall exit."
requirement "SHALL-DESCRIPTION-594" doc="Only the failure of the pipeline itself shall be considered."
requirement "SHALL-DESCRIPTION-595" doc="The -e setting shall be ignored when executing the compound list following the while, until, if, or elif reserved word, a pipeline beginning with the ! reserved word, or any command of an AND-OR list other than the last."
requirement "SHALL-DESCRIPTION-596" doc="If the exit status of a compound command other than a subshell command was the result of a failure while -e was being ignored, then -e shall not apply."

begin test "errexit exits on command failure"
  begin script
    set -e
    echo "start"
    false
    echo "should not run"
  end script
  expect_stdout "start"
  not_expect_exit_code 0
end test "errexit exits on command failure"

begin test "errexit ignores failures in if/while/until and AND-OR lists"
  begin script
    set -e
    if false; then echo "no"; fi
    false || true
    true && false || true
    while false; do echo "no"; done
    echo "survived"
  end script
  expect_stdout "survived"
end test "errexit ignores failures in if/while/until and AND-OR lists"

begin test "errexit does not exit on ! pipeline"
  begin script
    set -e; ! false; echo "survived_not"
  end script
  expect_stdout "survived_not"
end test "errexit does not exit on ! pipeline"

begin test "errexit triggers on pipeline failure (last command)"
  begin script
    set -e; echo ok | false; echo should_not_appear
  end script
  not_expect_stdout_line ".*should_not_appear.*"
end test "errexit triggers on pipeline failure (last command)"

# ==============================================================================
# The '-f' Option (noglob)
# ==============================================================================

requirement "SHALL-DESCRIPTION-597" doc="-f The shell shall disable pathname expansion."

begin test "set -f disables pathname expansion"
  begin script
    set -f
    touch tmp_set_f.txt
    echo tmp_set_*.txt
  end script
  expect_stdout "tmp_set_\*.txt"
end test "set -f disables pathname expansion"

# ==============================================================================
# The '-m' Option (monitor/job control)
# ==============================================================================

requirement "SHALL-DESCRIPTION-598" doc="-m This option shall be supported if the implementation supports the User Portability Utilities option."
requirement "SHALL-DESCRIPTION-599" doc="When this option is enabled, the shell shall perform job control actions."
requirement "SHALL-DESCRIPTION-600" doc="This option shall be enabled by default for interactive shells."

begin test "set -m is accepted without error"
  begin script
    set -m 2>/dev/null; true
  end script
  expect_exit_code 0
end test "set -m is accepted without error"

# ==============================================================================
# The '-n' Option (noexec)
# ==============================================================================

requirement "SHALL-DESCRIPTION-601" doc="-n The shell shall read commands but not execute them; this can be used to check for shell script syntax errors."

begin test "set -n suppresses command execution"
  begin script
    set -n
    echo "should not run"
  end script
  expect_stdout ""
end test "set -n suppresses command execution"

# ==============================================================================
# The '-u' Option (nounset)
# ==============================================================================

requirement "SHALL-DESCRIPTION-607" doc="-u The shell shall write a message to standard error when it tries to expand a variable that is not set and immediately exit."

begin test "nounset exits on unset variable expansion"
  begin script
    set -u
    echo "start"
    echo "${this_var_is_definitely_unset}"
    echo "should not run"
  end script
  expect_stdout "start"
  not_expect_exit_code 0
end test "nounset exits on unset variable expansion"

begin test "nounset does not trigger on $@ and $*"
  begin script
    set -u
    for i in "$@"; do echo $i; done
    echo "survived"
  end script
  expect_stdout "survived"
end test "nounset does not trigger on $@ and $*"

# ==============================================================================
# The '-v' Option (verbose)
# ==============================================================================

requirement "SHALL-DESCRIPTION-608" doc="-v The shell shall write its input to standard error as it is read."

begin test "set -v echoes input to stderr"
  begin script
    set -v
    echo "testing_verbose"
  end script
  expect_stderr_line ".*echo.*testing_verbose.*"
end test "set -v echoes input to stderr"

# ==============================================================================
# The '-x' Option (xtrace)
# ==============================================================================

requirement "SHALL-DESCRIPTION-609" doc="-x The shell shall write to standard error a trace for each command after it expands the command and before it executes it."

begin test "set -x traces expanded commands to stderr"
  begin script
    set -x
    echo "testing_xtrace"
  end script
  expect_stderr_line ".*echo testing_xtrace.*"
end test "set -x traces expanded commands to stderr"

# ==============================================================================
# The '-o' Option
# ==============================================================================

requirement "SHALL-DESCRIPTION-591" doc="Asynchronous notification shall not be enabled by default."

begin test "set -o succeeds"
  begin script
    set -o 2>/dev/null; true
  end script
  expect_exit_code 0
end test "set -o succeeds"

# ==============================================================================
# set -- for positional parameters
# ==============================================================================

requirement "SHALL-DESCRIPTION-613" doc="All positional parameters shall be unset before any new values are assigned."
requirement "SHALL-DESCRIPTION-614" doc="set -- without argument shall unset all positional parameters and set # to zero."

begin test "set -- assigns positional parameters"
  begin script
    set -- a b c; echo "$# $1 $2 $3"
  end script
  expect_stdout "3 a b c"
end test "set -- assigns positional parameters"

begin test "set -- without args clears positional parameters"
  begin script
    set -- x y z; set --; echo "$#"
  end script
  expect_stdout "0"
end test "set -- without args clears positional parameters"
