testsuite "Consequences of Shell Errors"

# ==============================================================================
# Non-Interactive Shell Exits
# ==============================================================================

requirement "SHALL-2-8-1-233" doc="Certain errors shall cause the shell to write a diagnostic message to standard error and exit"
requirement "SHALL-2-8-1-230" doc="shall exit"
requirement "SHALL-2-8-1-232" doc="shall exit 1"
requirement "SHALL-2-8-1-236" doc="shall exit 4"
requirement "SHALL-2-8-1-244" doc="The shell shall exit only if the special built-in utility is executed directly"
requirement "SHALL-2-8-1-246" doc="If the exec command fails, a non-interactive shell shall exit from the current shell execution environment"
requirement "SHALL-2-8-1-249" doc="When this option is on, when any command fails the shell immediately shall exit, as if by executing the exit special built-in utility with no arguments"
requirement "SHALL-2-8-1-250" doc="If the command_string operand is an empty string, sh shall exit with a zero exit status"
requirement "SHALL-2-8-1-254" doc="If an unrecoverable read error occurs when reading commands, the shell shall execute no further commands other than any specified in a previously defined EXIT trap action"
requirement "SHALL-2-8-1-255" doc="An unrecoverable read error while reading from the file operand of the dot special built-in shall be treated as a special built-in utility error"

begin test "syntax error causes non-interactive shell to exit"
  begin script
    echo 'if true; echo "no_then"; fi; echo "survived"' > tmp_err1.sh; {{SHELL}} tmp_err1.sh 2>/dev/null
  end script
  not_expect_exit_code 0
end test "syntax error causes non-interactive shell to exit"

begin test "syntax error prevents further execution"
  begin script
    echo 'if true; echo "no_then"; fi; echo "survived"' > tmp_err1.sh; {{SHELL}} tmp_err1.sh 2>/dev/null
  end script
  expect_stdout ""
end test "syntax error prevents further execution"

begin test "readonly assignment before special built-in causes exit"
  begin script
    echo 'readonly RO_VAR=1; RO_VAR=2 export OTHER=3; echo "survived"' > tmp_err2.sh; {{SHELL}} tmp_err2.sh 2>/dev/null
  end script
  expect_stdout ""
end test "readonly assignment before special built-in causes exit"

begin test "invalid option on special built-in causes exit"
  begin script
    echo 'set -Z; echo "survived"' > tmp_err3.sh; {{SHELL}} tmp_err3.sh 2>/dev/null
  end script
  expect_stdout ""
end test "invalid option on special built-in causes exit"


# ==============================================================================
# Interactive Shells and The 'command' Utility
# ==============================================================================

requirement "SHALL-2-8-1-251" doc="The shell shall exit only if the special built-in utility is executed directly"
requirement "SHALL-2-8-1-252" doc="If it is executed via the command utility, the shell shall not exit"

begin test "command utility prevents exit on special built-in error"
  begin script
    echo 'command set -Z; echo "survived"' > tmp_err4.sh; {{SHELL}} tmp_err4.sh 2>/dev/null
  end script
  expect_stdout "survived"
end test "command utility prevents exit on special built-in error"


# ==============================================================================
# Subshell Environments
# ==============================================================================

requirement "SHALL-2-8-1-256" doc="If any of the errors shown as shall exit or may exit occur in a subshell environment, the shell shall exit from the subshell environment with a non-zero status and continue in the environment from which that subshell environment was invoked"

begin test "special built-in error in subshell only terminates subshell"
  begin script
    ( set -Z ) 2>/dev/null
    echo "parent survived"
  end script
  expect_stdout "parent survived"
end test "special built-in error in subshell only terminates subshell"


# ==============================================================================
# Non-Exiting Errors
# ==============================================================================

requirement "SHALL-2-8-2-259" doc="The exit status of a command shall be determined as follows"
requirement "SHALL-2-8-2-263" doc="Otherwise, the exit status shall be the value obtained by the equivalent of the WEXITSTATUS macro applied to the status obtained by the wait function"
requirement "SHALL-2-8-1-231" doc="shall not exit"
requirement "SHALL-2-8-1-234" doc="shall not exit"
requirement "SHALL-2-8-1-253" doc="The shell is not required to write a diagnostic message, but the utility itself shall write a diagnostic message if required to do so"
requirement "SHALL-2-8-1-257" doc="In all of the cases shown in the table where an interactive shell is required not to exit and a non-interactive shell is required to exit, an interactive shell shall not perform any further processing of the command in which the error occurred"

begin test "missing command does not cause shell to exit"
  begin script
    missing_command_123 2>/dev/null
    echo "survived missing command"
  end script
  expect_stdout "survived missing command"
end test "missing command does not cause shell to exit"
