testsuite "Job Control"

# ==============================================================================
# The Maestro: Managing Processes
# ==============================================================================

requirement "SHALL-2-11-435" doc="Job control allows users to selectively stop (suspend) the execution of processes"
requirement "SHALL-ASYNCHRONOUS-EVENTS-025" doc="The sh utility shall take the standard action for all signals with exceptions"
requirement "SHALL-2-11-425" doc="Shell shall initially set foreground process group ID to its own"
requirement "SHALL-2-11-427" doc="If it has a controlling terminal, it shall initially perform steps if interactive"
requirement "SHALL-2-11-428" doc="If process group is not foreground, shell shall stop itself or attempt read"
requirement "SHALL-2-11-429" doc="If stopped, when it continues it shall repeat these steps"
requirement "SHALL-2-11-430" doc="Shell shall change foreground process group when foreground job is running"
requirement "SHALL-2-11-448" doc="When job control is enabled, the shell shall create one or more jobs"
requirement "SHALL-2-11-432" doc="A list with more than one async AND-OR list treated as split into multiple lists"
requirement "SHALL-2-11-433" doc="Single async AND-OR list forms background job with process group leader"
requirement "SHALL-2-11-434" doc="Sequential AND-OR lists followed by async one form single foreground then background"
requirement "SHALL-2-11-435" doc="Processes in foreground pipeline share process group"
requirement "SHALL-2-11-436" doc="Background job can be brought to foreground by fg utility"
requirement "SHALL-2-11-437" doc="Stopped foreground process causes entire job to become suspended"
requirement "SHALL-2-11-439" doc="When foreground job created or brought to foreground, shell sets process group"
requirement "SHALL-2-11-440" doc="Foreground process group ID set when each pipeline in job is executed"
requirement "SHALL-2-11-441" doc="If all commands in pipeline executed by shell, foreground group set to shell's"
requirement "SHALL-2-11-442" doc="When foreground job terminates, shell sets foreground process group to shell's"
requirement "SHALL-2-11-443" doc="Each background job has associated job number and process ID"
requirement "SHALL-2-11-444" doc="When background job brought to foreground, job number removed from list"
requirement "SHALL-2-11-445" doc="If foreground process stopped by catchable signal, entire job becomes suspended"
requirement "SHALL-2-11-446" doc="Otherwise, shell creates suspended job from unspecified set including stopped pipeline"
requirement "SHALL-2-11-447" doc="Commands not completed and not in suspended job shall be discarded"
requirement "SHALL-2-11-448" doc="If foreground process stopped by SIGSTOP, behavior as for catchable signal"
requirement "SHALL-2-11-449" doc="Suspended job assigned job number and shell writes message"
requirement "SHALL-2-11-450" doc="Message may indicate completed commands which shall not be repeated on continue"
requirement "SHALL-2-11-451" doc="Interactive shell shall save terminal settings before changing them"
requirement "SHALL-2-11-453" doc="Background job stopped by signal, shell converts to suspended job"
requirement "SHALL-2-11-454" doc="If set -b disabled, message written prior to next prompt"
requirement "SHALL-ASYNCHRONOUS-EVENTS-026" doc="Interactive shell SIGINT during editing handled per EXTENDED DESCRIPTION"
requirement "SHALL-ASYNCHRONOUS-EVENTS-027" doc="Interactive shell: SIGQUIT and SIGTERM shall be ignored"
requirement "SHALL-ASYNCHRONOUS-EVENTS-028" doc="With -m, SIGTTIN SIGTTOU SIGTSTP shall be ignored"
requirement "SHALL-ASYNCHRONOUS-EVENTS-029" doc="If caught, signal-catching function sets default and re-raises"

begin test "background job and jobs listing"
  spawn {{SHELL}} -i
  expect "$ "
  send "sleep 10 &"
  expect "\[[[:digit:]]+\] [[:digit:]]+"
  expect "$ "
  send "jobs"
  expect "\[1\].*sleep 10"
  sendeof
  wait
end test "background job and jobs listing"


# ==============================================================================
# History maintained interactively
# ==============================================================================

requirement "SHALL-Command-History-List-031" doc="When used interactively, shell shall maintain command history in HISTFILE"

begin test "history maintained interactively"
  spawn {{SHELL}} -i
  expect "$ "
  send "echo histcheck_1"
  expect "histcheck_1"
  expect "$ "
  send "echo histcheck_2"
  expect "histcheck_2"
  expect "$ "
  send "fc -l -2 -1"
  expect "histcheck_1"
  expect "histcheck_2"
  sendeof
  wait
end test "history maintained interactively"


# ==============================================================================
# User must explicitly exit interactive shell
# ==============================================================================

requirement "SHALL-DESCRIPTION-602" doc="A user shall explicitly exit to leave the interactive shell"

begin test "user must explicitly exit interactive shell"
  spawn {{SHELL}} -i
  expect "$ "
  send "echo still_here"
  expect "still_here"
  expect "$ "
  send "exit"
  wait
end test "user must explicitly exit interactive shell"


# ==============================================================================
# fg/bg send SIGCONT to stopped job
# ==============================================================================

requirement "SHALL-2-11-455" doc="fg and bg shall send SIGCONT to stopped process group"
requirement "SHALL-2-11-456" doc="fg shall send SIGCONT after setting foreground process group"
requirement "SHALL-2-11-457" doc="fg shall restore terminal settings before sending SIGCONT"

begin test "fg/bg send SIGCONT to stopped job"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 60 &"
  expect "$ "
  send "kill -STOP %1"
  sleep 500ms
  expect "$ "
  send "fg %1"
  sleep 500ms
  send ""
  sleep 200ms
  send "kill %1"
  sleep 500ms
  sendeof
  wait
end test "fg/bg send SIGCONT to stopped job"


# ==============================================================================
# Background job completion notification
# ==============================================================================

requirement "SHALL-2-11-459" doc="When background job completes, interactive shell writes message to stderr"
requirement "SHALL-2-11-454" doc="If set -b disabled, message written prior to next prompt"

begin test "background job completion notification"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 0.1 &"
  expect "$ "
  sleep 500ms
  send "echo trigger_prompt"
  expect "\[[[:digit:]]+\].*Done.*sleep"
  sendeof
  wait
end test "background job completion notification"


# ==============================================================================
# Signal inheritance with job control disabled
# ==============================================================================

requirement "SHALL-2-12-461" doc="If job control disabled, async commands inherit SIG_IGN for SIGINT and SIGQUIT"

begin test "signal inheritance with job control disabled"
  run "trap \"\" INT; (trap) & wait"
  expect_exit_code 0
end test "signal inheritance with job control disabled"


# ==============================================================================
# Signal inheritance — default case
# ==============================================================================

requirement "SHALL-2-12-462" doc="Commands shall inherit same signal actions as those inherited by shell from parent"

begin test "exported variable inherited by child"
  run "MYVAR=hello; export MYVAR; {{SHELL}} -c 'echo $MYVAR'"
  expect_stdout "hello"
end test "exported variable inherited by child"


# ==============================================================================
# Trap deferred during foreground command
# ==============================================================================

requirement "SHALL-2-12-463" doc="Trap shall not execute until foreground command has completed"

begin test "trap deferred during foreground command"
  run "trap 'echo TRAP_FIRED' USR1; (sleep 0.1; kill -USR1 $$) & sleep 300ms; echo FOREGROUND_DONE"
  expect_stdout_line "FOREGROUND_DONE"
end test "trap deferred during foreground command"


# ==============================================================================
# wait interrupted by trapped signal
# ==============================================================================

requirement "SHALL-2-12-464" doc="When shell waiting via wait, trapped signal causes wait to return >128"

begin test "wait interrupted by trapped signal"
  run "trap 'echo GOT_USR1' USR1; sleep 60 & bgpid=$!; (sleep 0.1; kill -USR1 $$) & wait $bgpid; rc=$?; kill $bgpid 2>/dev/null; wait $bgpid 2>/dev/null; echo wait_rc=$rc"
  expect_stdout_line "GOT_USR1"
  expect_stdout_line "wait_rc=(129|1[3-9][0-9]|2[0-4][0-9]|25[0-5])"
end test "wait interrupted by trapped signal"


# ==============================================================================
# Utility execution environment
# ==============================================================================

requirement "SHALL-2-13-465" doc="Utilities other than special built-ins invoked in separate environment"
requirement "SHALL-2-13-466" doc="Initial value of objects same as parent shell except as noted"
requirement "SHALL-2-13-468" doc="Variables with export attribute passed as environment variables"

begin test "exported variable visible in child"
  run "MYVAR=hello; export MYVAR; {{SHELL}} -c 'echo $MYVAR'"
  expect_stdout "hello"
end test "exported variable visible in child"

begin test "non-exported variable not visible in child"
  run "MYVAR=secret; {{SHELL}} -c 'echo ${MYVAR:-empty}'"
  expect_stdout "empty"
end test "non-exported variable not visible in child"


# ==============================================================================
# Trap inheritance in shell scripts
# ==============================================================================

requirement "SHALL-2-13-467" doc="Shell script traps caught by parent set to default, ignored remain ignored"

begin test "trap inheritance in shell scripts"
  run "s=$TMPDIR/_trap_inherit_$$.sh; printf 'trap\n' > $s; chmod +x $s; trap 'echo caught' USR1; {{SHELL}} $s; rc=$?; rm -f $s; exit $rc"
  not_expect_stdout ".*USR1.*"
  not_expect_stdout ".*caught.*"
end test "trap inheritance in shell scripts"


# ==============================================================================
# Subshell environment
# ==============================================================================

requirement "SHALL-2-13-471" doc="Subshell environment duplicate of shell except traps set to default"
requirement "SHALL-2-13-472" doc="If interactive, subshell behaves as non-interactive"

begin test "subshell traps reset to default"
  run "trap \"echo parent_trap\" USR1; (trap) 2>/dev/null"
  not_expect_stdout ".*USR1.*"
end test "subshell traps reset to default"

begin test "subshell inherits variables"
  run "FOO=bar; ( echo $FOO )"
  expect_stdout "bar"
end test "subshell inherits variables"


# ==============================================================================
# Special built-in utilities
# ==============================================================================

requirement "SHALL-2-15-506" doc="Special built-in utilities shall be supported"

begin test "special built-in: break exists"
  run "command -v break >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: break exists"

begin test "special built-in: colon exists"
  run "command -v : >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: colon exists"

begin test "special built-in: continue exists"
  run "command -v continue >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: continue exists"

begin test "special built-in: dot exists"
  run "command -v . >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: dot exists"

begin test "special built-in: eval exists"
  run "command -v eval >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: eval exists"

begin test "special built-in: exec exists"
  run "command -v exec >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: exec exists"

begin test "special built-in: exit exists"
  run "command -v exit >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: exit exists"

begin test "special built-in: export exists"
  run "command -v export >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: export exists"

begin test "special built-in: readonly exists"
  run "command -v readonly >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: readonly exists"

begin test "special built-in: return exists"
  run "command -v return >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: return exists"

begin test "special built-in: set exists"
  run "command -v set >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: set exists"

begin test "special built-in: shift exists"
  run "command -v shift >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: shift exists"

begin test "special built-in: trap exists"
  run "command -v trap >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: trap exists"

begin test "special built-in: unset exists"
  run "command -v unset >/dev/null 2>&1 || true"
  expect_exit_code 0
end test "special built-in: unset exists"

requirement "SHALL-2-15-507" doc="Output of special built-in written to stdout, subject to redirection"

begin test "special built-in output goes to stdout"
  run "export FOO=bar; export -p > /dev/null; echo ok"
  expect_stdout "ok"
end test "special built-in output goes to stdout"

requirement "SHALL-2-15-508" doc="Error in special built-in may cause shell to abort"
requirement "SHALL-2-15-509" doc="If special built-in error does not abort, exit value non-zero"

begin test "error in special built-in produces non-zero exit"
  run "shift 999 2>/dev/null"
  not_expect_exit_code 0
end test "error in special built-in produces non-zero exit"

requirement "SHALL-2-15-510" doc="Variable assignments preceding special built-in affect current environment"

begin test "assignment before special built-in persists"
  run "FOO=bar eval 'echo $FOO'"
  expect_stdout "bar"
end test "assignment before special built-in persists"

begin test "variable persists after eval completes"
  run "FOO=bar eval true; echo $FOO"
  expect_stdout "bar"
end test "variable persists after eval completes"

requirement "SHALL-2-15-511" doc="For special built-ins not in syntax guidelines, -- need not be recognized"

begin test "set -- positional parameters"
  run "set -- a b c; echo count=$#"
  expect_stdout "count=3"
end test "set -- positional parameters"


# ==============================================================================
# set -b immediate background job notification
# ==============================================================================

requirement "SHALL-2-11-453" doc="If set -b enabled, message written immediately or prior to next prompt"

begin test "set -b immediate background job notification"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "set -b"
  expect "$ "
  send "sleep 0.1 &"
  expect "\[[[:digit:]]+\] [[:digit:]]+"
  sleep 1000ms
  expect "Done"
  send "echo setb_ok"
  expect "setb_ok"
  sendeof
  wait
end test "set -b immediate background job notification"


# ==============================================================================
# Multiple async commands in one list
# ==============================================================================

requirement "SHALL-2-11-432" doc="List with multiple async AND-OR lists treated as split into separate lists"

begin test "multiple async commands in one list"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -m"
  expect "$ "
  send "sleep 1 & sleep 2 & sleep 3 &"
  expect "\[1\]"
  expect "\[2\]"
  expect "\[3\]"
  expect "$ "
  send "kill %1 %2 %3 2>/dev/null; wait"
  expect "$ "
  sendeof
  wait
end test "multiple async commands in one list"
