testsuite "Quoting and Token Recognition"

# ==============================================================================
# Token Recognition
# ==============================================================================

requirement "SHALL-2-3-023" doc="The shell shall read its input in terms of lines."
requirement "SHALL-2-3-024" doc="These lines shall be parsed using two major modes: ordinary token recognition and processing of here-documents."
requirement "SHALL-2-3-025" doc="When an io_here token has been recognized by the grammar, one or more of the subsequent lines immediately following the next NEWLINE token form the body of a here-document."
requirement "SHALL-2-3-026" doc="Any non-NEWLINE tokens recognized while searching for the next NEWLINE token shall be saved for processing after the here-document has been parsed."
requirement "SHALL-2-3-027" doc="If a saved token is an io_here token, the corresponding here-document shall start on the line immediately following the line containing the trailing delimiter of the previous here-document."
requirement "SHALL-2-3-028" doc="When it is not processing an io_here, the shell shall break its input into tokens by applying the first applicable rule below to each character in turn."
requirement "SHALL-2-3-029" doc="At the start of input or after a previous token has just been delimited, the first or next token shall start with the first character not already included in a token."
requirement "SHALL-2-3-030" doc="Once a token has started, zero or more characters from the input shall be appended to the token until the end of the token is delimited."
requirement "SHALL-2-3-031" doc="When both the start and end of a token have been delimited, the characters forming the token shall be exactly those in the input between the two delimiters, including any quoting characters."
requirement "SHALL-2-3-032" doc="If a rule below indicates that a token is delimited, and no characters have been included in the token, that empty token shall be discarded."
requirement "SHALL-2-3-033" doc="If the end of input is recognized, the current token (if any) shall be delimited."
requirement "SHALL-2-3-036" doc="If the current character is an unquoted backslash, single-quote, or double-quote or is the first character of an unquoted dollar-sign single-quote sequence, it shall affect quoting for subsequent characters."
requirement "SHALL-2-3-037" doc="During token recognition no substitutions shall be actually performed, and the result token shall contain exactly the characters that appear in the input unmodified."
requirement "SHALL-2-3-038" doc="The token shall not be delimited by the end of the quoted field."
requirement "SHALL-2-3-039" doc="If the current character is an unquoted $ or backtick, the shell shall identify the start of any candidates for parameter expansion, command substitution, or arithmetic expansion."
requirement "SHALL-2-3-040" doc="The shell shall read sufficient input to determine the end of the unit to be expanded."
requirement "SHALL-2-3-041" doc="While processing the characters, if instances of expansions or quoting are found nested within the substitution, the shell shall recursively process them."
requirement "SHALL-2-3-042" doc="For $( and backtick only, if instances of io_here tokens are found nested within the substitution, they shall be parsed according to the rules of Here-Document."
requirement "SHALL-2-3-043" doc="The characters found from the beginning of the substitution to its end shall be included unmodified in the result token."
requirement "SHALL-2-3-044" doc="The token shall not be delimited by the end of the substitution."
requirement "SHALL-2-3-050" doc="complete_command executed before next is tokenized and parsed."
requirement "SHALL-2-3-1-052" doc="The value of the alias shall be processed as if it had been read from input."
requirement "SHALL-2-3-1-053" doc="An implementation may defer alias change but it shall take effect no later than the completion of the next complete_command."
requirement "SHALL-DESCRIPTION-001" doc="The sh utility is a command language interpreter that shall execute commands read from a command line string, the standard input, or a specified file."
requirement "SHALL-DESCRIPTION-002" doc="The application shall ensure that the commands to be executed are expressed in the language described in 2."
requirement "SHALL-V3CHAP02-1000" doc="The application shall quote the following characters if they are to represent themselves."
requirement "SHALL-2-2-1-002" doc="A backslash that is not quoted shall preserve the literal value of the following character, with the exception of a newline."
requirement "SHALL-2-2-1-003" doc="If a newline immediately follows the backslash, the shell shall interpret this as line continuation."
requirement "SHALL-2-2-1-004" doc="The backslash and newline shall be removed before splitting the input into tokens."
requirement "SHALL-2-2-2-005" doc="Enclosing characters in single-quotes shall preserve the literal value of each character within the single-quotes."
requirement "SHALL-2-2-3-007" doc="Enclosing characters in double-quotes shall preserve the literal value of all characters within the double-quotes, with the exception of backquote, dollar-sign, and backslash."
requirement "SHALL-2-2-3-008" doc="The input characters within the quoted string that are also enclosed between $( and the matching ) shall not be affected by the double-quotes."
requirement "SHALL-2-2-3-009" doc="The tokenizing rules in Token Recognition shall be applied recursively to find the matching )."
requirement "SHALL-2-2-3-010" doc="For the four varieties of parameter expansion that provide for substring processing, the double-quotes shall have no effect on the handling of any special characters."
requirement "SHALL-2-2-3-011" doc="For parameter expansions other than substring processing, double-quotes shall preserve the literal value of all characters with the exception of double-quote, backquote, dollar-sign, and backslash."
requirement "SHALL-2-2-3-012" doc="The backquote and dollar-sign characters shall follow the same rules as for characters in double-quotes."
requirement "SHALL-2-2-3-013" doc="The backslash character shall follow the same rules as for characters in double-quotes except that it shall additionally retain its special meaning as an escape character when followed by }."
requirement "SHALL-2-2-3-014" doc="The backquote shall retain its special meaning introducing the other form of command substitution."
requirement "SHALL-2-2-3-015" doc="Outside of $(...) and ${...} the backslash shall retain its special meaning as an escape character only when immediately followed by $ backtick backslash or newline."
requirement "SHALL-2-2-3-016" doc="When double-quotes are used to quote a parameter expansion, command substitution, or arithmetic expansion, the literal value of all characters within the result shall be preserved."
requirement "SHALL-2-2-3-017" doc="The application shall ensure that a double-quote not within $(...) nor ${...} is immediately preceded by a backslash in order to be included within double-quotes."
requirement "SHALL-2-2-4-019" doc="In cases where a variable number of characters can be used to specify an escape sequence, the escape sequence shall be terminated by the first character that is not of the expected type."
requirement "SHALL-2-2-4-020" doc="A sequence starting with dollar-sign single-quote shall preserve the literal value of all characters within the single-quotes, with the exception of backslash."
requirement "SHALL-2-2-4-021" doc="However, implementations shall not replace an unsupported character with bytes that do not form valid characters in that locale."
requirement "SHALL-2-2-4-022" doc="If a backslash-escape sequence represents a single-quote character, that sequence shall not terminate the dollar-single-quote sequence."
requirement "SHALL-2-3-034" doc="If the current character is a newline, it shall delimit the current token."
requirement "SHALL-V3CHAP02-1003" doc="The following words shall be recognized as reserved words: ! { } case do done elif else esac fi for if in then until while."
requirement "SHALL-V3CHAP02-1004" doc="Recognition shall only occur when unquoted, used as first word of command."
requirement "SHALL-V3CHAP02-1015" doc="TOKEN-to-reserved-word conversion rules in grammar productions."
requirement "SHALL-V3CHAP02-1001-DUP51" doc="If alias value ends in unquoted blank, shell shall check next token for alias substitution."
requirement "SHALL-V3CHAP02-1002" doc="After categorizing as TOKEN, alias substitution shall apply if: no quoting chars, valid alias name, not currently being substituted."
requirement "SHALL-V3CHAP02-1001" doc="$'...' preserves literal values with backslash-escape support."
requirement "SHALL-V3CHAP02-1006-DUP143" doc="$(commands) and backtick substitution: execute in subshell, replace with stdout, strip trailing newlines."
requirement "SHALL-V3CHAP02-1007" doc="Nesting within backquoted version requires preceding inner backquotes with backslash."
requirement "SHALL-V3CHAP02-1009" doc="Arithmetic expression: only signed long integer arithmetic required."

# ==============================================================================
# Token Recognition: Substitution does not delimit token
# ==============================================================================

begin test "end of substitution does not delimit token"
  begin script
    echo $(echo hello)suffix
  end script
  expect_stdout "hellosuffix"
end test "end of substitution does not delimit token"

begin test "complete_command executed before next is tokenized"
  begin script
    x=first; echo $x
    x=second; echo $x
  end script
  expect_stdout "first\nsecond"
end test "complete_command executed before next is tokenized"

begin test "line continuation: backslash-newline removed before tokenizing"
  begin script
    echo a\
    b
  end script
  expect_stdout "ab"
end test "line continuation: backslash-newline removed before tokenizing"

begin test "bad expansion parameter error"
  begin script
    echo ${/} 2>/dev/null
  end script
  not_expect_exit_code 0
end test "bad expansion parameter error"

begin test "end of input delimits current token"
  begin script
    printf '%s' 'echo lastword' | {{SHELL}}
  end script
  expect_stdout "lastword"
end test "end of input delimits current token"

begin test "empty token discarded"
  begin script
    {{SHELL}} -c ';;' 2>/dev/null || true
  end script
  expect_exit_code 0
end test "empty token discarded"

begin test "quoted field does not delimit token"
  begin script
    echo "hello"world
  end script
  expect_stdout "helloworld"
end test "quoted field does not delimit token"

begin test "substitution does not delimit token nested"
  begin script
    echo prefix_$(echo inner)_suffix
  end script
  expect_stdout "prefix_inner_suffix"
end test "substitution does not delimit token nested"

begin test "here-document body after io_here"
  begin script
    cat <<EOF
    hello from heredoc
    EOF
  end script
  expect_stdout "hello from heredoc"
end test "here-document body after io_here"

begin test "multiple here-documents on same line"
  begin script
    cat <<A; cat <<B
    first
    A
    second
    B
  end script
  expect_stdout "first\nsecond"
end test "multiple here-documents on same line"

begin test "here-doc nested in command substitution"
  begin script
    echo $(cat <<EOF
    nested_heredoc
    EOF
    )
  end script
  expect_stdout "nested_heredoc"
end test "here-doc nested in command substitution"

# ==============================================================================
# The Humble Backslash
# ==============================================================================

begin test "backslash quoting of special characters"
  begin script
    echo \| \& \;
  end script
  expect_stdout "\| & ;"
end test "backslash quoting of special characters"

begin test "backslash preserves literal value of following character"
  begin script
    echo a\\*b
  end script
  expect_stdout "a\\\*b"
end test "backslash preserves literal value of following character"

begin test "backslash preserves dollar sign literally"
  begin script
    echo \$foo
  end script
  expect_stdout "\$foo"
end test "backslash preserves dollar sign literally"

begin test "backslash-newline is line continuation"
  begin script
    ec\
    ho line continuation
  end script
  expect_stdout "line continuation"
end test "backslash-newline is line continuation"

# ==============================================================================
# Single Quotes: The Absolute Literal
# ==============================================================================

begin test "single quotes preserve all characters literally"
  begin script
    echo '$foo *'
  end script
  expect_stdout "\$foo \*"
end test "single quotes preserve all characters literally"

# ==============================================================================
# Double Quotes: The Compromise
# ==============================================================================

begin test "double quotes prevent wildcard expansion"
  begin script
    echo "a*b"
  end script
  expect_stdout "a\*b"
end test "double quotes prevent wildcard expansion"

begin test "double quotes backslash produces single backslash"
  begin script
    echo "\\"
  end script
  expect_stdout "\\"
end test "double quotes backslash produces single backslash"

begin test "double quotes allow parameter and command and arithmetic expansion"
  begin script
    foo=bar; echo "$foo $(echo sub) $((2+2)) $'literal'"
  end script
  expect_stdout "bar sub 4 \$'literal'"
end test "double quotes allow parameter and command and arithmetic expansion"

begin test "inner double quotes inside command substitution"
  begin script
    echo "$(echo "inner quotes")"
  end script
  expect_stdout "inner quotes"
end test "inner double quotes inside command substitution"

begin test "recursive tokenizing finds matching paren"
  begin script
    echo "$(echo "(recursive)")"
  end script
  expect_stdout "\(recursive\)"
end test "recursive tokenizing finds matching paren"

begin test "backquote inside double quotes executes"
  begin script
    echo "`echo sub`"
  end script
  expect_stdout "sub"
end test "backquote inside double quotes executes"

begin test "backslash in double quotes special only before certain chars"
  begin script
    printf "%s\n" "\n \$ \` \\"
  end script
  expect_stdout "\\n \$ ` \\"
end test "backslash in double quotes special only before certain chars"

begin test "double quotes preserve expansion result literally"
  begin script
    foo='* * *'; echo "$foo"
  end script
  expect_stdout "\* \* \*"
end test "double quotes preserve expansion result literally"

# ==============================================================================
# Parameter Expansion Variations in Double Quotes
# ==============================================================================

begin test "substring processing not affected by outer double quotes"
  begin script
    foo="a*b"; unset unset_var; echo "${foo#a*}" "${unset_var:-*}"
  end script
  expect_stdout ".*\*b \*.*"
end test "substring processing not affected by outer double quotes"

begin test "backslash dollar and backquote inside braces"
  begin script
    unset foo; printf "%s\n" "${foo:-`echo default` \$ \n \\ }"
  end script
  expect_stdout "default \$ \\n \\.*"
end test "backslash dollar and backquote inside braces"

begin test "escaped double quote inside double quotes"
  begin script
    echo "\""
  end script
  expect_stdout """"
end test "escaped double quote inside double quotes"

# ==============================================================================
# Dollar-Single-Quotes: The C-Style Strings
# ==============================================================================

begin test "dollar-single-quote newline escape"
  begin script
    echo $'a\nb'
  end script
  expect_stdout "a\nb"
end test "dollar-single-quote newline escape"

begin test "dollar-single-quote hex escape"
  begin script
    echo $'\x41\x42'
  end script
  expect_stdout "AB"
end test "dollar-single-quote hex escape"

begin test "dollar-single-quote escaped single quote"
  begin script
    echo $'quote: \x27, done'
  end script
  expect_stdout "quote: ', done"
end test "dollar-single-quote escaped single quote"

# ==============================================================================
# The Newline Token Delimiter
# ==============================================================================

begin test "newline delimits token"
  begin script
    echo a
    echo b
  end script
  expect_stdout "a\nb"
end test "newline delimits token"

# ==============================================================================
# Reserved Word Recognition
# ==============================================================================

begin test "reserved words not recognized when quoted"
  begin script
    echo "if"
  end script
  expect_stdout "if"
end test "reserved words not recognized when quoted"

begin test "reserved word in variable value not recognized"
  begin script
    x=case; echo $x
  end script
  expect_stdout "case"
end test "reserved word in variable value not recognized"

begin test "reserved words work in correct positions"
  begin script
    if true; then echo yes; fi
  end script
  expect_stdout "yes"
end test "reserved words work in correct positions"

begin test "case/esac reserved words"
  begin script
    case x in x) echo match ;; esac
  end script
  expect_stdout "match"
end test "case/esac reserved words"

# ==============================================================================
# Alias Substitution
# ==============================================================================

begin test "alias trailing blank triggers expansion of next word"
  begin script
    alias myalias="echo "
    myalias hello
  end script
  expect_stdout "hello"
end test "alias trailing blank triggers expansion of next word"

# ==============================================================================
# Dollar-Single-Quote ($') Quoting
# ==============================================================================

begin test "dollar-single-quote basic support"
  begin script
    printf '%s\n' $'hello\nworld'
  end script
  expect_stdout_line ".*hello.*"
  expect_stdout_line ".*world.*"
end test "dollar-single-quote basic support"

# ==============================================================================
# Command Substitution
# ==============================================================================

begin test "dollar-paren command substitution"
  begin script
    echo $(echo hello)
  end script
  expect_stdout "hello"
end test "dollar-paren command substitution"

begin test "backtick command substitution"
  begin script
    echo `echo hello`
  end script
  expect_stdout "hello"
end test "backtick command substitution"

begin test "nested dollar-paren command substitution"
  begin script
    echo $(echo $(echo nested))
  end script
  expect_stdout "nested"
end test "nested dollar-paren command substitution"

# ==============================================================================
# Arithmetic Expansion
# ==============================================================================

begin test "arithmetic addition"
  begin script
    echo $((40 + 2))
  end script
  expect_stdout "42"
end test "arithmetic addition"

begin test "arithmetic subtraction negative"
  begin script
    echo $((3 - 4))
  end script
  expect_stdout "-1"
end test "arithmetic subtraction negative"
