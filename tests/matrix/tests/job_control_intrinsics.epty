testsuite "Job Control Intrinsics"

# ==============================================================================
# jobs -p shows background PIDs
# ==============================================================================


requirement "SHALL-JOBS-1221" doc="If the current shell execution environment (see 2.13 Shell Execution Environment ) is not a subshell environment, the jobs utility shall display the status of background jobs that were created in the current shell execution environment; it may also do so if the current shell execution environment is a subshell environment."
requirement "SHALL-JOBS-1038" doc="The following environment variables shall affect the execution of jobs : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
requirement "SHALL-KILL-1063" doc="The following operands shall be supported: pid One of the following: A decimal integer specifying a process or process group to be signaled."
begin test "jobs -p shows background PID"
  script
    sleep 2 & bg_pid=$!
    jobs -p > jobs_out 2>/dev/null
    grep -q "$bg_pid" jobs_out
    res=$?
    kill "$bg_pid" 2>/dev/null
    wait "$bg_pid" 2>/dev/null
    exit $res
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "jobs -p shows background PID"

requirement "SHALL-SH-1024-DUP746" doc="The following exit values shall be returned: 0 The script to be executed consisted solely of zero or more blank lines or comments, or both."
requirement "SHALL-FG-1049" doc="If fg does not move a job into the foreground, the following exit value shall be returned: >0 An error occurred."
requirement "SHALL-WAIT-1344" doc="If the wait utility is invoked with no operands, it shall wait until all process IDs known to the invoking shell have terminated and exit with a zero exit status."
begin test "wait with no operands exits 0 when all finish"
  script
    sleep 1 & sleep 1 & wait
    exit $?
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "wait with no operands exits 0 when all finish"

requirement "SHALL-WAIT-1087" doc="The following operand shall be supported: pid One of the following: The unsigned decimal integer process ID of a child process whose termination the utility is to wait for."
requirement "SHALL-WAIT-1347" doc="The exit status returned by the wait utility shall be the exit status of the process requested by the last pid operand."
begin test "wait for unknown pid exits 127"
  script
    wait 999999
    exit $?
  expect
    stdout ""
    stderr ".+"
    exit_code 127
end test "wait for unknown pid exits 127"

requirement "SHALL-KILL-1240" doc="For each pid operand, the kill utility shall perform actions equivalent to the kill () function defined in the System Interfaces volume of POSIX.1-2024 called with the following arguments: The value of the pid operand shall be used as the pid argument."
begin test "kill invalid pid fails"
  script
    kill 999999 2>/dev/null
  expect
    stdout ""
    stderr ""
    exit_code !=0
end test "kill invalid pid fails"
