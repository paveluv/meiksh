testsuite "Alias and Unalias Built-ins"

# ==============================================================================
# alias-name operand writes alias definition to stdout
# ==============================================================================

requirement "SHALL-ALIAS-1026" doc="The following operands shall be supported: alias-name Write the alias definition to standard output."

begin test "alias-name operand writes definition to stdout"
  begin script
    alias myalias="echo hello"
    alias myalias
  end script
  expect_exit_code 0
  expect_stdout_line ".*myalias=.*echo hello.*"
end test "alias-name operand writes definition to stdout"

requirement "SHALL-ALIAS-1026" doc="The following operands shall be supported: alias-name Write the alias definition to standard output."
begin test "query second alias writes its definition"
  begin script
    alias foo="ls -la"
    alias bar="grep x"
    alias foo
  end script
  expect_exit_code 0
  expect_stdout_line ".*foo=.*ls -la.*"
end test "query second alias writes its definition"

# ==============================================================================
# alias definition replaces command name when encountered
# ==============================================================================

requirement "SHALL-ALIAS-1053" doc="An alias definition provides a string value that shall replace a command name when it is encountered."

# POSIX §2.3.1: "An implementation may defer the effect of a change to an
# alias but the change shall take effect no later than the completion of
# the currently executing complete_command." Use newline to separate the
# alias definition and usage into distinct complete_commands.

requirement "SHALL-ALIAS-1053" doc="An alias definition provides a string value that shall replace a command name when it is encountered."
begin test "alias definition replaces command name"
  begin script
    alias greet="echo hello world"
    greet
  end script
  expect_exit_code 0
  expect_stdout "hello world"
end test "alias definition replaces command name"

requirement "SHALL-ALIAS-1053" doc="An alias definition provides a string value that shall replace a command name when it is encountered."
begin test "alias definition replaces command name numeric"
  begin script
    alias answer="echo 42"
    answer
  end script
  expect_exit_code 0
  expect_stdout "42"
end test "alias definition replaces command name numeric"

# ==============================================================================
# alias affects current shell execution environment and subshells
# ==============================================================================

requirement "SHALL-ALIAS-1054" doc="An alias definition shall affect the current shell execution environment and the execution environments of the subshells of the current shell."

begin test "alias affects current shell"
  begin script
    alias myecho="echo from_alias"
    myecho
  end script
  expect_exit_code 0
  expect_stdout "from_alias"
end test "alias affects current shell"

requirement "SHALL-ALIAS-1052" doc="The alias utility shall create or redefine alias definitions or write the values of existing alias definitions to standard output."
begin test "alias visible in subshell"
  begin script
    alias sa="echo sub_alias"
    (sa)
  end script
  expect_stdout "sub_alias"
end test "alias visible in subshell"

# ==============================================================================
# alias shall not affect parent process or utility environment
# ==============================================================================

requirement "SHALL-ALIAS-1055" doc="When used as specified by this volume of POSIX.1-2024, the alias definition shall not affect the parent process of the current shell nor any utility environment invoked by the shell; see 2.13 Shell Execution Environment ."

begin test "alias in subshell does not leak to parent"
  begin script
    (alias leaked="echo LEAKED")
    echo world
  end script
  expect_stdout "world"
end test "alias in subshell does not leak to parent"

requirement "SHALL-ALIAS-1055" doc="When used as specified by this volume of POSIX.1-2024, the alias definition shall not affect the parent process of the current shell nor any utility environment invoked by the shell; see 2.13 Shell Execution Environment ."
begin test "alias in child shell does not leak to parent"
  begin script
    $SHELL -c 'alias outer_leak="echo LEAKED"' 2>/dev/null
    echo ok
  end script
  expect_stdout "ok"
end test "alias in child shell does not leak to parent"

# ==============================================================================
# If no operands, all alias definitions written to stdout
# ==============================================================================

requirement "SHALL-ALIAS-1057" doc="If no operands are given, all alias definitions shall be written to standard output."

begin test "alias with no operands lists all definitions"
  begin script
    alias a1="echo 1"
    alias a2="echo 2"
    alias
  end script
  expect_exit_code 0
  expect_stdout_line ".*a1=.*echo 1.*"
  expect_stdout_line ".*a2=.*echo 2.*"
end test "alias with no operands lists all definitions"

# ==============================================================================
# Value string written with appropriate quoting suitable for reinput
# ==============================================================================

requirement "SHALL-ALIAS-1060" doc="The value string shall be written with appropriate quoting so that it is suitable for reinput to the shell."

begin test "alias output suitable for reinput"
  begin script
    alias special="echo hello world"
    _def=$(alias special)
    eval "alias $_def"
    special
  end script
  expect_stdout_line ".*hello world.*"
end test "alias output suitable for reinput"

requirement "SHALL-2-2-3-007" doc="Enclosing characters in double-quotes ( \"\" ) shall preserve the literal value of all characters within the double-quotes, with the exception of the characters backquote, <dollar-sign>, and <backslash>, as follows: $ The <dollar-sign> shall retain its special meaning introducing parameter expansion (see 2.6.2 Parameter Expansion ), a form of command substitution (see 2.6.3 Command Substitution ), and arithmetic expansion (see 2.6.4 Arithmetic Expansion ), but shall not retain its special meaning introducing the dollar-single-quotes form of quoting (see 2.2.4 Dollar-Single-Quotes )."
begin test "alias quoting handles single quotes in value"
  begin script
    alias sq="echo it's fine"
    alias sq
  end script
  expect_stdout_line ".*sq=.*"
end test "alias quoting handles single quotes in value"

# ==============================================================================
# unalias -a removes all alias definitions
# ==============================================================================

requirement "SHALL-UNALIAS-1083" doc="The following option shall be supported: -a Remove all alias definitions from the current shell execution environment."

begin test "unalias -a removes all aliases"
  begin script
    alias x1="echo 1"
    alias x2="echo 2"
    unalias -a
    alias
  end script
  not_expect_stdout_line ".*x1.*"
  not_expect_stdout_line ".*x2.*"
end test "unalias -a removes all aliases"

# ==============================================================================
# unalias alias-name operand removes the named alias
# ==============================================================================

requirement "SHALL-UNALIAS-1084" doc="The following operand shall be supported: alias-name The name of an alias to be removed."

begin test "unalias removes named alias"
  begin script
    alias rmme="echo gone"
    unalias rmme
  end script
  expect_exit_code 0
end test "unalias removes named alias"

requirement "SHALL-UNALIAS-1084" doc="The following operand shall be supported: alias-name The name of an alias to be removed."
begin test "querying removed alias fails"
  begin script
    alias rmme="echo gone"
    unalias rmme
    alias rmme 2>&1
  end script
  not_expect_exit_code 0
  not_expect_stdout_line ".*rmme.*echo.*gone.*"
end test "querying removed alias fails"

requirement "SHALL-2-5-2-062" doc="Listed below are the special parameters and the values to which they shall expand."
begin test "unaliased command does not expand"
  begin script
    alias rmme2="echo gone"
    unalias rmme2
    rmme2
  end script
  not_expect_exit_code 0
end test "unaliased command does not expand"

# ==============================================================================
# unalias removes definition for each alias name
# ==============================================================================

requirement "SHALL-UNALIAS-1335" doc="The unalias utility shall remove the definition for each alias name specified."

begin test "unalias removes multiple aliases"
  begin script
    alias a="echo A"
    alias b="echo B"
    alias c="echo C"
    unalias a b
    alias
  end script
  not_expect_stdout_line ".*a=.*echo.*A.*"
  not_expect_stdout_line ".*b=.*echo.*B.*"
  expect_stdout_line ".*c=.*echo C.*"
end test "unalias removes multiple aliases"

# ==============================================================================
# Removed from current shell execution environment
# ==============================================================================

requirement "SHALL-UNALIAS-1336" doc="The aliases shall be removed from the current shell execution environment; see 2.13 Shell Execution Environment ."

begin test "unaliased name no longer expands"
  begin script
    alias zz="echo WRONG"
    unalias zz
    echo after_removal
  end script
  expect_stdout "after_removal"
  not_expect_stdout "WRONG"
end test "unaliased name no longer expands"

requirement "SHALL-UNALIAS-1046" doc="The following environment variables shall affect the execution of unalias : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "unalias -a clears environment"
  begin script
    alias yy="echo WRONG"
    unalias -a
    echo clean
  end script
  expect_stdout "clean"
  not_expect_stdout "WRONG"
end test "unalias -a clears environment"

# ==============================================================================
# alias utility (from command_identification)
# ==============================================================================

requirement "SHALL-ALIAS-1052" doc="The alias utility shall create or redefine alias definitions or write the values of existing alias definitions to standard output."
requirement "SHALL-ALIAS-1026-DUP757" doc="The format for displaying aliases (when no operands or only name operands are specified) shall be: \"%s=%s\\n\", name , value The value string shall be written with appropriate quoting so that it is suitable for reinput to the shell."
requirement "SHALL-ALIAS-1028" doc="The following exit values shall be returned: 0 Successful completion."

begin test "alias creates definition visible in output"
  begin script
    alias foo=bar
    alias foo | grep -q "foo=" && echo pass || echo fail
  end script
  expect_stdout "pass"
end test "alias creates definition visible in output"

requirement "SHALL-ALIAS-1052" doc="The alias utility shall create or redefine alias definitions or write the values of existing alias definitions to standard output."
begin test "alias redefine updates the definition"
  begin script
    alias mya="echo old"
    alias mya="echo new"
    alias mya
  end script
  expect_stdout_line ".*mya=.*new.*"
end test "alias redefine updates the definition"

requirement "SHALL-ALIAS-1025" doc="The following environment variables shall affect the execution of alias : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables for the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "alias exit code 0 on success"
  begin script
    alias a1=b1 2>/dev/null
  end script
  expect_exit_code 0
end test "alias exit code 0 on success"

# ==============================================================================
# unalias utility (from command_identification)
# ==============================================================================

requirement "SHALL-UNALIAS-1337" doc="The unalias utility shall conform to XBD 12.2 Utility Syntax Guidelines ."

begin test "unalias removes alias and query fails"
  begin script
    alias foo=bar
    unalias foo
    alias foo >/dev/null 2>&1 || echo pass
  end script
  expect_stdout "pass"
end test "unalias removes alias and query fails"

requirement "SHALL-UNALIAS-1335" doc="The unalias utility shall remove the definition for each alias name specified."
begin test "unalias -a empties alias list"
  begin script
    alias foo=bar
    alias baz=qux
    unalias -a
    val=$(alias)
    [ -z "$val" ] && echo pass || echo fail
  end script
  expect_stdout "pass"
end test "unalias -a empties alias list"
