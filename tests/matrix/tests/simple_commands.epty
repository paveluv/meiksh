testsuite "Simple Commands"

# ==============================================================================
# Order of Processing
# ==============================================================================

requirement "SHALL-2-9-1-1-267" doc="The first word (if any) that is not a variable assignment or redirection shall be expanded."
requirement "SHALL-2-9-1-1-268" doc="When a given simple command is required to be executed, if any fields remain following its expansion, the first field shall be considered the command name."
requirement "SHALL-2-9-1-1-271" doc="For all other command names, words after the word that produced the command name shall be subject only to regular expansion."
requirement "SHALL-2-9-1-1-272" doc="All fields resulting from the expansion of the word that produced the command name and the subsequent words, except for the field containing the command name, shall be the arguments for the command."
requirement "SHALL-2-9-1-1-273" doc="Redirections shall be performed as described in 2.7 Redirection."

begin test "variable expands into command name and argument"
  begin script
    cmd="printf %s
    "; $cmd "hello"
  end script
  expect_stdout "hello"
end test "variable expands into command name and argument"

requirement "SHALL-2-9-1-1-269" doc="If no fields remain, the next word (if any) shall be expanded, and so on, until a command name is found or no words remain."

begin test "empty first word skipped to find command"
  begin script
    empty=""; $empty printf "%s
    " "hello"
  end script
  expect_stdout "hello"
end test "empty first word skipped to find command"

# ==============================================================================
# Variable Assignments
# ==============================================================================

requirement "SHALL-2-9-1-2-276" doc="If no command name results, variable assignments shall affect the current execution environment."

begin test "assignment with no command alters shell state"
  begin script
    FOO=bar; printf "%s
    " "$FOO"
  end script
  expect_stdout "bar"
end test "assignment with no command alters shell state"

requirement "SHALL-2-9-1-2-277" doc="If the command name is not a special built-in utility or function, the variable assignments shall be exported for the execution environment of the command and shall not affect the current execution environment."

begin test "assignment before regular command is temporary"
  begin script
    FOO=bar sh -c 'echo $FOO'; echo "${FOO:-unset}"
  end script
  expect_stdout "bar\nunset"
end test "assignment before regular command is temporary"

requirement "SHALL-2-9-1-2-279" doc="If the command name is a special built-in utility, variable assignments shall affect the current execution environment before the utility is executed and remain in effect when the command completes."

begin test "assignment before special built-in persists"
  begin script
    FOO=bar export DUMMY=1; printf "%s
    " "$FOO"
  end script
  expect_stdout "bar"
end test "assignment before special built-in persists"

requirement "SHALL-2-9-1-2-281" doc="If any of the variable assignments attempt to assign a value to a variable for which the readonly attribute is set in the current shell environment, a variable assignment error shall occur."

begin test "assignment to readonly variable fails"
  begin script
    readonly FOO=1; FOO=2
  end script
  not_expect_exit_code 0
end test "assignment to readonly variable fails"

# ==============================================================================
# Redirections without Command Names
# ==============================================================================

requirement "SHALL-2-9-1-3-282" doc="If a simple command has no command name after word expansion, any redirections shall be performed in a subshell environment."
requirement "SHALL-2-9-1-3-283" doc="If any of the redirections performed in the current shell execution environment fail, the command shall immediately fail with an exit status greater than zero."

begin test "redirection with no command creates file"
  begin script
    > tmp_redir.txt; ls tmp_redir.txt
  end script
  expect_stdout "tmp_redir.txt"
end test "redirection with no command creates file"

begin test "failed redirection with no command yields non-zero"
  begin script
    > /does_not_exist/file
  end script
  not_expect_exit_code 0
end test "failed redirection with no command yields non-zero"

requirement "SHALL-2-9-1-3-284" doc="If there is no command name but the command contains a command substitution, the command shall complete with the exit status of the last command substitution."

begin test "command substitution exit status propagates"
  begin script
    var=$(false)
  end script
  not_expect_exit_code 0
end test "command substitution exit status propagates"

requirement "SHALL-2-9-1-3-285" doc="Otherwise, the command shall complete with a zero exit status."

begin test "simple assignment completes with zero exit status"
  begin script
    FOO=bar
  end script
  expect_exit_code 0
end test "simple assignment completes with zero exit status"

# ==============================================================================
# Command Search and Execution
# ==============================================================================

requirement "SHALL-2-9-1-4-288" doc="If the command name matches the name of a function known to this shell, the function shall be invoked."

begin test "function invocation by name"
  begin script
    myfunc() { printf "%s
    " "in func"; }; myfunc
  end script
  expect_stdout "in func"
end test "function invocation by name"
