testsuite "fc Extended"

# ==============================================================================
# fc -l with -r (reverse listing)
# ==============================================================================

requirement "SHALL-FC-1128" doc="fc shall list or edit and re-execute commands from the command history"
requirement "SHALL-FC-1130" doc="The relationship of a number to its command shall not change"
requirement "SHALL-FC-1131" doc="When the number reaches an implementation-defined upper limit, which shall be no smaller than the value of HISTSIZE, it shall wrap"
requirement "SHALL-FC-1132" doc="fc shall maintain the time-ordering sequence of the history list"
requirement "SHALL-FC-1137" doc="The fc utility shall conform to XBD 12.2 Utility Syntax Guidelines"
requirement "SHALL-FC-1141" doc="The commands shall be written in the sequence indicated by first and last, as affected by -r"
requirement "SHALL-FC-1146" doc="If last is omitted, last shall default to the previous command"
requirement "SHALL-FC-1151" doc="It shall not be an error to specify first or last values that are out of range"
requirement "SHALL-FC-1152" doc="For example, fc -l and fc 1 99 shall list all commands"
requirement "SHALL-FC-1033" doc="If the command consists of more than one line, the lines after the first shall be displayed"
requirement "SHALL-FC-1046" doc="Exit value 0 for listing"
requirement "SHALL-FC-1042" doc="Any command line variable assignments or redirection operators used with fc shall affect both the fc built-in and the resulting command"
requirement "SHALL-FC-1150" doc="If first represents a newer command than last, the commands shall be listed or edited in reverse sequence"

begin interactive test "fc -lr lists in reverse order"
  spawn -i
  expect "$ "
  send "echo rev_alpha"
  expect "rev_alpha"
  expect "$ "
  send "echo rev_beta"
  expect "rev_beta"
  expect "$ "
  send "echo rev_gamma"
  expect "rev_gamma"
  expect "$ "
  send "fc -lr -3 -1"
  expect "rev_gamma"
  expect "rev_beta"
  expect "rev_alpha"
  sendeof
  wait
end interactive test "fc -lr lists in reverse order"

begin interactive test "fc -l -r with explicit range reverses listing"
  spawn -i
  expect "$ "
  send "echo rl_one"
  expect "rl_one"
  expect "$ "
  send "echo rl_two"
  expect "rl_two"
  expect "$ "
  send "fc -l -r -2 -1"
  expect "rl_two"
  expect "rl_one"
  sendeof
  wait
end interactive test "fc -l -r with explicit range reverses listing"


# ==============================================================================
# fc with negative numbers
# ==============================================================================

requirement "SHALL-FC-1045" doc="The value of first or last or both shall be a positive or negative number used as a command number; a negative number shall be used as an offset from the current command number"
requirement "SHALL-FC-1148" doc="If first and last are both present, all of the commands from first to last shall be edited or listed"

begin interactive test "fc -l -1 lists only the most recent command"
  spawn -i
  expect "$ "
  send "echo neg_latest"
  expect "neg_latest"
  expect "$ "
  send "fc -l -1 -1"
  expect "echo neg_latest"
  sendeof
  wait
end interactive test "fc -l -1 lists only the most recent command"

begin interactive test "fc -l -3 -2 lists a range by negative offsets"
  spawn -i
  expect "$ "
  send "echo neg_a"
  expect "neg_a"
  expect "$ "
  send "echo neg_b"
  expect "neg_b"
  expect "$ "
  send "echo neg_c"
  expect "neg_c"
  expect "$ "
  send "fc -l -3 -2"
  expect "echo neg_a"
  expect "echo neg_b"
  sendeof
  wait
end interactive test "fc -l -3 -2 lists a range by negative offsets"

requirement "SHALL-FC-1145" doc="If first is omitted, the previous command shall be used"

begin interactive test "fc -s with negative number re-executes offset command"
  spawn -i
  expect "$ "
  send "echo neg_reexec_target"
  expect "neg_reexec_target"
  expect "$ "
  send "echo filler"
  expect "filler"
  expect "$ "
  send "fc -s -2"
  expect "neg_reexec_target"
  sendeof
  wait
end interactive test "fc -s with negative number re-executes offset command"


# ==============================================================================
# fc range selection with first > last (reverse)
# ==============================================================================

begin interactive test "fc -l with first > last lists in reverse sequence"
  spawn -i
  expect "$ "
  send "echo rng_first"
  expect "rng_first"
  expect "$ "
  send "echo rng_second"
  expect "rng_second"
  expect "$ "
  send "echo rng_third"
  expect "rng_third"
  expect "$ "
  send "fc -l -1 -3"
  expect "rng_third"
  expect "rng_second"
  expect "rng_first"
  sendeof
  wait
end interactive test "fc -l with first > last lists in reverse sequence"

begin interactive test "reversed range with positive numbers"
  spawn -i
  expect "$ "
  send "echo posrev_a"
  expect "posrev_a"
  expect "$ "
  send "echo posrev_b"
  expect "posrev_b"
  expect "$ "
  send "echo posrev_c"
  expect "posrev_c"
  expect "$ "
  send "fc -l -1 -3"
  expect "posrev_c"
  expect "posrev_b"
  expect "posrev_a"
  sendeof
  wait
end interactive test "reversed range with positive numbers"


# ==============================================================================
# History number formatting in fc -l output
# ==============================================================================

requirement "SHALL-FC-1031" doc="When the -l option is used to list commands, the format of each command in the list shall be as follows: \"%d\\t%s\\n\", <line number>, <command>"
requirement "SHALL-FC-1129" doc="The command history list shall reference commands by number"

begin interactive test "fc -l output contains command text"
  spawn -i
  expect "$ "
  send "echo numfmt_test"
  expect "numfmt_test"
  expect "$ "
  send "fc -l -1 -1"
  expect "echo numfmt_test"
  sendeof
  wait
end interactive test "fc -l output contains command text"

begin interactive test "fc -l line numbers are monotonically increasing"
  spawn -i
  expect "$ "
  send "echo mono_a"
  expect "mono_a"
  expect "$ "
  send "echo mono_b"
  expect "mono_b"
  expect "$ "
  send "echo mono_c"
  expect "mono_c"
  expect "$ "
  send "fc -l -3 -1"
  expect "echo mono_a"
  expect "echo mono_b"
  expect "echo mono_c"
  sendeof
  wait
end interactive test "fc -l line numbers are monotonically increasing"

requirement "SHALL-FC-1032" doc="If both the -l and -n options are specified, the format of each command shall be: \"\\t%s\\n\", <command>"

begin interactive test "fc -ln suppresses line numbers"
  spawn -i
  expect "$ "
  send "echo nfmt_test"
  expect "nfmt_test"
  expect "$ "
  send "fc -ln -1 -1"
  expect "echo nfmt_test"
  sendeof
  wait
end interactive test "fc -ln suppresses line numbers"


# ==============================================================================
# fc interaction with HISTSIZE
# ==============================================================================

requirement "SHALL-FC-1143" doc="The number of previous commands that can be accessed shall be determined by the value of the HISTSIZE variable"

begin interactive test "fc -l shows recently entered command"
  spawn -i
  expect "$ "
  send "echo hs_test_cmd"
  expect "hs_test_cmd"
  expect "$ "
  send "fc -l"
  expect "hs_test_cmd"
  sendeof
  wait
end interactive test "fc -l shows recently entered command"


# ==============================================================================
# fc -l with no operands lists previous 16 commands
# ==============================================================================

requirement "SHALL-FC-1147" doc="If first and last are both omitted, the previous 16 commands shall be listed or the previous single command shall be edited"

begin interactive test "fc -l with no operands lists recent commands"
  spawn -i
  expect "$ "
  send "echo bare_list_test"
  expect "bare_list_test"
  expect "$ "
  send "fc -l"
  expect "echo bare_list_test"
  sendeof
  wait
end interactive test "fc -l with no operands lists recent commands"


# ==============================================================================
# fc -s re-executes and enters result into history
# ==============================================================================

requirement "SHALL-FC-1133" doc="When commands are edited, the resulting lines shall be entered at the end of the history list and then re-executed by sh"

begin interactive test "fc -s re-executes and enters result into history"
  spawn -i
  expect "$ "
  send "echo reenter_hist"
  expect "reenter_hist"
  expect "$ "
  send "fc -s"
  expect "reenter_hist"
  expect "$ "
  send "fc -l -1 -1"
  expect "echo reenter_hist"
  sendeof
  wait
end interactive test "fc -s re-executes and enters result into history"
