testsuite "fc — Command History Editing"

# ==============================================================================
# Requirements
# ==============================================================================

requirement "SHALL-FC-1128" doc="The fc utility shall list, or shall edit and re-execute, commands previously entered to an interactive sh"
requirement "SHALL-FC-1129" doc="The command history list shall reference commands by number"
requirement "SHALL-FC-1134" doc="The fc command itself shall not be entered into the history when listing"
requirement "SHALL-FC-1043" doc="Use the editor named by editor to edit the commands"
requirement "SHALL-FC-1044" doc="fc -s [old=new] [command] — re-execute the command, performing the optional substitution of old with new"
requirement "SHALL-FC-1045" doc="A positive number representing a command number; command numbers can be displayed with the -l option"
requirement "SHALL-FC-1139" doc="The value in the FCEDIT variable shall be used as a default when -e is not specified"
requirement "SHALL-FC-1149" doc="Editing multiple commands: all presented at once to the editor"
requirement "SHALL-FC-1154" doc="FCEDIT environment variable"
requirement "SHALL-FC-1164" doc="Exit status otherwise = that of re-executed commands"
requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution"
requirement "SHALL-FC-1031" doc="When the -l option is used to list commands, the format of each command in the list shall be as follows: %d\\t%s\\n, <line number>, <command>"
requirement "SHALL-FC-1032" doc="If both the -l and -n options are specified, the format of each command shall be: \\t%s\\n, <command>"
requirement "SHALL-FC-1145" doc="If first is omitted, the previous command shall be used"
requirement "SHALL-FC-1148" doc="If first and last are both present, all of the commands from first to last shall be edited or listed"
requirement "SHALL-FC-1147" doc="If first and last are both omitted, the previous 16 commands shall be listed or the previous single command shall be edited"
requirement "SHALL-FC-1133" doc="When commands are edited, the resulting lines shall be entered at the end of the history list and then re-executed by sh"
requirement "SHALL-FC-1150" doc="If first represents a newer command than last, the commands shall be listed or edited in reverse sequence"
requirement "SHALL-FC-1143" doc="The number of previous commands that can be accessed shall be determined by the value of the HISTSIZE variable"
requirement "SHALL-FC-1046" doc="The following exit values shall be returned: 0 Successful completion of the listing"


# ==============================================================================
# fc -l: List command history
# ==============================================================================

begin interactive test "fc -l lists command history"
  spawn -i
  expect "$ "
  send "echo fc_test_1"
  expect "fc_test_1"
  expect "$ "
  send "echo fc_test_2"
  expect "fc_test_2"
  expect "$ "
  send "fc -l"
  expect "echo fc_test_1"
  expect "echo fc_test_2"
  sendeof
  wait
end interactive test "fc -l lists command history"


# ==============================================================================
# fc -l with -n (suppress line numbers)
# ==============================================================================

begin interactive test "fc -ln suppresses line numbers"
  spawn -i
  expect "$ "
  send "echo ln_test"
  expect "ln_test"
  expect "$ "
  send "fc -ln"
  expect "echo ln_test"
  sendeof
  wait
end interactive test "fc -ln suppresses line numbers"


# ==============================================================================
# fc -s: Re-execute previous command
# ==============================================================================

begin interactive test "fc -s re-executes previous command"
  spawn -i
  expect "$ "
  send "echo reexec_target"
  expect "reexec_target"
  expect "$ "
  send "fc -s"
  expect "reexec_target"
  sendeof
  wait
end interactive test "fc -s re-executes previous command"


# ==============================================================================
# fc -s with substitution: old=new
# ==============================================================================

begin interactive test "fc -s old=new substitution"
  spawn -i
  expect "$ "
  send "echo old_value"
  expect "old_value"
  expect "$ "
  send "fc -s old_value=new_value"
  expect "new_value"
  sendeof
  wait
end interactive test "fc -s old=new substitution"


# ==============================================================================
# fc first/last range selection
# ==============================================================================

begin interactive test "fc -l with first/last range"
  spawn -i
  expect "$ "
  send "echo range_a"
  expect "range_a"
  expect "$ "
  send "echo range_b"
  expect "range_b"
  expect "$ "
  send "echo range_c"
  expect "range_c"
  expect "$ "
  send "fc -l -2 -1"
  expect "echo range_b"
  expect "echo range_c"
  sendeof
  wait
end interactive test "fc -l with first/last range"


# ==============================================================================
# fc with FCEDIT editor invocation
# ==============================================================================

begin interactive test "fc with FCEDIT editor invocation"
  spawn -i
  expect "$ "
  send "echo original_cmd"
  expect "original_cmd"
  expect "$ "
  send "FCEDIT=/tmp/_fc_ed.sh; printf '#!/bin/sh\nf=$1; sed s/original_cmd/edited_cmd/ <$f >/tmp/_fc_tmp && mv /tmp/_fc_tmp $f' >$FCEDIT; chmod +x $FCEDIT; export FCEDIT"
  expect "$ "
  send "fc"
  expect "edited_cmd"
  expect "$ "
  sendeof
  wait
end interactive test "fc with FCEDIT editor invocation"


# ==============================================================================
# fc -e editor option
# ==============================================================================

begin interactive test "fc -e editor option"
  spawn -i
  expect "$ "
  send "echo fe_original"
  expect "fe_original"
  expect "$ "
  send "printf '#!/bin/sh\nf=$1; sed s/fe_original/fe_edited/ <$f >/tmp/_fc_tmp2 && mv /tmp/_fc_tmp2 $f' >/tmp/_fc_ed2.sh; chmod +x /tmp/_fc_ed2.sh"
  expect "$ "
  send "fc -e /tmp/_fc_ed2.sh"
  expect "fe_edited"
  expect "$ "
  send "true"
  expect "$ "
  sendeof
  wait
end interactive test "fc -e editor option"


# ==============================================================================
# fc -e editor with non-zero exit suppresses re-execution
# ==============================================================================

begin interactive test "fc -e non-zero exit suppresses re-execution"
  spawn -i
  expect "$ "
  send "echo should_not_reexec"
  expect "should_not_reexec"
  expect "$ "
  send "fc -e false; true"
  expect "$ "
  not_expect "should_not_reexec"
  sendeof
  wait
end interactive test "fc -e non-zero exit suppresses re-execution"


# ==============================================================================
# fc -l with string pattern as first operand
# ==============================================================================

begin interactive test "fc -l with string pattern operand"
  spawn -i
  expect "$ "
  send "echo unique_pat_cmd"
  expect "unique_pat_cmd"
  expect "$ "
  send "echo other_cmd"
  expect "other_cmd"
  expect "$ "
  send "fc -l -2 -1"
  expect "echo unique_pat_cmd"
  expect "echo other_cmd"
  sendeof
  wait
end interactive test "fc -l with string pattern operand"


# ==============================================================================
# fc -l reverse order
# ==============================================================================

begin interactive test "fc -l reverse order"
  spawn -i
  expect "$ "
  send "echo rev_first"
  expect "rev_first"
  expect "$ "
  send "echo rev_second"
  expect "rev_second"
  expect "$ "
  send "fc -l -1 -2"
  expect "rev_second"
  expect "rev_first"
  sendeof
  wait
end interactive test "fc -l reverse order"


# ==============================================================================
# HISTSIZE controls accessible history
# ==============================================================================

begin interactive test "HISTSIZE controls accessible history"
  spawn -i
  expect "$ "
  send "HISTSIZE=3"
  expect "$ "
  send "echo old_gone"
  expect "$ "
  send "echo keep1"
  expect "$ "
  send "echo keep2"
  expect "$ "
  send "echo keep3"
  expect "$ "
  send "fc -l"
  not_expect "old_gone"
  expect "keep"
  sendeof
  wait
end interactive test "HISTSIZE controls accessible history"


# ==============================================================================
# fc exit status
# ==============================================================================

begin interactive test "fc -l exit status is zero"
  spawn -i
  expect "$ "
  send "echo status_test"
  expect "status_test"
  expect "$ "
  send "fc -l; echo fc_exit_$?"
  expect "fc_exit_0"
  sendeof
  wait
end interactive test "fc -l exit status is zero"


# ==============================================================================
# fc -l with absolute line numbers
# ==============================================================================

begin interactive test "fc -l with absolute line numbers"
  spawn -i
  expect "$ "
  send "echo a"
  expect "a"
  expect "$ "
  send "echo b"
  expect "b"
  expect "$ "
  send "echo c"
  expect "c"
  expect "$ "
  send "fc -l 1 3"
  expect "echo a"
  expect "echo b"
  expect "echo c"
  sendeof
  wait
end interactive test "fc -l with absolute line numbers"


# ==============================================================================
# fc -l with out-of-range line number
# ==============================================================================

begin interactive test "fc -l with out-of-range line number"
  spawn -i
  expect "$ "
  send "fc -l 9999; echo fc_done"
  expect "fc_done"
  sendeof
  wait
end interactive test "fc -l with out-of-range line number"


# ==============================================================================
# fc -s old=new with string-pattern operand
# ==============================================================================

begin interactive test "fc -s old=new with string-pattern operand"
  spawn -i
  expect "$ "
  send "echo OLD_VALUE"
  expect "OLD_VALUE"
  expect "$ "
  send "fc -s OLD=NEW echo"
  expect "NEW_VALUE"
  sendeof
  wait
end interactive test "fc -s old=new with string-pattern operand"
