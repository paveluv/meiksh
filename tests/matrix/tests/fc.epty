testsuite "fc — Command History Editing"

# ==============================================================================
# Requirements
# ==============================================================================


requirement "SHALL-FC-1129" doc="The command history list shall reference commands by number."
requirement "SHALL-FC-1134" doc="The fc command that caused the editing shall not be entered into the history list."
requirement "SHALL-FC-1032" doc="If both the -l and -n options are specified, the format of each command shall be: \"\\t%s\\n\", <command>."
begin interactive test "fc -l lists command history"
  spawn -i
  expect "$ "
  send "echo fc_test_1"
  expect "fc_test_1"
  expect "$ "
  send "echo fc_test_2"
  expect "fc_test_2"
  expect "$ "
  send "fc -l"
  expect "echo fc_test_1"
  expect "echo fc_test_2"
  sendeof
  wait
end interactive test "fc -l lists command history"

requirement "SHALL-FC-1032" doc="If both the -l and -n options are specified, the format of each command shall be: \"\\t%s\\n\", <command>."
begin interactive test "fc -ln suppresses line numbers"
  spawn -i
  expect "$ "
  send "echo ln_test"
  expect "ln_test"
  expect "$ "
  send "fc -ln"
  expect "echo ln_test"
  sendeof
  wait
end interactive test "fc -ln suppresses line numbers"

requirement "SHALL-FC-1128" doc="The fc utility shall list, or shall edit and re-execute, commands previously entered to an interactive sh ."
requirement "SHALL-FC-1145" doc="When the synopsis form with -s is used: If first is omitted, the previous command shall be used."
requirement "SHALL-FC-1147" doc="If first and last are both omitted, the previous 16 commands shall be listed or the previous single command shall be edited (based on the -l option)."
begin interactive test "fc -s re-executes previous command"
  spawn -i
  expect "$ "
  send "echo reexec_target"
  expect "reexec_target"
  expect "$ "
  send "fc -s"
  expect "reexec_target"
  sendeof
  wait
end interactive test "fc -s re-executes previous command"

requirement "SHALL-FC-1149" doc="Editing multiple commands shall be accomplished by presenting to the editor all of the commands at one time, each command starting on a new line."
begin interactive test "fc -s old=new substitution"
  spawn -i
  expect "$ "
  send "echo old_value"
  expect "old_value"
  expect "$ "
  send "fc -s old_value=new_value"
  expect "new_value"
  sendeof
  wait
end interactive test "fc -s old=new substitution"

requirement "SHALL-FC-1044" doc="The following operands shall be supported: first , last Select the commands to list or edit."
requirement "SHALL-FC-1045" doc="The value of first or last or both shall be one of the following: [+] number A positive number representing a command number; command numbers can be displayed with the -l option."
requirement "SHALL-FC-1148" doc="If first and last are both present, all of the commands from first to last shall be edited (without -l ) or listed (with -l )."
begin interactive test "fc -l with first/last range"
  spawn -i
  expect "$ "
  send "echo range_a"
  expect "range_a"
  expect "$ "
  send "echo range_b"
  expect "range_b"
  expect "$ "
  send "echo range_c"
  expect "range_c"
  expect "$ "
  send "fc -l -2 -1"
  expect "echo range_b"
  expect "echo range_c"
  sendeof
  wait
end interactive test "fc -l with first/last range"

requirement "SHALL-FC-1139" doc="The value in the FCEDIT variable shall be used as a default when -e is not specified."
begin interactive test "fc with FCEDIT editor invocation"
  spawn -i
  expect "$ "
  send "echo original_cmd"
  expect "original_cmd"
  expect "$ "
  send "FCEDIT=/tmp/_fc_ed.sh; printf '#!%s\nf=$1; sed s/original_cmd/edited_cmd/ <$f >/tmp/_fc_tmp && mv /tmp/_fc_tmp $f' \"${SHELL%% *}\" >$FCEDIT; chmod +x $FCEDIT; export FCEDIT"
  expect "$ "
  send "fc"
  expect "edited_cmd"
  expect "$ "
  sendeof
  wait
end interactive test "fc with FCEDIT editor invocation"

requirement "SHALL-FC-1043" doc="The following options shall be supported: -e editor Use the editor named by editor to edit the commands."
requirement "SHALL-FC-1154" doc="The following environment variables shall affect the execution of fc : FCEDIT This variable, when expanded by the shell, shall determine the default value for the -e editor option's editor option-argument."
requirement "SHALL-FC-1133" doc="When commands are edited (when the -l option is not specified), the resulting lines shall be entered at the end of the history list and then re-executed by sh ."
begin interactive test "fc -e editor option"
  spawn -i
  expect "$ "
  send "echo fe_original"
  expect "fe_original"
  expect "$ "
  send "printf '#!%s\nf=$1; sed s/fe_original/fe_edited/ <$f >/tmp/_fc_tmp2 && mv /tmp/_fc_tmp2 $f' \"${SHELL%% *}\" >/tmp/_fc_ed2.sh; chmod +x /tmp/_fc_ed2.sh"
  expect "$ "
  send "fc -e /tmp/_fc_ed2.sh"
  expect "fe_edited"
  expect "$ "
  send "true"
  expect "$ "
  sendeof
  wait
end interactive test "fc -e editor option"

requirement "SHALL-FC-1135" doc="If the editor returns a non-zero exit status, this shall suppress the entry into the history list and the command re-execution."
requirement "SHALL-FC-1046" doc="The following exit values shall be returned: 0 Successful completion of the listing."
begin interactive test "fc -e non-zero exit suppresses re-execution"
  spawn -i
  expect "$ "
  send "echo should_not_reexec"
  expect "should_not_reexec"
  expect "$ "
  send "fc -e false; true"
  expect "$ "
  not_expect "should_not_reexec"
  sendeof
  wait
end interactive test "fc -e non-zero exit suppresses re-execution"

requirement "SHALL-OPTIONS-5000" doc="The echo utility shall not recognize the \"--\" argument in the manner specified by Guideline 10 of XBD 12.2 Utility Syntax Guidelines ; \"--\" shall be recognized as a string operand."
begin interactive test "fc -l with string pattern operand"
  spawn -i
  expect "$ "
  send "echo unique_pat_cmd"
  expect "unique_pat_cmd"
  expect "$ "
  send "echo other_cmd"
  expect "other_cmd"
  expect "$ "
  send "fc -l -2 -1"
  expect "echo unique_pat_cmd"
  expect "echo other_cmd"
  sendeof
  wait
end interactive test "fc -l with string pattern operand"

requirement "SHALL-FC-1150" doc="If first represents a newer command than last , the commands shall be listed or edited in reverse sequence, equivalent to using -r ."
begin interactive test "fc -l reverse order"
  spawn -i
  expect "$ "
  send "echo rev_first"
  expect "rev_first"
  expect "$ "
  send "echo rev_second"
  expect "rev_second"
  expect "$ "
  send "fc -l -1 -2"
  expect "rev_second"
  expect "rev_first"
  sendeof
  wait
end interactive test "fc -l reverse order"

requirement "SHALL-FC-1143" doc="The number of previous commands that can be accessed shall be determined by the value of the HISTSIZE variable."
begin interactive test "HISTSIZE controls accessible history"
  spawn -i
  expect "$ "
  send "HISTSIZE=3"
  expect "$ "
  send "echo old_gone"
  expect "$ "
  send "echo keep1"
  expect "$ "
  send "echo keep2"
  expect "$ "
  send "echo keep3"
  expect "$ "
  send "fc -l"
  not_expect "old_gone"
  expect "keep"
  sendeof
  wait
end interactive test "HISTSIZE controls accessible history"

requirement "SHALL-FC-1164" doc="Otherwise, the exit status shall be that of the commands executed by fc ."
begin interactive test "fc -l exit status is zero"
  spawn -i
  expect "$ "
  send "echo status_test"
  expect "status_test"
  expect "$ "
  send "fc -l; echo fc_exit_$?"
  expect "fc_exit_0"
  sendeof
  wait
end interactive test "fc -l exit status is zero"

requirement "SHALL-FC-1131" doc="When the number reaches an implementation-defined upper limit, which shall be no smaller than the value in HISTSIZE or 32767 (whichever is greater), the shell may wrap the numbers, starting the next command with a lower number (usually 1)."
begin interactive test "fc -l with absolute line numbers"
  spawn -i
  expect "$ "
  send "echo a"
  expect "a"
  expect "$ "
  send "echo b"
  expect "b"
  expect "$ "
  send "echo c"
  expect "c"
  expect "$ "
  send "fc -l 1 3"
  expect "echo a"
  expect "echo b"
  expect "echo c"
  sendeof
  wait
end interactive test "fc -l with absolute line numbers"

requirement "SHALL-FC-1031" doc="When the -l option is used to list commands, the format of each command in the list shall be as follows: \"%d\\t%s\\n\", <line number>, <command>."
begin interactive test "fc -l with out-of-range line number"
  spawn -i
  expect "$ "
  send "fc -l 9999; echo fc_done"
  expect "fc_done"
  sendeof
  wait
end interactive test "fc -l with out-of-range line number"

requirement "SHALL-FC-1149" doc="Editing multiple commands shall be accomplished by presenting to the editor all of the commands at one time, each command starting on a new line."
begin interactive test "fc -s old=new with string-pattern operand"
  spawn -i
  expect "$ "
  send "echo OLD_VALUE"
  expect "OLD_VALUE"
  expect "$ "
  send "fc -s OLD=NEW echo"
  expect "NEW_VALUE"
  sendeof
  wait
end interactive test "fc -s old=new with string-pattern operand"
