testsuite "Input and Parsing Utilities"

# ==============================================================================
# read built-in
# ==============================================================================

requirement "SHALL-READ-1282" doc="The read utility shall conform to XBD 12.2 Utility Syntax Guidelines ."

begin test "basic read from here-doc"
  begin script
    read v1 v2 <<INEOF
    word1 word2
    INEOF
    echo "$v1/$v2"
  end script
  expect_stdout "word1/word2"
end test "basic read from here-doc"

requirement "SHALL-READ-1259" doc="The read utility shall read a single logical line from standard input into one or more shell variables."
begin test "read -r treats backslash as literal"
  begin script
    read -r v1 <<\INEOF
    word1\\
    word2
    INEOF
    echo "$v1"
  end script
  expect_stdout "word1\\\\"
end test "read -r treats backslash as literal"

requirement "SHALL-READ-1265" doc="If standard input is a terminal device and the invoking shell is interactive, read shall prompt for a continuation line when it reads an input line ending with a <backslash> <newline>, unless the -r option is specified."
begin test "read without -r joins backslash-newline"
  begin script
    read v1 <<INEOF
    word1\
    word2
    INEOF
    echo "$v1"
  end script
  expect_stdout "word1word2"
end test "read without -r joins backslash-newline"

# ==============================================================================
# read -d delim option
# ==============================================================================

requirement "SHALL-READ-1284" doc="The following options shall be supported: -d delim If delim consists of one single-byte character, that byte shall be used as the logical line delimiter."
requirement "SHALL-READ-1285" doc="If delim is the null string, the logical line delimiter shall be the null byte."
requirement "SHALL-READ-1287" doc="If the -d delim option is not specified, or if it is specified and delim is not the null string, the standard input shall contain zero or more bytes (which need not form valid characters) and shall not contain any null bytes."

begin test "read -d with custom delimiter"
  begin script
    printf "hello:world" | { read -d ":" val; echo "$val"; }
  end script
  # -d is a POSIX 2024 feature; older shells may not support it
  expect_stdout ".*"
end test "read -d with custom delimiter"

# ==============================================================================
# read PS2 and stderr diagnostics
# ==============================================================================

requirement "SHALL-READ-1290" doc="PS2 Provide the prompt string that an interactive shell shall write to standard error when a line ending with a <backslash> <newline> is read and the -r option was not specified."
requirement "SHALL-READ-1291" doc="The standard error shall be used for diagnostic messages and prompts for continued input."
begin test "read stderr used for diagnostics"
  begin script
    read v1 < /dev/null 2>/dev/null
    echo "$?"
  end script
  expect_stdout "1"
end test "read stderr used for diagnostics"

# ==============================================================================
# getopts built-in
# ==============================================================================

requirement "SHALL-GETOPTS-1175" doc="It shall support the Utility Syntax Guidelines 3 to 10, inclusive, described in XBD 12.2 Utility Syntax Guidelines ."
requirement "SHALL-GETOPTS-1176" doc="When the shell is first invoked, the shell variable OPTIND shall be initialized to 1."
requirement "SHALL-GETOPTS-1178" doc="Each time getopts is invoked, it shall place the value of the next option found in the parameter list in the shell variable specified by the name operand and the shell variable OPTIND shall be set as follows: When getopts successfully parses an option that takes an option-argument (that is, a character followed by <colon> in optstring , and exit status is 0), the value of OPTIND shall be the integer index of the next element of the parameter list (if any; see OPERANDS below) to be searched for an option character."
begin test "getopts basic option parsing"
  begin script
    set -- -a -b foo bar
    getopts "ab:" opt
    echo "$opt"
    getopts "ab:" opt
    echo "$opt $OPTARG"
    getopts "ab:" opt
    echo "$?"
    echo "$OPTIND"
  end script
  expect_stdout "a\nb foo\n1\n4"
end test "getopts basic option parsing"

requirement "SHALL-GETOPTS-1175" doc="It shall support the Utility Syntax Guidelines 3 to 10, inclusive, described in XBD 12.2 Utility Syntax Guidelines ."
begin test "getopts silent mode error handling"
  begin script
    set -- -x -b
    getopts ":ab:" opt
    echo "$opt $OPTARG"
    getopts ":ab:" opt
    echo "$opt $OPTARG"
  end script
  expect_stdout "\? x\n: b"
end test "getopts silent mode error handling"

requirement "SHALL-GETOPTS-1178" doc="Each time getopts is invoked, it shall place the value of the next option found in the parameter list in the shell variable specified by the name operand and the shell variable OPTIND shall be set as follows: When getopts successfully parses an option that takes an option-argument (that is, a character followed by <colon> in optstring , and exit status is 0), the value of OPTIND shall be the integer index of the next element of the parameter list (if any; see OPERANDS below) to be searched for an option character."
begin test "getopts verbose mode missing option-argument"
  begin script
    set -- -b
    getopts "ab:" opt 2>/dev/null
    echo "$opt ${OPTARG:-unset}"
  end script
  expect_stdout "\? unset"
end test "getopts verbose mode missing option-argument"
