testsuite "Interactive Features"

# ==============================================================================
# The Face of the Shell: Prompt Strings ($PS1)
# ==============================================================================

requirement "SHALL-Command-History-List-031" doc="When the sh utility is being used interactively, it shall maintain a list of commands previously entered from the terminal in the file named by the HISTFILE environment variable."
requirement "SHALL-DESCRIPTION-602" doc="A user shall explicitly exit to leave the interactive shell."
requirement "SHALL-2-5-3-085" doc="Each time an interactive shell is ready to read a command, the value of this variable shall be subjected to parameter expansion (see 2.6.2 Parameter Expansion ) and exclamation-mark expansion (see below)."

begin interactive test "PS1 prompt expansion"
  spawn -i
  expect "$ "
  send "PS1=\"prompt> \""
  expect "prompt> "
  send "echo interactive-test"
  expect "interactive-test"
  sendeof
  wait
end interactive test "PS1 prompt expansion"

requirement "SHALL-2-5-3-089" doc="The other pass shall perform the other expansion(s) according to the rules in 2.6 Word Expansions ."
requirement "SHALL-2-5-3-086" doc="After expansion, the value shall be written to standard error."

begin interactive test "PS1 parameter expansion replaces variable references"
  spawn -i
  expect "$ "
  send "MYVAR=hello"
  expect "$ "
  send "PS1='${MYVAR}> '"
  expect "hello> "
  send "MYVAR=world"
  expect "world> "
  send "PS1='${MYVAR}> '"
  expect "world> "
  sendeof
  wait
end interactive test "PS1 parameter expansion replaces variable references"

requirement "SHALL-2-5-3-089" doc="The other pass shall perform the other expansion(s) according to the rules in 2.6 Word Expansions ."

begin interactive test "PS1 expansion re-evaluates on each prompt"
  spawn -i
  expect "$ "
  send "COUNTER=1"
  expect "$ "
  send "PS1='[$COUNTER]> '"
  expect "\[1\]> "
  send "COUNTER=2"
  expect "\[2\]> "
  send "COUNTER=3"
  expect "\[3\]> "
  sendeof
  wait
end interactive test "PS1 expansion re-evaluates on each prompt"

requirement "SHALL-2-5-3-089" doc="The other pass shall perform the other expansion(s) according to the rules in 2.6 Word Expansions ."

begin interactive test "PS1 parameter expansion with default value syntax"
  spawn -i
  expect "$ "
  send "unset NOVAR"
  expect "$ "
  send "PS1='${NOVAR:-fallback}> '"
  expect "fallback> "
  send "NOVAR=actual"
  expect "actual> "
  send "PS1='${NOVAR:-fallback}> '"
  expect "actual> "
  sendeof
  wait
end interactive test "PS1 parameter expansion with default value syntax"

requirement "SHALL-2-5-3-089" doc="The other pass shall perform the other expansion(s) according to the rules in 2.6 Word Expansions ."
requirement "SHALL-2-5-3-086" doc="After expansion, the value shall be written to standard error."

begin interactive test "PS1 expanded value is written to stderr"
  spawn -i
  expect "$ "
  send "MARKER=stderr_test_ok"
  expect "$ "
  send "PS1='${MARKER}> '"
  expect "stderr_test_ok> "
  sendeof
  wait
end interactive test "PS1 expanded value is written to stderr"

requirement "SHALL-2-5-3-086" doc="After expansion, the value shall be written to standard error."
begin test "PS1 prompt text is emitted to stderr stream"
  begin script
    $SHELL -i > ps1_stdout.txt 2> ps1_stderr.txt <<'EOF'
    PS1='ps1_stream_marker> '
    :
    exit
    EOF
    grep -q 'ps1_stream_marker> ' ps1_stderr.txt && echo stderr_ok || echo stderr_missing
    grep -q 'ps1_stream_marker> ' ps1_stdout.txt && echo stdout_leak || echo stdout_clean
  end script
  expect_stdout "stderr_ok\nstdout_clean"
end test "PS1 prompt text is emitted to stderr stream"

requirement "SHALL-2-5-3-092" doc="An <exclamation-mark> character escaped by another <exclamation-mark> character (that is, \"!!\" ) shall expand to a single <exclamation-mark> character."
begin interactive test "PS1 double exclamation becomes single literal exclamation"
  spawn -i
  expect "$ "
  send "PS1='bang!!> '"
  expect "bang!> "
  sendeof
  wait
end interactive test "PS1 double exclamation becomes single literal exclamation"

requirement "SHALL-V3CHAP02-1005" doc="The processing of the PS2 shell variable shall be supported if the system supports the User Portability Utilities option."
requirement "SHALL-2-5-3-095" doc="The default value shall be \"> \" ."
begin interactive test "PS2 default continuation prompt is greater-than space"
  spawn -i
  expect "$ "
  send "echo \\\n"
  expect "> "
  send "ok\n"
  expect "ok"
  sendeof
  wait
end interactive test "PS2 default continuation prompt is greater-than space"

requirement "SHALL-2-5-3-093" doc="Each time the user enters a <newline> prior to completing a command line in an interactive shell, the value of this variable shall be subjected to parameter expansion (see 2.6.2 Parameter Expansion )."
requirement "SHALL-V3CHAP02-1005" doc="The processing of the PS2 shell variable shall be supported if the system supports the User Portability Utilities option."
requirement "SHALL-2-5-3-094" doc="For PS2, after expansion, the value shall be written to standard error."
begin interactive test "PS2 parameter expansion is used for continuation prompt"
  spawn -i
  expect "$ "
  send "MYPS2=cont"
  expect "$ "
  send "PS2='${MYPS2}> '"
  expect "$ "
  send "echo \\\n"
  expect "cont> "
  send "ok\n"
  expect "ok"
  sendeof
  wait
end interactive test "PS2 parameter expansion is used for continuation prompt"

requirement "SHALL-2-5-3-094" doc="For PS2, after expansion, the value shall be written to standard error."
begin test "PS2 prompt text is emitted to stderr stream"
  begin script
    $SHELL -i > ps2_stdout.txt 2> ps2_stderr.txt <<'EOF'
    PS2='cont> '
    : \

    exit
    EOF
    grep -q 'cont> ' ps2_stderr.txt && echo stderr_ok || echo stderr_missing
    grep -q 'cont> ' ps2_stdout.txt && echo stdout_leak || echo stdout_clean
  end script
  expect_stdout "stderr_ok\nstdout_clean"
end test "PS2 prompt text is emitted to stderr stream"


# ==============================================================================
# Terminal Erase and Kill
# ==============================================================================

requirement "SHALL-RATIONALE-144" doc="Early proposals had the following list entry in vi Line Editing Insert Mode : \\ If followed by the erase or kill character, that character shall be inserted into the input line."
requirement "SHALL-RATIONALE-145" doc="Otherwise, the <backslash> itself shall be inserted into the input line."
