testsuite "Interactive Features"

# ==============================================================================
# The Face of the Shell: Prompt Strings ($PS1)
# ==============================================================================

requirement "SHALL-Command-History-List-031" doc="When used interactively, shell shall maintain command history in HISTFILE"
requirement "SHALL-DESCRIPTION-602" doc="A user shall explicitly exit to leave the interactive shell"
requirement "SHALL-2-5-3-085" doc="Parameters: PS1: Each time an interactive shell is ready to read a command, the value of this variable shall be subjected to parameter expansion"

begin interactive test "PS1 prompt expansion"
  spawn {{SHELL}} -i
  expect "$ "
  send "PS1=\"prompt> \""
  expect "prompt> "
  send "echo interactive-test"
  expect "interactive-test"
  sendeof
  wait
end interactive test "PS1 prompt expansion"


# ==============================================================================
# Terminal Erase and Kill
# ==============================================================================

requirement "SHALL-RATIONALE-144" doc="Early proposals had the following list entry in vi Line Editing Insert Mode: backslash followed by erase or kill character, that character shall be inserted into the input line"
requirement "SHALL-RATIONALE-145" doc="Otherwise, the backslash itself shall be inserted into the input line"
