# ==============================================================================
# X edge cases
# ==============================================================================

requirement "SHALL-vi-Line-Editing-Command-Mode-119" doc="If the line contained no characters, the terminal shall be alerted and the cursor shall not be moved"
requirement "SHALL-vi-Line-Editing-Command-Mode-118" doc="If the line contained a single character, the X command shall have no effect"

begin interactive test "X on first char no effect"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -o vi"
  expect "$ "
  sendraw 65 63 68 6f 20 61
  sendraw 1b
  sleep 100ms
  sendraw 30 77
  sleep 50ms
  sendraw 58
  sleep 100ms
  sendraw 0a
  expect "a"
  expect "$ "
  sendeof
  wait
end interactive test "X on first char no effect"

requirement "SHALL-vi-Line-Editing-Command-Mode-120" doc="If the count is larger than the number of characters before the cursor, this shall not be considered an error; all the characters from before the cursor to the beginning of the line shall be deleted"

begin interactive test "X count overflow 99X"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -o vi"
  expect "$ "
  sendraw 65 63 68 6f 20 61 62 63 64
  sendraw 1b
  sleep 100ms
  sendraw 39 39 58
  sleep 100ms
  sendraw 0a
  expect "$ "
  sendeof
  wait
end interactive test "X count overflow 99X"


# ==============================================================================
# Yank (y + motion): cursor position unchanged
# ==============================================================================

requirement "SHALL-SH-1041" doc="A number count shall be applied to the motion command"
requirement "SHALL-SH-1042" doc="If the motion command would move toward the beginning of the command line, the character under the current cursor position shall not be included in the set of yanked characters"
requirement "SHALL-SH-1043" doc="If the motion command is y, the entire current command line shall be yanked into the save buffer"
requirement "SHALL-SH-1044" doc="The current cursor position shall be unchanged"
requirement "SHALL-SH-1045" doc="If the count is larger than the number of characters between the cursor and the end of the line, all remaining characters shall be yanked"
requirement "SHALL-vi-Line-Editing-Command-Mode-122" doc="The current character position shall be unchanged"

begin interactive test "yank yw cursor unchanged"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -o vi"
  expect "$ "
  sendraw 65 63 68 6f 20 61 62 63
  sendraw 1b
  sleep 100ms
  sendraw 30
  sleep 50ms
  sendraw 79 77
  sleep 50ms
  sendraw 72 5a
  sleep 100ms
  sendraw 0a
  expect "Zcho"
  expect "$ "
  sendeof
  wait
end interactive test "yank yw cursor unchanged"


# ==============================================================================
# History k/- past HISTSIZE boundary
# ==============================================================================

requirement "SHALL-vi-Line-Editing-Command-Mode-131" doc="If a k or - command would retreat past the maximum number of commands in effect for this shell, the terminal shall be alerted, and the command shall have no effect"

begin interactive test "history k past HISTSIZE boundary"
  spawn {{SHELL}} -i
  expect "$ "
  send "set -o vi"
  expect "$ "
  send "echo only_cmd"
  expect "only_cmd"
  expect "$ "
  sendraw 1b
  sleep 100ms
  sendraw 6b
  sleep 100ms
  sendraw 6b
  sleep 100ms
  sendraw 0a
  expect "only_cmd"
  expect "$ "
  sendeof
  wait
end interactive test "history k past HISTSIZE boundary"


