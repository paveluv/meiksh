testsuite "Shell Mail Notification"

# ==============================================================================
# MAIL notification on file creation
# ==============================================================================

requirement "SHALL-SH-1025" doc="If MAIL is set, the shell shall inform the user if the file named by the variable is created or if its modification time has changed."
requirement "SHALL-SH-1026" doc="Informing the user shall be accomplished by writing a string of unspecified format to standard error prior to the writing of the next primary prompt string."
requirement "SHALL-SH-1027" doc="Such check shall be performed only after the completion of the interval defined by the MAILCHECK variable after the last such check."

begin interactive test "MAIL notification on file creation"
  spawn {{SHELL}} -i
  expect "$ "
  send "bind 'set enable-bracketed-paste off'"
  expect "$ "
  send "MAILCHECK=1"
  expect "$ "
  send "MAIL=$HOME/mbox1"
  expect "$ "
  sleep 1100ms
  send "echo created > $HOME/mbox1"
  expect timeout=5s "(mail|Mail|MAIL|you have)"
  expect "$ "
  sendeof
  wait
end interactive test "MAIL notification on file creation"

# ==============================================================================
# MAIL not checked if MAILPATH is set
# ==============================================================================

requirement "SHALL-SH-1028" doc="The user shall be informed only if MAIL is set and MAILPATH is not set."

begin interactive test "MAIL not checked if MAILPATH is set"
  spawn {{SHELL}} -i
  expect "$ "
  send "bind 'set enable-bracketed-paste off'"
  expect "$ "
  send "MAILCHECK=1"
  expect "$ "
  send "MAILPATH=/tmp/nonexistent_mailpath"
  expect "$ "
  send "MAIL=$HOME/mbox2"
  expect "$ "
  sleep 1100ms
  send "echo data > $HOME/mbox2"
  not_expect timeout=3s "(mail|Mail|MAIL|you have)"
  expect "$ "
  sendeof
  wait
end interactive test "MAIL not checked if MAILPATH is set"

# ==============================================================================
# MAILCHECK=0 checks at every prompt
# ==============================================================================

requirement "SHALL-SH-1029" doc="MAILCHECK specifies how often (in seconds) the shell shall check for the arrival of mail."
requirement "SHALL-SH-1031" doc="If set to zero, the shell shall check before issuing each primary prompt."

begin interactive test "MAILCHECK=0 checks at every prompt"
  spawn {{SHELL}} -i
  expect "$ "
  send "bind 'set enable-bracketed-paste off'"
  expect "$ "
  send "MAILCHECK=0"
  expect "$ "
  send "touch $HOME/mbox3"
  expect "$ "
  send "MAIL=$HOME/mbox3"
  expect "$ "
  sleep 1100ms
  send "echo data >> $HOME/mbox3"
  expect timeout=5s "(mail|Mail|MAIL|you have)"
  expect "$ "
  sendeof
  wait
end interactive test "MAILCHECK=0 checks at every prompt"

# ==============================================================================
# MAILPATH with multiple paths and custom messages
# ==============================================================================

requirement "SHALL-SH-1032" doc="If MAILPATH is set, the shell shall inform the user if any of the files named by the variable are created or if any of their modification times change."
requirement "SHALL-SH-1033" doc="Each pathname can be followed by '%' and a string that shall be subjected to parameter expansion and written to standard error."

begin interactive test "MAILPATH with custom message"
  spawn {{SHELL}} -i
  expect "$ "
  send "bind 'set enable-bracketed-paste off'"
  expect "$ "
  send "MAILCHECK=0"
  expect "$ "
  send "touch $HOME/mp1"
  expect "$ "
  send "MAILPATH=\"$HOME/mp1%custom msg here:$HOME/mp2\""
  expect "$ "
  sleep 1100ms
  send "echo data >> $HOME/mp1"
  expect timeout=5s "custom msg here"
  expect "$ "
  sendeof
  wait
end interactive test "MAILPATH with custom message"

# ==============================================================================
# MAILPATH percent escaping
# ==============================================================================

requirement "SHALL-SH-1034" doc="If a '%' character in the pathname is preceded by a backslash, it shall be treated as a literal '%' in the pathname."

begin interactive test "MAILPATH percent escaping"
  spawn {{SHELL}} -i
  expect "$ "
  send "MAILPATH='/tmp/file\\%name'"
  expect "$ "
  send "echo ok"
  expect "ok"
  expect "$ "
  sendeof
  wait
end interactive test "MAILPATH percent escaping"
