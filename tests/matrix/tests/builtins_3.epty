testsuite "Special Built-ins (export, readonly, set, unset)"

# ==============================================================================
# The 'export' Utility
# ==============================================================================


requirement "SHALL-DESCRIPTION-562" doc="The export special built-in shall support XBD 12.2 Utility Syntax Guidelines ."
requirement "SHALL-Issue-6-628" doc="IEEE Std 1003.1-2001/Cor 1-2002, item XCU/TC1/D6/9 is applied, changing text in the DESCRIPTION from: \"Write the accumulated user and system times for the shell and for all of its child processes ...\" to: \"The times utility shall write the accumulated user and system times for the shell and for all of its child processes ...\"."
requirement "SHALL-DESCRIPTION-617" doc="The positional parameters shall be shifted."
begin test "export makes variable available to child processes"
  begin script
    foo="bar"
    export foo baz="qux"
    env | grep -E "^(foo|baz)=" | sort
  end script
  expect_stdout "baz=qux\nfoo=bar"
end test "export makes variable available to child processes"

requirement "SHALL-DESCRIPTION-654" doc="If neither -f nor -v is specified, name refers to a variable; if a variable by that name does not exist, it is unspecified whether a function by that name, if any, shall be unset."
requirement "SHALL-DESCRIPTION-656" doc="The unset special built-in shall support XBD 12.2 Utility Syntax Guidelines ."
requirement "SHALL-DESCRIPTION-620" doc="The value n shall be an unsigned decimal integer less than or equal to the value of the special parameter '#' ."
begin test "export -p generates eval-able output"
  begin script
    export EXPORTED_VAR="val with spaces"
    output=$(export -p | grep "EXPORTED_VAR=")
    unset EXPORTED_VAR
    eval "$output"
    echo "$EXPORTED_VAR"
  end script
  expect_stdout "val with spaces"
end test "export -p generates eval-able output"

requirement "SHALL-DESCRIPTION-567" doc="The variables whose name s are specified shall be given the readonly attribute."
requirement "SHALL-DESCRIPTION-572" doc="The readonly special built-in shall support XBD 12.2 Utility Syntax Guidelines ."
begin test "readonly prevents assignment"
  begin script
    readonly RO_VAR="protected"
    RO_VAR="mutated"
  end script
  not_expect_exit_code 0
end test "readonly prevents assignment"

requirement "SHALL-DESCRIPTION-645" doc="The shell shall format the output, including the proper use of quoting, so that it is suitable for reinput to the shell as commands that achieve the same trapping results for the set of conditions included in the output, except for signals that were ignored on entry to the shell as described above."
requirement "SHALL-DESCRIPTION-568" doc="As described in XBD 8.1 Environment Variable Definition , conforming applications shall not request to mark a variable as readonly if it is documented as being manipulated by a shell built-in utility, as it may render those utilities unable to complete successfully."
requirement "SHALL-DESCRIPTION-655" doc="Unsetting a variable or function that was not previously set shall not be considered an error and does not cause the shell to abort."
begin test "readonly -p generates eval-able output"
  begin script
    readonly RO_VAR="protected"
    output=$(readonly -p | grep "RO_VAR=")
    echo "$output; echo \"$RO_VAR\"" > tmp_ro.sh
    $SHELL tmp_ro.sh
  end script
  expect_stdout "protected"
end test "readonly -p generates eval-able output"

requirement "SHALL-DESCRIPTION-558" doc="The shell shall give the export attribute to the variables corresponding to the specified name s, which shall cause them to be in the environment of subsequently executed commands."
requirement "SHALL-DESCRIPTION-559" doc="If the name of a variable is followed by = word , then the value of that variable shall be set to word ."
requirement "SHALL-DESCRIPTION-580" doc="If no option s or argument s are specified, set shall write the names and values of all shell variables in the collation sequence of the current locale."
begin test "set lists all shell variables"
  begin script
    MY_TEST_VAR="hello_set"
    set | grep -q "^MY_TEST_VAR=hello_set$" && echo "found"
  end script
  expect_stdout "found"
end test "set lists all shell variables"

requirement "SHALL-Issue-6-566" doc="IEEE Std 1003.1-2001/Cor 1-2002, item XCU/TC1/D6/6 is applied, adding the following text to the end of the first paragraph of the DESCRIPTION: \"If the name of a variable is followed by = word , then the value of that variable shall be set to word .\"."
requirement "SHALL-Issue-6-575" doc="IEEE Std 1003.1-2001/Cor 1-2002, item XCU/TC1/D6/7 is applied, adding the following text to the end of the first paragraph of the DESCRIPTION: \"If the name of a variable is followed by = word , then the value of that variable shall be set to word .\"."
requirement "SHALL-DESCRIPTION-618" doc="Positional parameter 1 shall be assigned the value of parameter (1+ n ), parameter 2 shall be assigned the value of parameter (2+ n ), and so on."
begin test "unset removes a variable"
  begin script
    my_var="value"
    unset my_var
    echo "${my_var:-is_unset}"
  end script
  expect_stdout "is_unset"
end test "unset removes a variable"

requirement "SHALL-DESCRIPTION-651" doc="The unset utility shall unset each variable or function definition specified by name that does not have the readonly attribute and remove any attributes other than readonly that have been given to name (see 2.15 Special Built-In Utilities export and readonly )."
requirement "SHALL-DESCRIPTION-652" doc="If -v is specified, name refers to a variable name and the shell shall unset it and remove it from the environment."
requirement "SHALL-DESCRIPTION-653" doc="If -f is specified, name refers to a function and the shell shall unset the function definition."
begin test "unset -f removes a function"
  begin script
    my_func() { echo "running"; }
    unset -f my_func
    my_func 2>/dev/null || echo "not found"
  end script
  expect_stdout "not found"
end test "unset -f removes a function"
