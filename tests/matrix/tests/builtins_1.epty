testsuite "Special Built-ins (break, continue, colon, dot, eval)"

# ==============================================================================
# The 'break' Utility
# ==============================================================================


requirement "SHALL-DESCRIPTION-515" doc="The application shall ensure that the value of n is a positive decimal integer."
requirement "SHALL-DESCRIPTION-513" doc="If n is not specified, break shall behave as if n was specified as 1."
requirement "SHALL-EXIT-STATUS-533" doc="If no readable file was found or if the commands in the file could not be parsed, and the shell is interactive (and therefore does not abort; see 2.8.1 Consequences of Shell Errors ), the exit status shall be non-zero."
begin test "break without n defaults to 1"
  begin script
    for i in 1 2 3; do
      echo $i
      break
      echo "no"
    done
    echo "done"
  end script
  expect_stdout "1\ndone"
end test "break without n defaults to 1"

requirement "SHALL-OPTIONS-520" doc="This utility shall not recognize the \"--\" argument in the manner specified by Guideline 10 of XBD 12.2 Utility Syntax Guidelines ."
requirement "SHALL-OPTIONS-521" doc="Implementations shall not support any options."
requirement "SHALL-DESCRIPTION-535" doc="The constructed command string shall be tokenized (see 2.3 Token Recognition ), parsed (see 2.10 Shell Grammar ), and executed by the shell in the current environment."
begin test "break 2 exits two loops"
  begin script
    for i in a b; do
      for j in 1 2
      do echo "$i$j"
      break 2
    done
    done
    echo "done"
  end script
  expect_stdout "a1\ndone"
end test "break 2 exits two loops"

requirement "SHALL-DESCRIPTION-512" doc="If n is specified, the break utility shall exit from the n th enclosing for , while , or until loop."
requirement "SHALL-DESCRIPTION-516" doc="If n is greater than the number of enclosing loops, the outermost enclosing loop shall be exited."
requirement "SHALL-DESCRIPTION-525" doc="If n is greater than the number of enclosing loops, the outermost enclosing loop shall be used."
begin test "break n greater than enclosing loops"
  begin script
    for i in a b; do
      echo $i
      break 5
    done
    echo "done"
  end script
  expect_stdout "a\ndone"
end test "break n greater than enclosing loops"

requirement "SHALL-DESCRIPTION-522" doc="If n is specified, the continue utility shall return to the top of the n th enclosing for , while , or until loop."
requirement "SHALL-DESCRIPTION-523" doc="If n is not specified, continue shall behave as if n was specified as 1."
requirement "SHALL-DESCRIPTION-526" doc="The meaning of \"enclosing\" shall be as specified in the description of the break utility."
begin test "continue without n defaults to 1"
  begin script
    for i in 1 2; do
      echo $i
      continue
      echo "no"
    done
    echo "done"
  end script
  expect_stdout "1\n2\ndone"
end test "continue without n defaults to 1"

requirement "SHALL-DESCRIPTION-517" doc="A loop shall enclose a break or continue command if the loop lexically encloses the command."
requirement "SHALL-DESCRIPTION-514" doc="Execution shall continue with the command immediately following the exited loop."
requirement "SHALL-DESCRIPTION-531" doc="The dot special built-in shall support XBD 12.2 Utility Syntax Guidelines , except for Guidelines 1 and 2."
begin test "continue 2 returns to outer loop"
  begin script
    for i in a b; do
      echo "outer $i"
      for j in 1 2; do
        echo "inner $j"
        continue 2
      done
    done
    echo "done"
  end script
  expect_stdout "outer a\ninner 1\nouter b\ninner 1\ndone"
end test "continue 2 returns to outer loop"

requirement "SHALL-DESCRIPTION-519" doc="This utility shall do nothing except return a 0 exit status."
begin test "colon returns exit code 0"
  begin script
    :
  end script
  expect_exit_code 0
end test "colon returns exit code 0"

requirement "SHALL-DESCRIPTION-534" doc="The eval utility shall construct a command string by concatenating argument s together, separating each with a <space> character."
begin test "eval concatenates and executes arguments"
  begin script
    foo="bar"
    eval echo "$foo" "and" "baz"
  end script
  expect_stdout "bar and baz"
end test "eval concatenates and executes arguments"

requirement "SHALL-DESCRIPTION-528" doc="The shell shall tokenize (see 2.3 Token Recognition ) the contents of the file , parse the tokens (see 2.10 Shell Grammar ), and execute the resulting commands in the current environment."
requirement "SHALL-DESCRIPTION-530" doc="If no readable file is found, a non-interactive shell shall abort; an interactive shell shall write a diagnostic message to standard error."
begin test "dot sources file in current directory"
  begin script
    echo 'export SOURCED_VAR=hello' > tmp_source.sh
    . ./tmp_source.sh
    echo "$SOURCED_VAR"
  end script
  expect_stdout "hello"
end test "dot sources file in current directory"

requirement "SHALL-DESCRIPTION-529" doc="If file does not contain a <slash>, the shell shall use the search path specified by PATH to find the directory containing file ."
begin test "dot sources file via PATH resolution"
  begin script
    mkdir -p tmp_bin
    echo 'export SOURCED_VAR=path_resolved' > tmp_bin/tmp_source.sh
    PATH="$PWD/tmp_bin:$PATH" . tmp_source.sh
    echo "$SOURCED_VAR"
  end script
  expect_stdout "path_resolved"
end test "dot sources file via PATH resolution"
