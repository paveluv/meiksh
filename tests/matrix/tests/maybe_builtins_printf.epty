requirement "SHALL-ENVIRONMENT-VARIABLES-5023" doc="The following environment variables shall affect the execution of printf : LANG Provide a default value for the internationalization variables that are unset or null. (See XBD 8.2 Internationalization Variables the precedence of internationalization variables used to determine the values of locale categories.) LC_ALL If set to a non-empty string value, override the values of all the other internationalization variables."
begin test "printf %d non-numeric produces stderr diagnostic"
  script
    printf "%d" not_a_number 2>&1 >/dev/null
  expect
    stdout ".+"
    stderr ""
    exit_code !=0
end test "printf %d non-numeric produces stderr diagnostic"

# ==============================================================================
# Not an error if argument not completely used for b, c, s
# ==============================================================================

requirement "SHALL-EXTENDED-DESCRIPTION-5051" doc="It shall not be considered an error if an argument operand is not completely used for a b , c , or s conversion."

begin test "printf %c with multi-char arg exits 0"
  script
    printf "%c" hello
  expect
    stdout "(.|\n)*"
    stderr ""
    exit_code 0
end test "printf %c with multi-char arg exits 0"

requirement "SHALL-DESCRIPTION-5020" doc="The printf utility shall write formatted operands to the standard output."
begin test "printf %.3s with truncation exits 0"
  script
    printf "%.3s" hello
  expect
    stdout "(.|\n)*"
    stderr ""
    exit_code 0
end test "printf %.3s with truncation exits 0"

requirement "SHALL-DESCRIPTION-5020" doc="The printf utility shall write formatted operands to the standard output."
begin test "printf %b with long arg exits 0"
  script
    printf "%b" "hello world"
  expect
    stdout "(.|\n)*"
    stderr ""
    exit_code 0
end test "printf %b with long arg exits 0"

requirement "SHALL-DESCRIPTION-5020" doc="The printf utility shall write formatted operands to the standard output."
begin test "printf %c output correct despite partial use"
  script
    printf "%c" hello
  expect
    stdout "h"
    stderr ""
    exit_code 0
end test "printf %c output correct despite partial use"

requirement "SHALL-DESCRIPTION-5020" doc="The printf utility shall write formatted operands to the standard output."
begin test "printf %.3s output correct despite truncation"
  script
    printf "%.3s" hello
  expect
    stdout "hel"
    stderr ""
    exit_code 0
end test "printf %.3s output correct despite truncation"

# ==============================================================================
# printf: %n$ format reuse — n refers to nth arg after highest consumed
# ==============================================================================

requirement "SHALL-EXTENDED-DESCRIPTION-5044" doc="If conversion specifications beginning with a \"% n $\" sequence are used, on format reuse the value of n shall refer to the n th argument operand following the highest numbered argument operand consumed by the previous use of the format operand."

begin test "printf %n$ format reuse"
  script
    /usr/bin/printf '%1$s %2$s\n' a b c d
  expect
    stdout "a b\nc d"
    stderr ""
    exit_code 0
end test "printf %n$ format reuse"
