testsuite "Pattern Matching Notation"

# ==============================================================================
# Single Character Matching
# ==============================================================================

requirement "SHALL-2-14-1-486" doc="A <question-mark> is a pattern that shall match any character."
requirement "SHALL-2-14-1-481" doc="An ordinary character is a pattern that shall match itself."
requirement "SHALL-2-14-1-476" doc="The following patterns shall match a single character: ordinary characters, special pattern characters, and pattern bracket expressions."
requirement "SHALL-2-14-1-482" doc="Matching shall be based on the bit pattern used for encoding the character, not on the graphic representation of the character."
requirement "SHALL-2-14-1-478" doc="When unquoted, unescaped, and not inside a bracket expression, the following three characters shall have special meaning in the specification of patterns."

begin test "? matches single character in case"
  begin script
    case "apple" in
        a??le) echo "match" ;;
        *) echo "no" ;;
    esac
  end script
  expect_stdout "match"
end test "? matches single character in case"

# ==============================================================================
# Multi-Character Matching
# ==============================================================================

requirement "SHALL-2-14-2-490" doc="The <asterisk> is a pattern that shall match any string, including the null string."
requirement "SHALL-2-14-1-487" doc="An <asterisk> is a pattern that shall match multiple characters, as described in 2.14.2 Patterns Matching Multiple Characters."

begin test "* matches multiple characters and null string in case"
  begin script
    case "apple" in
        a*e) echo "match_1" ;;
    esac
    case "apple" in
        apple*) echo "match_2" ;;
    esac
  end script
  expect_stdout "match_1\nmatch_2"
end test "* matches multiple characters and null string in case"

# ==============================================================================
# Bracket Expressions
# ==============================================================================

requirement "SHALL-2-14-1-488" doc="A <left-square-bracket> shall introduce a bracket expression if the characters following it meet the requirements for bracket expressions."
requirement "SHALL-2-14-1-489" doc="A <left-square-bracket> that does not introduce a valid bracket expression shall match the character itself."
requirement "SHALL-2-14-1-477" doc="The pattern bracket expression also shall match a single collating element."

begin test "bracket expression matches one of the listed chars"
  begin script
    case "b" in
        [abc]) echo "match_bracket" ;;
    esac
    case "[" in
        [) echo "match_literal" ;;
    esac
  end script
  expect_stdout "match_bracket\nmatch_literal"
end test "bracket expression matches one of the listed chars"

# ==============================================================================
# Escaping and Quoting
# ==============================================================================

requirement "SHALL-2-14-1-478" doc="When unquoted, unescaped, and not inside a bracket expression, the following three characters shall have special meaning in the specification of patterns."
requirement "SHALL-2-14-1-479" doc="A <backslash> character that is not inside a bracket expression shall preserve the literal value of the following character."
requirement "SHALL-2-14-1-480" doc="All of the requirements and effects of quoting on ordinary, shell special, and special pattern characters shall apply to escaping in this context."
requirement "SHALL-2-14-1-483" doc="If any character is quoted or escaped with a <backslash>, that pattern shall match the character itself."
requirement "SHALL-2-14-1-484" doc="The application shall ensure that it quotes or escapes any character that would otherwise be treated as special, in order for it to be matched as an ordinary character."

begin test "quoted and escaped * match literal asterisk"
  begin script
    case "a*b" in
        "a*b") echo "quoted" ;;
    esac
    case "a*b" in
        a\*b) echo "escaped" ;;
    esac
  end script
  expect_stdout "quoted\nescaped"
end test "quoted and escaped * match literal asterisk"

# ==============================================================================
# Patterns Matching Multiple Characters
# ==============================================================================

requirement "SHALL-2-14-2-491" doc="The concatenation of patterns matching a single character is a valid pattern that shall match the concatenation of the single characters or collating elements matched by each of the concatenated patterns."
requirement "SHALL-2-14-2-492" doc="Each <asterisk> shall match a string of zero or more characters, matching the greatest possible number of characters that still allows the remainder of the pattern to match the string."

begin test "concatenated patterns and greedy asterisk"
  begin script
    case "xyzabc" in
        x*c) echo yes ;;
        *) echo no ;;
    esac
  end script
  expect_stdout "yes"
end test "concatenated patterns and greedy asterisk"

# ==============================================================================
# Pathname Expansion Rules
# ==============================================================================

requirement "SHALL-2-14-3-493" doc="The <slash> character in a pathname shall be explicitly matched by using one or more <slash> characters in the pattern; it shall neither be matched by the <asterisk> or <question-mark> special characters nor by a bracket expression."
requirement "SHALL-2-14-3-494" doc="<slash> characters in the pattern shall be identified before bracket expressions; thus, a <slash> cannot be included in a pattern bracket expression used for filename expansion."
requirement "SHALL-2-14-3-495" doc="If a <slash> character is found following an unescaped <left-square-bracket> character before a corresponding <right-square-bracket> is found, the open bracket shall be treated as an ordinary character."

begin test "* does not match across slash in pathname"
  begin script
    mkdir -p tmp_pattern/dir
    touch tmp_pattern/dir/file.txt tmp_pattern/dir/file.md tmp_pattern/a.txt
    echo tmp_pattern/*/file.txt
  end script
  expect_stdout "tmp_pattern/dir/file.txt"
end test "* does not match across slash in pathname"

begin test "* without slash does not match dir/file"
  begin script
    mkdir -p tmp_pattern/dir
    touch tmp_pattern/dir/file.txt tmp_pattern/a.txt
    echo tmp_pattern/*file.txt
  end script
  expect_stdout "tmp_pattern/\*file.txt"
end test "* without slash does not match dir/file"

# ==============================================================================
# Dotfile Matching
# ==============================================================================

requirement "SHALL-2-14-3-496" doc="If a filename begins with a <period>, the <period> shall be explicitly matched by using a <period> as the first character of the pattern or immediately following a <slash> character."
requirement "SHALL-2-14-3-497" doc="The leading <period> shall not be matched by the <asterisk> or <question-mark> special characters."

begin test "glob * does not match dotfiles"
  begin script
    mkdir -p tmp_pattern
    touch tmp_pattern/.hidden tmp_pattern/a.txt tmp_pattern/dir
    echo tmp_pattern/*
  end script
  expect_stdout_line ".*a\.txt.*dir.*"
  not_expect_stdout_line ".*\.hidden.*"
end test "glob * does not match dotfiles"

begin test ".* matches hidden files"
  begin script
    mkdir -p tmp_pattern
    touch tmp_pattern/.hidden
    echo tmp_pattern/.*
  end script
  expect_stdout_line ".*\.hidden.*"
end test ".* matches hidden files"

# ==============================================================================
# Pattern vs Existing Filenames
# ==============================================================================

requirement "SHALL-2-14-3-498" doc="If a specified pattern contains any '*', '?' or '[' characters that will be treated as special, it shall be matched against existing filenames and pathnames."
requirement "SHALL-2-14-3-499" doc="Each component that contains any such characters shall require read permission in the directory containing that component."
requirement "SHALL-2-14-3-500" doc="Any component, except the last, that does not contain any '*', '?' or '[' characters that will be treated as special shall require search permission."
requirement "SHALL-2-14-3-501" doc="If these permissions are denied, this shall not be considered an error and pathname expansion shall continue as if no matching directory entries had been found."
requirement "SHALL-2-14-3-502" doc="If the pattern matches any existing filenames or pathnames, the pattern shall be replaced with those filenames and pathnames, sorted according to the collating sequence in effect in the current locale."
requirement "SHALL-2-14-3-503" doc="If this collating sequence does not have a total ordering of all characters, any filenames or pathnames that collate equally shall be further compared byte-by-byte using the collating sequence for the POSIX locale."
requirement "SHALL-2-14-3-504" doc="If the pattern does not match any existing filenames or pathnames, the pattern string shall be left unchanged."
requirement "SHALL-2-14-3-505" doc="If a specified pattern does not contain any '*', '?' or '[' characters that will be treated as special, the pattern string shall be left unchanged."

begin test "unmatched glob pattern left unchanged"
  begin script
    mkdir -p tmp_pattern
    echo tmp_pattern/*.md
  end script
  expect_stdout "tmp_pattern/\*.md"
end test "unmatched glob pattern left unchanged"
