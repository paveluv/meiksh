testsuite "Extended umask Built-in"

# ==============================================================================
# umask sets file mode creation mask of current shell
# ==============================================================================

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."

begin test "umask 0022 exits successfully"
  script
    umask 0022
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "umask 0022 exits successfully"

requirement "SHALL-UMASK-1319" doc="If the mask operand is not specified, the umask utility shall write to standard output the value of the file mode creation mask of the invoking process."
begin test "umask 0022 reports correct value"
  script
    umask 0022
    umask
  expect
    stdout "0*022"
    stderr ""
    exit_code 0
end test "umask 0022 reports correct value"

# ==============================================================================
# Mask affects initial permission bits of new files
# ==============================================================================

requirement "SHALL-UMASK-1317" doc="This mask shall affect the initial value of the file permission bits of subsequently created files."

begin test "umask affects file permissions"
  script
    _d=$(mktemp -d)
    umask 0077
    > "$_d/test_077"
    umask 0000
    > "$_d/test_000"
    _p077=$(ls -l "$_d/test_077" | awk '{print $1}')
    _p000=$(ls -l "$_d/test_000" | awk '{print $1}')
    rm -rf "$_d"
    [ "$_p077" != "$_p000" ] && echo different || echo same
  expect
    stdout "different"
    stderr ""
    exit_code 0
end test "umask affects file permissions"

# ==============================================================================
# If no mask operand, write current mask value to stdout
# ==============================================================================

requirement "SHALL-UMASK-1319" doc="If the mask operand is not specified, the umask utility shall write to standard output the value of the file mode creation mask of the invoking process."

begin test "umask with no operand produces output"
  script
    umask 0027
    umask
  expect
    stdout ".+"
    stderr ""
    exit_code 0
end test "umask with no operand produces output"

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."
begin test "umask with no operand reflects set value"
  script
    umask 0027
    umask
  expect
    stdout "0*027"
    stderr ""
    exit_code 0
end test "umask with no operand reflects set value"

# ==============================================================================
# Exit 0 on success or no mask operand
# ==============================================================================

requirement "SHALL-UMASK-1082" doc="The following exit values shall be returned: 0 The file mode creation mask was successfully changed, or no mask operand was supplied."

begin test "umask set exits 0"
  script
    umask 0022
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "umask set exits 0"

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."
begin test "umask query exits 0"
  script
    umask
  expect
    stdout "(.|\n)*"
    stderr ""
    exit_code 0
end test "umask query exits 0"

# ==============================================================================
# mask operand specifies new file mode creation mask
# ==============================================================================

requirement "SHALL-UMASK-1080" doc="The following operand shall be supported: mask A string specifying the new file mode creation mask."

begin test "umask octal operand 0037"
  script
    umask 0037
    umask
  expect
    stdout "0*037"
    stderr ""
    exit_code 0
end test "umask octal operand 0037"

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."
begin test "umask symbolic operand u=rwx,g=rx,o="
  script
    umask u=rwx,g=rx,o=
    umask
  expect
    stdout "0*027"
    stderr ""
    exit_code 0
end test "umask symbolic operand u=rwx,g=rx,o="

# ==============================================================================
# -S option produces symbolic output
# ==============================================================================

requirement "SHALL-UMASK-1079" doc="The following option shall be supported: -S Produce symbolic output."

begin test "umask -S produces symbolic output"
  script
    umask 0022
    umask -S
  expect
    stdout ".*u=.*g=.*o=.*"
    stderr ""
    exit_code 0
end test "umask -S produces symbolic output"

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."
begin test "umask -S reflects mask 0077"
  script
    umask 0077
    umask -S
  expect
    stdout ".*u=rwx.*g=.*o=.*"
    stderr ""
    exit_code 0
end test "umask -S reflects mask 0077"

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."
begin test "umask -S with mask 0000 shows all permissions"
  script
    umask 0000
    umask -S
  expect
    stdout ".*u=rwx.*g=rwx.*o=rwx.*"
    stderr ""
    exit_code 0
end test "umask -S with mask 0000 shows all permissions"

# ==============================================================================
# umask in subshell shall not affect caller
# ==============================================================================

requirement "SHALL-UMASK-1318" doc="If umask is called in a subshell or separate utility execution environment, such as one of the following: (umask 002) nohup umask ... find . -exec umask ... \\; it shall not affect the file mode creation mask of the caller's environment."

begin test "subshell umask does not affect parent"
  script
    umask 0022
    (umask 0077)
    umask
  expect
    stdout "0*022"
    stderr ""
    exit_code 0
end test "subshell umask does not affect parent"

requirement "SHALL-2-5-3-084" doc="In a subshell (see 2.13 Shell Execution Environment ), PPID shall be set to the same value as that of the parent of the current shell."
begin test "subshell and parent masks are independent"
  script
    umask 0022
    (umask 0077; echo inner=$(umask))
    echo outer=$(umask)
  expect
    stdout ".*inner=.*077.*\n.*outer=.*022.*"
    stderr ""
    exit_code 0
end test "subshell and parent masks are independent"

# ==============================================================================
# Default output recognized on subsequent invocation as mask
# ==============================================================================

requirement "SHALL-UMASK-1322" doc="The default output style is unspecified, but shall be recognized on a subsequent invocation of umask on the same system as a mask operand to restore the previous file mode creation mask."

begin test "umask default output round-trip"
  script
    umask 0037
    _saved=$(umask)
    umask 0000
    umask "$_saved"
    _restored=$(umask)
    [ "$_saved" = "$_restored" ] && echo roundtrip_ok || echo MISMATCH
  expect
    stdout "roundtrip_ok"
    stderr ""
    exit_code 0
end test "umask default output round-trip"

# ==============================================================================
# Default output recognized as mask operand
# ==============================================================================

requirement "SHALL-UMASK-1327" doc="The default output of a prior invocation of umask on the same system with no operand also shall be recognized as a mask operand."

begin test "umask default output as mask operand round-trip"
  script
    umask 0055
    _saved=$(umask)
    umask 0000
    umask "$_saved"
    _restored=$(umask)
    [ "$_saved" = "$_restored" ] && echo roundtrip_ok || echo MISMATCH
  expect
    stdout "roundtrip_ok"
    stderr ""
    exit_code 0
end test "umask default output as mask operand round-trip"

# ==============================================================================
# If mask operand specified, no output to stdout
# ==============================================================================

requirement "SHALL-UMASK-1332" doc="If a mask operand is specified, there shall be no output written to standard output."

begin test "umask with octal operand produces no stdout"
  script
    umask 0022
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "umask with octal operand produces no stdout"

requirement "SHALL-UMASK-1316" doc="The umask utility shall set the file mode creation mask of the current shell execution environment (see 2.13 Shell Execution Environment ) to the value specified by the mask operand."
begin test "umask with symbolic operand produces no stdout"
  script
    umask u=rwx,g=rx,o=rx
  expect
    stdout ""
    stderr ""
    exit_code 0
end test "umask with symbolic operand produces no stdout"
