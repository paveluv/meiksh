testsuite "Asynchronous Lists"

# ==============================================================================
# Background Execution and $!
# ==============================================================================

requirement "SHALL-2-9-3-1-320" doc="If an AND-OR list is terminated by the control operator <ampersand> ( '&' ), the shell shall execute the AND-OR list asynchronously in a subshell environment."
requirement "SHALL-2-9-3-1-321" doc="This subshell shall execute in the background; that is, the shell shall not wait for the subshell to terminate before executing the next command (if any); if there are no further commands to execute, the shell shall not wait for the subshell to terminate before exiting."
requirement "SHALL-2-9-3-1-322" doc="If job control is enabled (see set , -m ), the AND-OR list shall become a job-control background job and a job number shall be assigned to it."
requirement "SHALL-2-9-3-1-323" doc="If job control is disabled, the AND-OR list may become a non-job-control background job, in which case a job number shall be assigned to it; if no job number is assigned it shall become a background command but not a background job."
requirement "SHALL-2-9-3-1-324" doc="The process ID associated with the asynchronous AND-OR list shall become known in the current shell execution environment; see 2.13 Shell Execution Environment."
requirement "SHALL-2-9-3-1-325" doc="This process ID shall remain known until any one of the following occurs (and, unless otherwise specified, may continue to remain known after it occurs)."
requirement "SHALL-2-9-3-1-329" doc="If the shell is interactive and the asynchronous AND-OR list became a background job, the job number and process ID shall be written to standard error."

begin test "background job PID and wait"
  begin script
    echo "bg_test" > tmp_bg.txt &
    bg_pid=$!
    wait $bg_pid
    cat tmp_bg.txt
  end script
  expect_stdout "bg_test"
end test "background job PID and wait"

begin test "background job runs in subshell"
  begin script
    my_var="parent"
    my_var="child" &
    wait $!
    echo "$my_var"
  end script
  expect_stdout "parent"
end test "background job runs in subshell"


# ==============================================================================
# Background Standard Input
# ==============================================================================

requirement "SHALL-2-9-3-1-326" doc="If, and only if, job control is disabled, the standard input for the subshell in which an asynchronous AND-OR list is executed shall initially be assigned to an open file description that behaves as if /dev/null had been opened for reading only."
requirement "SHALL-2-9-3-1-327" doc="This initial assignment shall be overridden by any explicit redirection of standard input within the AND-OR list."

begin test "background stdin from /dev/null"
  begin script
    cat &
    wait $!
    echo "done"
  end script
  expect_stdout "done"
end test "background stdin from /dev/null"

begin test "explicit redirect overrides /dev/null"
  begin script
    echo "redirected" > tmp_in.txt
    cat < tmp_in.txt &
    wait $!
  end script
  expect_stdout "redirected"
end test "explicit redirect overrides /dev/null"
