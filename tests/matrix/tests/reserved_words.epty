testsuite "Reserved Words"

# ==============================================================================
# Unquoted Recognition
# ==============================================================================

requirement "SHALL-2-4-058" doc="When used in circumstances where reserved words are recognized (described above), the following words may be recognized as reserved words, in which case the results are unspecified except as described below for time : [[ ]] function namespace select time When the word time is recognized as a reserved word in circumstances where it would, if it were not a reserved word, be the command name (see 2.9.1.1 Order of Processing ) of a simple command that would execute the time utility in a manner other than one for which time states that the results are unspecified, the behavior shall be as specified for the time utility."

begin test "quoted reserved word is not recognized"
  begin script
    "if" true
    then echo yes
    fi
  end script
  not_expect_exit_code 0
end test "quoted reserved word is not recognized"

requirement "SHALL-2-4-058" doc="When used in circumstances where reserved words are recognized (described above), the following words may be recognized as reserved words, in which case the results are unspecified except as described below for time : [[ ]] function namespace select time When the word time is recognized as a reserved word in circumstances where it would, if it were not a reserved word, be the command name (see 2.9.1.1 Order of Processing ) of a simple command that would execute the time utility in a manner other than one for which time states that the results are unspecified, the behavior shall be as specified for the time utility."
begin test "unquoted reserved word builds syntax"
  begin script
    if true; then
      echo "yes"
    fi
  end script
  expect_stdout "yes"
end test "unquoted reserved word builds syntax"

requirement "SHALL-COMMAND-1113" doc="Shell functions, special built-in utilities, regular built-in utilities not associated with a PATH search, and shell reserved words shall be written as just their names."
begin test "reserved words as arguments are not special"
  begin script
    echo if while for done
  end script
  expect_stdout "if while for done"
end test "reserved words as arguments are not special"

# ==============================================================================
# The 'time' Reserved Word
# ==============================================================================

requirement "SHALL-2-4-058" doc="When used in circumstances where reserved words are recognized (described above), the following words may be recognized as reserved words, in which case the results are unspecified except as described below for time : [[ ]] function namespace select time When the word time is recognized as a reserved word in circumstances where it would, if it were not a reserved word, be the command name (see 2.9.1.1 Order of Processing ) of a simple command that would execute the time utility in a manner other than one for which time states that the results are unspecified, the behavior shall be as specified for the time utility."
begin test "time reserved word measures and passes through output"
  begin script
    time echo "measured"
  end script
  expect_stdout "measured"
end test "time reserved word measures and passes through output"
