testsuite "XBD 9.3.5 RE Bracket Expressions"

# ==============================================================================
# Bracket expression matching ordinary characters
# ==============================================================================

requirement "SHALL-XBD-9-3-5-2000" doc="A bracket expression shall match a specific set of single characters based on the non-empty set of list expressions contained in the bracket expression."
requirement "SHALL-XBD-9-3-5-2008" doc="A matching list expression specifies a list that shall match any single character that is matched by one of the expressions represented in the list."
requirement "SHALL-XBD-9-3-5-2009" doc="An ordinary character in the list shall only match that character."

begin test "bracket expression matches ordinary characters"
  begin script
    case b in [abc]) echo "match b" ;; *) echo "no match" ;; esac
    case z in [abc]) echo "match z" ;; *) echo "no match" ;; esac
  end script
  expect_stdout "match b\nno match"
end test "bracket expression matches ordinary characters"

# ==============================================================================
# Non-matching list (circumflex negation)
# ==============================================================================

requirement "SHALL-XBD-9-3-5-2010" doc="A non-matching list expression begins with a circumflex, and the matching behavior shall be the logical inverse of the corresponding matching list expression."
requirement "SHALL-XBD-9-3-5-2011" doc="The circumflex shall have this special meaning only when it occurs first in the list, immediately following the left-square-bracket."

begin test "circumflex negation in bracket expressions"
  begin script
    case b in [!ac]) echo "match b" ;; *) echo "no match b" ;; esac
    case a in [!ac]) echo "match a" ;; *) echo "no match a" ;; esac
    case a in [a!c]) echo "match a" ;; *) echo "no match a" ;; esac
    case '!' in [a!c]) echo "match !" ;; *) echo "no match !" ;; esac
  end script
  expect_stdout "match b\nno match a\nmatch a\nmatch !"
end test "circumflex negation in bracket expressions"

# ==============================================================================
# Right-square-bracket as first character in list
# ==============================================================================

requirement "SHALL-XBD-9-3-5-2001" doc="The right-square-bracket shall lose its special meaning and represent itself in a bracket expression if it occurs first in the list."
requirement "SHALL-XBD-9-3-5-2002" doc="Otherwise, it shall terminate the bracket expression, unless it appears in a collating symbol or is the ending right-square-bracket for a collating symbol, equivalence class, or character class."

begin test "right-square-bracket literal when first in list"
  begin script
    case "]" in []a]) echo "match ]" ;; *) echo "no match ]" ;; esac
    case a in []a]) echo "match a" ;; *) echo "no match a" ;; esac
    case "]" in [!]]) echo "no match ]" ;; *) echo "match ]" ;; esac
    case a in [!]]) echo "match a" ;; *) echo "no match a" ;; esac
  end script
  expect_stdout "match ]\nmatch a\nmatch ]\nmatch a"
end test "right-square-bracket literal when first in list"

# ==============================================================================
# Special characters lose meaning inside bracket expressions
# ==============================================================================

requirement "SHALL-XBD-9-3-5-2005" doc="When the bracket expression appears within a shell pattern, the special characters ? * and [ shall lose their special meaning within the bracket expression."

begin test "special chars lose meaning inside bracket expression"
  begin script
    case "?" in [?]) echo "match ?" ;; *) echo "no match ?" ;; esac
    case "*" in [*]) echo "match *" ;; *) echo "no match *" ;; esac
    case "[" in [\[]) echo "match [" ;; *) echo "no match [" ;; esac
    case "\\" in [\\]) echo "match \\" ;; *) echo "no match \\" ;; esac
  end script
  expect_stdout "match \?\nmatch \*\nmatch \[\nmatch \\"
end test "special chars lose meaning inside bracket expression"

# ==============================================================================
# Character class expressions
# ==============================================================================

requirement "SHALL-XBD-9-3-5-2019" doc="All character classes specified in the current locale shall be recognized."
requirement "SHALL-XBD-9-3-5-2006" doc="The following character class expressions shall be supported in all locales: [:alnum:] [:cntrl:] [:lower:] [:space:] [:alpha:] [:digit:] [:print:] [:upper:] [:blank:] [:graph:] [:punct:] [:xdigit:]"

begin test "character class expressions match correctly"
  begin script
    case "A" in [[:alpha:]]) echo "match A alpha" ;; *) echo "no match A alpha" ;; esac
    case "5" in [[:digit:]]) echo "match 5 digit" ;; *) echo "no match 5 digit" ;; esac
    case " " in [[:space:]]) echo "match space" ;; *) echo "no match space" ;; esac
    case "!" in [[:punct:]]) echo "match punct" ;; *) echo "no match punct" ;; esac
  end script
  expect_stdout "match A alpha\nmatch 5 digit\nmatch space\nmatch punct"
end test "character class expressions match correctly"

# ==============================================================================
# Range expressions and hyphen handling
# ==============================================================================

requirement "SHALL-XBD-9-3-5-2022" doc="A range expression shall be expressed as the starting point and the ending point separated by a hyphen-minus."
requirement "SHALL-XBD-9-3-5-2023" doc="The starting range point and the ending range point shall be a collating element or collating symbol."
requirement "SHALL-XBD-9-3-5-2024" doc="The hyphen-minus character shall be treated as itself if it occurs first or last in the list, or as an ending range point in a range expression."
requirement "SHALL-XBD-9-3-5-2025" doc="To use a hyphen-minus as the starting range point, it shall either come first in the bracket expression or be specified as a collating symbol."
requirement "SHALL-XBD-9-3-5-2026" doc="If a bracket expression specifies both - and ], the ] shall be placed first and the - last within the bracket expression."

begin test "range expressions and hyphen positioning"
  begin script
    case b in [a-c]) echo "match b range" ;; *) echo "no match b" ;; esac
    case "-" in [-ac]) echo "match - first" ;; *) echo "no match" ;; esac
    case "-" in [ac-]) echo "match - last" ;; *) echo "no match" ;; esac
    case "-" in []ac-]) echo "match ] and -" ;; *) echo "no match" ;; esac
    case "]" in []ac-]) echo "match ] in ]ac-" ;; *) echo "no match" ;; esac
  end script
  expect_stdout "match b range\nmatch - first\nmatch - last\nmatch ] and -\nmatch ] in ]ac-"
end test "range expressions and hyphen positioning"
